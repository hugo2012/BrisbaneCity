FUNCTION zppm_fm_get_agents_variation.
*"----------------------------------------------------------------------
*"*"Local Interface:
*"  TABLES
*"      ACTOR_TAB STRUCTURE  SWHACTOR
*"      AC_CONTAINER STRUCTURE  SWCONT
*"  EXCEPTIONS
*"      NO_AGENT_FOUND
*"----------------------------------------------------------------------


  INCLUDE <cntain>.

  DATA:
    ls_variation_wf     TYPE zppm_s_variation_wf,
    lv_current_step     TYPE mmpur_wf_current_approval_step,
    lv_total_steps      TYPE mmpur_wf_total_steps,
    lv_ppm_id           TYPE /rpm/tv_extid,
    lv_variation_number TYPE qmnum,
    lv_variation_type   TYPE qmart,
    lv_wf_path          TYPE zde_apprv_path. "WF_PATH.

  DATA: lr_actions         TYPE RANGE OF zwrkflow_act,
        lsr_action         LIKE LINE OF lr_actions,
        lv_container_value TYPE swc_object,
        lv_ppm_wf_action   TYPE zwrkflow_act,
        lv_WorkitemId      TYPE sww_wiid,
        lt_recipients      TYPE zppm_tt_variation_holder.
  DATA: lt_container              TYPE swrtcont,
        lv_return_code            TYPE sysubrc,
        lv_document_id            TYPE so_entryid,
        lt_attachment_txt_content TYPE  TABLE OF solisti1,
        lt_message_lines          TYPE TABLE OF swr_messag,
        lt_message_struct         TYPE TABLE OF swr_mstruc,
        lv_decision_note          TYPE string,
        ls_variationhead          TYPE /noveco/var_head,
        lv_deep_link_url          TYPE tsftext,
        lv_wfinst_main            TYPE rpm_tv_guid,
        lv_lastlevelapproval      TYPE boole_d.

  " Always refresh the output tables first

  REFRESH actor_tab.

  " Extract mandatory runtime attributes from the Flexible Workflow macro container
  swc_get_element ac_container 'VariationNumber'  lv_variation_number.
  swc_get_element ac_container 'STEPNUMBER'       lv_current_step.
  swc_get_element ac_container 'PortfolioItem'    lv_ppm_id.
  swc_get_element ac_container 'WORKFLOW_ACTION'  lv_ppm_wf_action.
  swc_get_element ac_container 'VARIATION_TYPE'   lv_variation_type .
  swc_get_element ac_container 'WF_PATH'          lv_wf_path.
  swc_get_element ac_container 'WorkitemId'       lv_WorkitemId.
  swc_get_table  ac_container 'DEEP_LINK_URL'     lv_deep_link_url.
  swc_get_element  ac_container 'WFINST_MAIN'       lv_wfinst_main .
  swc_get_element  ac_container 'ISLASTLEVELAPPROVAL'       lv_lastlevelapproval.

* read variation header-------------------------------------------------------
  SELECT * INTO TABLE @DATA(lt_variationhead)
    FROM /noveco/var_head
  WHERE qmnum = @lv_variation_number.
  IF sy-subrc IS INITIAL.
    ls_variationhead = VALUE #( lt_variationhead[ 1 ] OPTIONAL ).
*  ELSE.
*    "run test
*    " Constructing a 1-row internal table on the fly with custom data
*    ls_variationhead = VALUE /noveco/var_head(
*        mandt            = sy-mandt
*        qmnum            = '000400000094'
*        qmtxt            = 'Variation for Scope Change'
*        aennr            = ''
*        priok            = '1'
*        var_reason       = 'SCOP'
*        var_rej_reason   = ''
*        ernam            = sy-uname
*        erdat            = sy-datum
*        date_appr        = sy-datum
*        date_rej         = '00000000'
