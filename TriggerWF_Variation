*&---------------------------------------------------------------------*
*&      Form  VALIDATE_COSTING_ASSIGNMENT
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_IR_DATA_CHANGED  text
*----------------------------------------------------------------------*
 FORM validate_costing_assignment   USING lt_mod_cells TYPE lvc_t_modi
                                          ir_data_changed TYPE REF TO cl_alv_changed_data_protocol .


   DATA : ls_mod_cell    TYPE lvc_s_modi,
          lv_value_pspnr TYPE lvc_value,
          lv_value_aufnr TYPE lvc_value.

   DATA: m_type         TYPE c, l_another_proj TYPE c.

   DATA: ls_prps            TYPE prps, ls_proj TYPE proj,
         new_pspnr          TYPE proj-pspnr,
         lv_project         TYPE string,
         lv_wbs_element     TYPE string,
         new_pspid          TYPE ps_pspid, lv_new_network_act TYPE string,
         lv_nwa_find_result TYPE i.

   DATA: lv_vornr TYPE vornr,
         lv_aufnr TYPE aufnr.

   DATA: lv_plan_allowed    VALUE space,
         lv_objnr           TYPE j_objnr,
         lv_wbs_find_result TYPE i,
         ls_proj_plan       TYPE /noveco/epm_plvl,
         lv_plan_level      TYPE /noveco/epm_plan_lvl.


   DATA: ls_tree LIKE LINE OF gcl_project->gt_tree.

   LOOP AT lt_mod_cells INTO ls_mod_cell
                        WHERE  ( fieldname = 'PSPNR' OR fieldname = 'AUFNR' OR fieldname = 'VORNR' ).

     lv_plan_level = gcl_project->gv_plan_level.

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'PSPNR'
       IMPORTING
         e_value     = lv_value_pspnr.


     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'AUFNR'
       IMPORTING
         e_value     = lv_value_aufnr.

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'PROJ_PSPID'
         i_value     = p_pspid.


     IF lv_value_pspnr NE '00000000' AND lv_value_aufnr IS NOT INITIAL.


       CALL METHOD ir_data_changed->add_protocol_entry
         EXPORTING
           i_msgid     = '/NOVECO/EVM'
           i_msgno     = '029'                 "Please enter either WBS or Network, but not both.
           i_msgty     = 'E'
           i_fieldname = ls_mod_cell-fieldname
           i_row_id    = ls_mod_cell-row_id.


       CALL METHOD ir_data_changed->display_protocol.

       EXIT.

     ENDIF.

*   Only planning elements are allowed on WBS
     IF lv_value_pspnr NE '00000000'.

       DATA lv_pspnr TYPE ps_intnr.

       lv_pspnr = lv_value_pspnr.

       CALL METHOD gcl_project->get_objnr_wbs
         EXPORTING
           pspnr           = lv_pspnr
           cur_pspid       = p_pspid
           pt_elm_ps       = gcl_database->mt_elm_ps
         IMPORTING
           objnr           = lv_objnr
           wbs_find_result = lv_wbs_find_result.

       SELECT SINGLE * FROM prps INTO ls_prps WHERE objnr = lv_objnr.
       SELECT SINGLE * FROM proj INTO ls_proj WHERE pspnr = ls_prps-psphi.

       IF lv_wbs_find_result IS NOT INITIAL.
         CASE lv_wbs_find_result.
           WHEN 1.
             CALL METHOD ir_data_changed->add_protocol_entry
               EXPORTING
                 i_msgid     = '/NOVECO/EVM'
                 i_msgno     = '051'                 "WBS does not exit
                 i_msgty     = 'E'
                 i_fieldname = ls_mod_cell-fieldname
                 i_row_id    = ls_mod_cell-row_id.

             CALL METHOD ir_data_changed->display_protocol.

           WHEN 2 OR 3.

             PERFORM check_if_diff_project_allowed CHANGING l_another_proj.
             IF l_another_proj = 'Y'.
               m_type = 'W'.
             ELSE.
               m_type = 'E'.
             ENDIF.

             CALL FUNCTION 'CONVERSION_EXIT_ABPSP_OUTPUT'
               EXPORTING
                 input  = ls_prps-pspnr
               IMPORTING
                 output = lv_wbs_element.

             CALL FUNCTION 'CONVERSION_EXIT_ABPSN_OUTPUT'
               EXPORTING
                 input  = ls_proj-pspid
               IMPORTING
                 output = lv_project.

             CALL METHOD ir_data_changed->add_protocol_entry
               EXPORTING
                 i_msgid     = '/NOVECO/EVM'
                 i_msgno     = '005'                 "WBS belongs to another Project
                 i_msgty     = m_type
                 i_msgv1     = lv_wbs_element
                 i_msgv2     = lv_project
                 i_fieldname = ls_mod_cell-fieldname
                 i_row_id    = ls_mod_cell-row_id.

             CALL METHOD ir_data_changed->display_protocol.

             IF m_type = 'E'.
               " clear WBS field
               CALL METHOD ir_data_changed->modify_cell
                 EXPORTING
                   i_row_id    = ls_mod_cell-row_id
                   i_fieldname = 'PROJ_PSPID'
                   i_value     = space.

               CALL METHOD ir_data_changed->modify_cell
                 EXPORTING
                   i_row_id    = ls_mod_cell-row_id
                   i_fieldname = 'PSPNR'
                   i_value     = space.

             ELSE.
               IF lv_wbs_find_result EQ 2. " new project to be added
                 PERFORM add_project USING ls_proj.
               ENDIF.

               SELECT SINGLE * FROM /noveco/epm_plvl INTO ls_proj_plan WHERE profl = ls_proj-pprof.
               IF sy-subrc EQ 0.
                 lv_plan_level = ls_proj_plan-plan_level.
               ENDIF.

               CALL METHOD ir_data_changed->modify_cell
                 EXPORTING
                   i_row_id    = ls_mod_cell-row_id
                   i_fieldname = 'PROJ_PSPID'
                   i_value     = ls_proj-pspid.

             ENDIF.

         ENDCASE.

       ENDIF.

       CHECK lv_wbs_find_result NE 1.

*     Check if it is a Planning Element?

       CALL METHOD gobj_epm_main->is_planning_element
         EXPORTING
           p_level          = lv_plan_level
           p_objnr          = lv_objnr
           mt_elm_ps        = gcl_database->mt_elm_ps
           lt_netw_param    = gcl_project->gt_netw_parameters
           pt_netw_act_data = gtb_netw_act_data
         IMPORTING
           p_plan_allowed   = lv_plan_allowed.

       IF lv_plan_allowed NE 'X'.

         CALL METHOD ir_data_changed->add_protocol_entry
           EXPORTING
             i_msgid     = '/NOVECO/EVM'
             i_msgno     = '037'                 "Planning not allowed this level
             i_msgty     = 'E'
             i_fieldname = ls_mod_cell-fieldname
             i_row_id    = ls_mod_cell-row_id.


         CALL METHOD ir_data_changed->display_protocol.
         EXIT.

       ENDIF.

     ENDIF.


*   Only planning elements are allowed on Network
     IF lv_value_aufnr IS NOT INITIAL.

       CALL METHOD ir_data_changed->get_cell_value
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'VORNR'
         IMPORTING
           e_value     = lv_vornr.

       IF lv_vornr IS NOT INITIAL.

         lv_aufnr = lv_value_aufnr.


*       only Planning Elements are allowed
         CALL METHOD gcl_project->get_objnr_nwa
           EXPORTING
             aufnr           = lv_aufnr
             vornr           = lv_vornr
             cur_pspid       = p_pspid
             pt_elm_ps       = gcl_database->mt_elm_ps
           IMPORTING
             objnr           = lv_objnr
             new_pspid       = new_pspid
             nwa_find_result = lv_nwa_find_result.

         IF lv_nwa_find_result IS NOT INITIAL.

           lv_new_network_act = lv_aufnr.
           SHIFT lv_new_network_act LEFT DELETING LEADING '0'.
           CONCATENATE lv_new_network_act lv_vornr INTO lv_new_network_act SEPARATED BY space.

           CASE lv_nwa_find_result.
             WHEN 1.
               CALL METHOD ir_data_changed->add_protocol_entry
                 EXPORTING
                   i_msgid     = '/NOVECO/EVM'
                   i_msgno     = '052'                 "NWA does not exit
                   i_msgty     = 'E'
                   i_msgv1     = lv_new_network_act
                   i_fieldname = ls_mod_cell-fieldname
                   i_row_id    = ls_mod_cell-row_id.

               CALL METHOD ir_data_changed->display_protocol.

               CALL METHOD ir_data_changed->modify_cell
                 EXPORTING
                   i_row_id    = ls_mod_cell-row_id
                   i_fieldname = 'VORNR'
                   i_value     = space.

             WHEN 2.

               PERFORM check_if_diff_project_allowed CHANGING l_another_proj.
               IF l_another_proj = 'Y'.
                 m_type = 'W'.
               ELSE.
                 m_type = 'E'.
               ENDIF.

               CALL FUNCTION 'CONVERSION_EXIT_ABPSN_OUTPUT'
                 EXPORTING
                   input  = new_pspid
                 IMPORTING
                   output = lv_project.


               CALL METHOD ir_data_changed->add_protocol_entry
                 EXPORTING
                   i_msgid     = '/NOVECO/EVM'
                   i_msgno     = '053'                 "NWA belongs to another Project
                   i_msgty     = m_type
                   i_msgv1     = lv_new_network_act
                   i_msgv2     = lv_project
                   i_fieldname = ls_mod_cell-fieldname
                   i_row_id    = ls_mod_cell-row_id.

               CALL METHOD ir_data_changed->display_protocol.

           ENDCASE.

           CHECK lv_nwa_find_result NE 1.

           IF m_type = 'E'.
             CALL METHOD ir_data_changed->modify_cell
               EXPORTING
                 i_row_id    = ls_mod_cell-row_id
                 i_fieldname = 'AUFNR'
                 i_value     = space.

             CALL METHOD ir_data_changed->modify_cell
               EXPORTING
                 i_row_id    = ls_mod_cell-row_id
                 i_fieldname = 'VORNR'
                 i_value     = space.

             CALL METHOD ir_data_changed->modify_cell
               EXPORTING
                 i_row_id    = ls_mod_cell-row_id
                 i_fieldname = 'PROJ_PSPID'
                 i_value     = space.

           ELSEIF m_type = 'W'.

             SELECT SINGLE  * FROM proj INTO ls_proj WHERE pspid = new_pspid.
             SELECT SINGLE * FROM /noveco/epm_plvl INTO ls_proj_plan WHERE profl = ls_proj-pprof.
             lv_plan_level = ls_proj_plan-plan_level.

             IF lv_nwa_find_result EQ 2. " new project to be added
               PERFORM add_project USING ls_proj.
               SELECT SINGLE * FROM /noveco/epm_plvl INTO ls_proj_plan WHERE profl = ls_proj-pprof.
               IF sy-subrc EQ 0.
                 lv_plan_level = ls_proj_plan-plan_level.
               ENDIF.
             ENDIF.

             CALL METHOD gcl_project->get_objnr_nwa
               EXPORTING
                 aufnr = lv_aufnr
                 vornr = lv_vornr
               IMPORTING
                 objnr = lv_objnr.

             CALL METHOD ir_data_changed->modify_cell
               EXPORTING
                 i_row_id    = ls_mod_cell-row_id
                 i_fieldname = 'PROJ_PSPID'
                 i_value     = new_pspid.


           ENDIF.

           IF ( lv_nwa_find_result = 2 AND m_type = 'W' ) OR lv_nwa_find_result = 3.
             CALL METHOD gobj_epm_main->is_planning_element
               EXPORTING
                 p_level          = lv_plan_level
                 p_objnr          = lv_objnr
                 mt_elm_ps        = gcl_database->mt_elm_ps
                 lt_netw_param    = gcl_project->gt_netw_parameters
                 pt_netw_act_data = gtb_netw_act_data
               IMPORTING
                 p_plan_allowed   = lv_plan_allowed.

             IF lv_plan_allowed NE 'X'.

               CALL METHOD ir_data_changed->add_protocol_entry
                 EXPORTING
                   i_msgid     = '/NOVECO/EVM'
                   i_msgno     = '037'                 "Planning not allowed this level
                   i_msgty     = 'E'
                   i_fieldname = ls_mod_cell-fieldname
                   i_row_id    = ls_mod_cell-row_id.


               CALL METHOD ir_data_changed->display_protocol.
             ENDIF.

             EXIT.
           ENDIF.
         ENDIF.
       ENDIF.
     ENDIF.

   ENDLOOP.


 ENDFORM.                    " VALIDATE_COSTING_ASSIGNMENT

