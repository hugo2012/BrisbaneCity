*&      Form  OPEN_PROJECT
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
 FORM open_project USING called.

* open project
   DATA: lv_pspnr         TYPE proj-pspnr,
         lv_objnr         TYPE j_objnr,
         ls_proj_selected TYPE /noveco/sel_proj_objects.

   DATA l_date TYPE datum.

   CLEAR gv_project_open.

   l_date =  sy-datum.

   CALL FUNCTION 'CONVERSION_EXIT_ABPSN_INPUT'
     EXPORTING
       input  = p_pspid
     IMPORTING
       output = p_pspid.

   SELECT SINGLE pspnr FROM proj INTO lv_pspnr
     WHERE pspid = p_pspid.

   IF sy-subrc NE 0.

     MESSAGE s021(/noveco/evm) WITH p_pspid DISPLAY LIKE 'E'.

   ELSE.

     CONCATENATE 'PD' lv_pspnr INTO lv_objnr.

     CALL METHOD gcl_database->read_proj
       EXPORTING
         p_objnr = lv_objnr
       CHANGING
         p_proj  = gcl_database->ml_proj.


     FREE gt_selected_proj_list.
     ls_proj_selected-pspid = p_pspid.
     APPEND ls_proj_selected TO gt_selected_proj_list.

     CALL METHOD gcl_database->open_project
       EXPORTING
         p_pspnr = lv_pspnr
         p_date  = l_date.

*   Build the configuration
     CALL METHOD gcl_database->build_configuration
       EXPORTING
         p_plan_period      = l_date
       EXCEPTIONS
         profile_not_config = 1
         profile_empty      = 2.

*   create tree from hierarchy
     CALL METHOD gcl_project->set_project( lv_pspnr ).

     gv_project_open = 'X'.

     PERFORM set_up_claims.

     PERFORM set_up_tree.

     IF gcl_screen->gr_alv_variations IS NOT INITIAL.

       gcl_screen->gr_alv_variations->refresh( ).
     ENDIF.

     IF gcl_screen->gr_alv_revenue IS NOT INITIAL.
       gcl_screen->gr_alv_revenue->refresh( ).
     ENDIF.

     IF gcl_screen->gr_alv_costs IS NOT INITIAL.
       gcl_screen->gr_alv_costs->refresh( ).
     ENDIF.

     CLEAR gs_qmel.

     DATA: lv_curr_type_par_id,
           lv_vkokr            TYPE kokrs, lv_waers TYPE waers.

     GET PARAMETER ID '/NOVECO/SET_COA_CURR' FIELD lv_curr_type_par_id.

     IF lv_curr_type_par_id IS NOT INITIAL.

       SELECT SINGLE vkokr INTO lv_vkokr
           FROM proj  WHERE pspid = gcl_database->ml_config-pspid.

       SELECT SINGLE waers INTO lv_waers
           FROM tka01 WHERE kokrs = lv_vkokr.

       gs_qmel-waers = lv_waers. " COA Currency
       gcl_database->ml_config-waers =  lv_waers.
       gcl_database->ml_config-curr_type = '2'. "COA Area Currency.
       gcl_database->ml_config-fcast_curr_key = lv_waers.

     ELSE.

       gs_qmel-waers = gcl_project->gv_proj-pwhie. " Project Currency
       gcl_database->ml_config-pwhie =  gcl_project->gv_proj-pwhie.

       gcl_database->ml_config-curr_type = '1'. "Proj. Currency.
       gcl_database->ml_config-fcast_curr_key = gcl_project->gv_proj-pwhie.

     ENDIF.

* Get Exchange Rate Type
     SELECT SINGLE kurst INTO gs_qmel-kurst FROM tbp1c
             WHERE profil = gcl_project->gv_proj-pprof AND
                   applik = 'P' AND wrttp = '01'.

     SELECT SINGLE * INTO gs_versions
           FROM /noveco/epm_vers
           WHERE kokrs EQ gcl_database->ml_config-kokrs.

     gcl_project->gc_proj_currency = gcl_database->ml_config-fcast_curr_key.

     REFRESH gt_text_lines.

     PERFORM set_initial_user_status.

     PERFORM set_current_variation.

     IF called IS INITIAL.
       LEAVE TO SCREEN 0.
     ENDIF.



   ENDIF.


 ENDFORM.                    " OPEN_PROJECT

