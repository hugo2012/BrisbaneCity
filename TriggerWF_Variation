 FORM set_alv_read_only_status .

   IF gv_ui5_call IS NOT INITIAL.
     IF gv_change_mode = 'X'.
       IF gs_qmel-budget_updated = 'X' OR gs_qmel-fcast_updated = 'X' OR gv_manage_rev_or_cost = 'R'.
         PERFORM clear_costs_cell_styles.
       ENDIF.
     ELSE.
       PERFORM clear_revenue_cell_styles.
       PERFORM clear_costs_cell_styles.
     ENDIF.
     RETURN.
   ENDIF.

   IF gv_change_mode = 'X'.

     IF gs_qmel-revenue_updated = 'X'.
       gcl_screen->gr_alv_revenue->set_read_only( abap_true ).
     ELSE.
       gcl_screen->gr_alv_revenue->set_read_only( abap_false ).
     ENDIF.

     IF gs_qmel-budget_updated = 'X' OR gs_qmel-fcast_updated = 'X' OR gv_manage_rev_or_cost = 'R'.
       gcl_screen->gr_alv_costs->set_read_only( abap_true ).
       PERFORM clear_costs_cell_styles.
     ELSE.
       gcl_screen->gr_alv_costs->set_read_only( abap_false ).
     ENDIF.


   ELSE.

     gcl_screen->gr_alv_revenue->set_read_only( abap_true ).
     gcl_screen->gr_alv_costs->set_read_only( abap_true ).

     PERFORM clear_revenue_cell_styles.
     PERFORM clear_costs_cell_styles.


   ENDIF.

