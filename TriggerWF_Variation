*&---------------------------------------------------------------------*
*&      Form  VARIATION_UPDATE
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_GCL_PROJECT_>PSPID  text
*      -->P_P_BUDGET_UPD_FLG  text
*      -->P_P_REVENUE_UPD_FLG  text
*      -->P_P_FCAST_UPD_FLG  text
*      -->P_GS_QMEL_QMNUM  text
*----------------------------------------------------------------------*
 FORM variation_update  USING    p_budget_upd_flg
                                 p_revenue_upd_flg
                                 p_fcast_upd_flg.


   DATA: lt_approved_notifs    TYPE TABLE OF qmel,
         lt_nonapproved_notifs TYPE TABLE OF qmel,
         lt_rejected_notifs    TYPE TABLE OF qmel,
         ls_qmel               TYPE qmel,
         lt_output             TYPE TABLE OF /noveco/epm_var_output. "Report of processed claims

* clear output table
   REFRESH lt_output.

*** Set Variation Costs Update Date
   IF gs_qmel-date_appr(6) > sy-datum(6).
     gs_qmel-use_date_appr = abap_true.
   ELSE.
     gs_qmel-use_date_appr = abap_false.
   ENDIF.

* Determine if claim is approved, non-approved or rejected
   DATA ls_epm_vupd TYPE /noveco/epm_vupd.

   SELECT SINGLE * FROM /noveco/epm_vupd INTO ls_epm_vupd
     WHERE qmart = gs_qmel-qmart
       AND stsma = gs_qmel-stsma
       AND estat = gs_qmel-user_status.

   IF sy-subrc = 0.

     SELECT SINGLE * FROM qmel INTO ls_qmel
       WHERE qmnum = gs_qmel-qmnum.

     CASE ls_epm_vupd-var_stat.
       WHEN c_approved_stat. "Approved
         APPEND ls_qmel TO lt_approved_notifs.

       WHEN c_nonapproved_stat. "Non-Approved
         APPEND ls_qmel TO lt_nonapproved_notifs.

       WHEN c_rejected_stat OR c_notactive_stat. "Rejected or Not Active
         APPEND ls_qmel TO lt_rejected_notifs.

       WHEN OTHERS.
*       no udpate required
         RETURN.

     ENDCASE.


   ELSE.
*   no udpate required
     RETURN.
   ENDIF.

* Process approved notifications
   DESCRIBE TABLE lt_approved_notifs.
   IF sy-tfill > 0.


     CALL FUNCTION '/NOVECO/PROCESS_APPROVED_VAR'
       EXPORTING
         p_t_prps_psj      = gcl_database->mt_prps_r[]
         p_t_rsthie_psj    = gcl_database->mt_rsthie_m[]
         p_t_elm_ps        = gcl_database->mt_elm_ps
         p_cosup           = p_budget_upd_flg
         p_revup           = p_revenue_upd_flg
         p_forup           = p_fcast_upd_flg
         p_versions        = gs_versions
         p_pspid           = p_pspid
       CHANGING
         p_qmel            = gs_qmel
         p_t_notifications = lt_approved_notifs
         p_t_output        = lt_output.


   ENDIF.
*
* Process non-approved notifications
   DESCRIBE TABLE lt_nonapproved_notifs.
   IF sy-tfill > 0.

     CALL FUNCTION '/NOVECO/PROCESS_NONAPPR_VAR'
       EXPORTING
         p_t_prps_psj      = gcl_database->mt_prps_r[]
         p_t_rsthie_psj    = gcl_database->mt_rsthie_m[]
         p_t_elm_ps        = gcl_database->mt_elm_ps
         p_cosup           = p_budget_upd_flg
         p_revup           = p_revenue_upd_flg
         p_forup           = p_fcast_upd_flg
         p_versions        = gs_versions
         p_pspid           = p_pspid
       CHANGING
         p_qmel            = gs_qmel
         p_t_notifications = lt_nonapproved_notifs
         p_t_output        = lt_output.

   ENDIF.

* Process rejected notifications
   DESCRIBE TABLE lt_rejected_notifs.
   IF sy-tfill > 0.

     CALL FUNCTION '/NOVECO/PROCESS_REJECTED_VAR'
       EXPORTING
         p_t_prps_psj      = gcl_database->mt_prps_r[]
         p_t_rsthie_psj    = gcl_database->mt_rsthie_m[]
         p_t_elm_ps        = gcl_database->mt_elm_ps
         p_cosup           = p_budget_upd_flg
         p_revup           = p_revenue_upd_flg
         p_forup           = p_fcast_upd_flg
         p_versions        = gs_versions
         p_pspid           = p_pspid
       CHANGING
         p_qmel            = gs_qmel
         p_t_notifications = lt_rejected_notifs
         p_t_output        = lt_output.
   ENDIF.



   DATA: ls_output LIKE LINE OF lt_output.

   LOOP AT lt_output INTO ls_output.
     MESSAGE s000(/noveco/evm) WITH ls_output-message.
     WAIT UP TO 1 SECONDS.
   ENDLOOP.


 ENDFORM.                    " VARIATION_UPDATE

