*----------------------------------------------------------------------*
 FORM convert_price_currency  USING    p_waers_from TYPE waers
                                       p_waers_to TYPE waers
                                       p_preis_from TYPE preis
                              CHANGING p_preis_to TYPE preis.

   DATA: lv_price_from TYPE wogxxx,
         lv_price_to   TYPE wogxxx.

   IF p_waers_from NE p_waers_to.

     lv_price_from = p_preis_from.

     CALL METHOD gcl_project->convert_to_currency
       EXPORTING
         i_date          = gs_qmel-erdat
         i_from_amount   = lv_price_from
         i_from_currency = p_waers_from
         i_to_currency   = p_waers_to
         i_type_of_rate  = gs_qmel-kurst
       IMPORTING
         e_to_amount     = lv_price_to.

     p_preis_to = lv_price_to.

   ELSE.
     p_preis_to =  p_preis_from.
   ENDIF.

 ENDFORM.                    " CONVERT_PRICE_CURRENCY

