*&      Module  STATUS_0301  OUTPUT
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
 MODULE status_0301 OUTPUT.

   DATA lv_update_type TYPE  /noveco/epm_vtyp-update_type.

   lv_update_type = gcl_project->get_update_type( gs_qmel-qmart ).

   LOOP AT SCREEN.

*   set fields display only in Display Mode
     IF screen-group1 = 'DIS' OR screen-group1 = 'REV'.
       IF gv_change_mode NE 'X'.
         screen-input = 0.
       ELSE.
         screen-input = 1.
       ENDIF.
       MODIFY SCREEN.
     ENDIF.

     IF lv_update_type = 1. " Costs Only
       IF screen-group1 = 'REV'.
         screen-input = 0.
         MODIFY SCREEN.
       ENDIF.
     ENDIF.

*   Set Mandatory fields required in Change Mode
     IF screen-group2 = 'MAN'.
       IF gv_change_mode EQ 'X' AND gs_qmel-qmnum(1) EQ '$'.
         screen-input = 1.
         screen-required = 1.
       ELSE.
         screen-input = 0.
         screen-required = 0.
       ENDIF.
       MODIFY SCREEN.
     ENDIF.

*   Set Mandatory field depending on other field
     IF screen-group2 = 'M1'.
       IF gv_change_mode EQ 'X'.
         IF gs_qmel-qmart IS NOT INITIAL AND gs_qmel-qmtxt IS NOT INITIAL.
           screen-required = 1.
         ELSE.
           screen-required = 0.
         ENDIF.
       ELSE.
         screen-required = 0.
       ENDIF.
       MODIFY SCREEN.
     ENDIF.

*   Rejection Reason can only be set if status is rejected
     IF screen-name = 'GS_QMEL-VAR_REJ_REASON'.
       DATA ls_epm_vupd TYPE /noveco/epm_vupd.
*     is it an rejected status via /NOVECO/EPM_VUPD?
       SELECT SINGLE * FROM /noveco/epm_vupd INTO ls_epm_vupd
         WHERE qmart = gs_qmel-qmart
           AND stsma = gs_qmel-stsma
           AND estat = gs_qmel-user_status
           AND var_stat = '03'.
       IF sy-subrc NE 0.
         screen-input = 0.
         MODIFY SCREEN.
       ENDIF.
     ENDIF.

   ENDLOOP.

 ENDMODULE.                 " STATUS_0301  OUTPUT

