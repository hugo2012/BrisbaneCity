 FORM authority_check CHANGING error TYPE char1 .

   DATA: tcode TYPE ust12-von,
         qmart TYPE ust12-von..

   IF gs_qmel-qmnum(1) = '$'.
     tcode = 'CLM1'.
   ELSE.
     tcode = 'CLM2'.
   ENDIF.

   qmart = gs_qmel-qmart.

   CALL FUNCTION 'AUTHORITY_CHECK'
     EXPORTING
       user                = sy-uname
       object              = 'I_QMEL'
       field1              = 'QMART'
       value1              = qmart
       field2              = 'TCD'
       value2              = tcode
     EXCEPTIONS
       user_dont_exist     = 1
       user_is_authorized  = 2
       user_not_authorized = 3
       user_is_locked      = 4
       OTHERS              = 5.

   IF sy-subrc = 3.
     MESSAGE e059 DISPLAY LIKE 'E'. " Athorization missing
     error = 'X'.
   ENDIF.


 ENDFORM.                    " AUTHORITY_CHECK
