*----------------------------------------------------------------------*
 FORM f4_alv_wbs USING p_er_event_data TYPE REF TO cl_alv_event_data
                       p_e_fieldname
                       p_row_id
                       p_billing_elements_only.

   FIELD-SYMBOLS: <modified_cells> TYPE lvc_t_modi.
   DATA ls_modified TYPE lvc_s_modi.
   DATA lt_return_tab TYPE STANDARD TABLE OF ddshretval.
   DATA ls_return_tab LIKE LINE OF lt_return_tab.

   TYPES: BEGIN OF t_value_pspnr,
            posid TYPE prps-posid,
            post1 TYPE prps-post1,
          END OF t_value_pspnr.
   DATA lt_value_pspnr TYPE STANDARD TABLE OF t_value_pspnr.
   DATA ls_value_pspnr TYPE t_value_pspnr.
   DATA ls_prps LIKE LINE OF gcl_database->mt_prps_r.

   DATA lv_pspnr TYPE prps-pspnr.

   IF p_billing_elements_only = 'X'.

     LOOP AT gcl_database->mt_prps_r INTO ls_prps WHERE fakkz = 'X'.   "Billing Element
       CLEAR ls_value_pspnr.
       ls_value_pspnr-posid = ls_prps-posid.
       ls_value_pspnr-post1 = ls_prps-post1.
       APPEND ls_value_pspnr TO lt_value_pspnr.
     ENDLOOP.

   ELSE.

     LOOP AT gcl_database->mt_prps_r INTO ls_prps.
       CLEAR ls_value_pspnr.
       ls_value_pspnr-posid = ls_prps-posid.
       ls_value_pspnr-post1 = ls_prps-post1.
       APPEND ls_value_pspnr TO lt_value_pspnr.
     ENDLOOP.


   ENDIF.

   CALL FUNCTION 'F4IF_INT_TABLE_VALUE_REQUEST'
     EXPORTING
       retfield        = 'POSID'
       window_title    = TEXT-t44 " Select WBS Element
       value_org       = 'S'
     TABLES
       value_tab       = lt_value_pspnr
       return_tab      = lt_return_tab
     EXCEPTIONS
       parameter_error = 1
       no_values_found = 2
       OTHERS          = 3.
   IF sy-subrc <> 0.
   ELSE.
     IF lt_return_tab[] IS NOT INITIAL.
       READ TABLE lt_return_tab INTO ls_return_tab INDEX 1.
       IF sy-subrc = 0.

         DATA: lv_posid TYPE prps-posid.

         lv_posid = ls_return_tab-fieldval.
         ls_modified-row_id    = p_row_id.
         ls_modified-fieldname = p_e_fieldname.
         ls_modified-value = lv_posid.

         ASSIGN p_er_event_data->m_data->* TO <modified_cells>.
         APPEND ls_modified TO <modified_cells>.


       ENDIF.
     ENDIF.

   ENDIF.

 ENDFORM.                    " F4_ALV_WBS

