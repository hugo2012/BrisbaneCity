         i_value     = lv_serv_text.
   ENDIF.

   CHECK lv_kstar IS NOT INITIAL.

   CALL METHOD gcl_epm_items->get_acpos_for_kstar
     EXPORTING
       p_appl      = 'PS'
       p_kokrs     = gcl_database->ml_config-kokrs
       p_kstar     = lv_kstar
