*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
 FORM rev_item_select_for_costing .

* get selected revenue item, and ensure only one selected
   DATA lt_index_rows TYPE lvc_t_row.
   DATA lt_row_no TYPE lvc_t_roid.

   CALL METHOD gcl_screen->gr_alv_revenue->gr_alv->get_selected_rows
     IMPORTING
       et_index_rows = lt_index_rows
       et_row_no     = lt_row_no.


   DATA: lv_num_selected TYPE i VALUE 0.
   LOOP AT lt_index_rows TRANSPORTING NO FIELDS WHERE rowtype IS INITIAL.
     ADD 1 TO lv_num_selected.
   ENDLOOP.
   IF sy-subrc NE 0.
     MESSAGE i008(/noveco/evm).  "please select a row
   ELSEIF lv_num_selected GT 1.
     MESSAGE i009(/noveco/evm).   "select only one revenue item
   ELSE.
     DATA ls_index_rows LIKE LINE OF lt_index_rows.
     LOOP AT lt_index_rows INTO ls_index_rows WHERE rowtype IS INITIAL.


       DATA: ls_var_revenue LIKE LINE OF gcl_project->gt_var_revenue.

       PERFORM select_rev_item_for_costing USING ls_index_rows.

       EXIT.

     ENDLOOP.
   ENDIF.

* Add new empty cost line
   IF gv_change_mode IS NOT INITIAL.
     PERFORM add_empty_cost_item.
     gcl_screen->gr_alv_costs->refresh( ).
   ENDIF.

