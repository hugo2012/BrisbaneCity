   DATA ls_modified TYPE lvc_s_modi.
   DATA lt_return_tab TYPE STANDARD TABLE OF ddshretval.
   DATA ls_return_tab LIKE LINE OF lt_return_tab.
   DATA ls_cost LIKE LINE OF gcl_project->gt_var_costs.

   CASE p_e_fieldname.

     WHEN 'PSPNR'.
       PERFORM f4_alv_wbs USING p_er_event_data
                                p_e_fieldname
                                p_row_id
                                space. "not just billing elements only
     WHEN 'AUFNR'.

       PERFORM f4_alv_networks USING p_er_event_data
                                p_e_fieldname
                                p_row_id.

     WHEN 'VORNR'.

       PERFORM f4_alv_nwa USING p_er_event_data
                                p_e_fieldname
                                p_row_id.

     WHEN 'RES_NAME'.

       PERFORM f4_alv_res_name USING p_er_event_data
                                     p_e_fieldname
                                     p_row_id.

     WHEN 'RESOURCE'.

*     dynamic, which Costing Key?
       ls_cost = gcl_project->read_cost_item( p_row_id ).

       CASE ls_cost-kalka.

         WHEN 'M'.    "Material

           PERFORM f4_alv_material USING p_er_event_data
                                         p_e_fieldname
                                         p_row_id.


         WHEN 'S'.    "Service

           PERFORM f4_alv_service USING p_er_event_data
                                        p_e_fieldname
                                        p_row_id.

         WHEN 'E'.    "Cost Centre

           PERFORM f4_alv_kostl USING p_er_event_data
                                      p_e_fieldname
                                      p_row_id.
       ENDCASE.

     WHEN 'PLANT_ACTIVITY'.

*     dynamic
       ls_cost = gcl_project->read_cost_item( p_row_id ).

       CASE ls_cost-kalka.

         WHEN 'M' OR 'S'.    "Material or Service

           PERFORM f4_alv_plant USING p_er_event_data
                                         p_e_fieldname
                                         p_row_id.


         WHEN 'E'.    "External Labour

           PERFORM f4_alv_activity_type USING p_er_event_data
                                              p_e_fieldname
                                              p_row_id.


       ENDCASE.



   ENDCASE.

