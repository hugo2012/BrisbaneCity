* Revenue - calculate Profit  and
* Probabilities and Predictable Values
* Get user parameters.
   DATA: lv_decimal_separator   TYPE char1,
         lv_thousands_separator TYPE char1,
         lv_dcpfm               TYPE xudcpfm.

   SELECT SINGLE dcpfm FROM usr01 INTO lv_dcpfm WHERE bname = sy-uname.

   CASE lv_dcpfm.
     WHEN ' '.
       lv_thousands_separator = '.'.
       lv_decimal_separator   = ','.

     WHEN 'X'.
       lv_thousands_separator = ','.
       lv_decimal_separator   = '.'.

     WHEN 'Y'.
       lv_thousands_separator = ' '.
       lv_decimal_separator   = ','.
   ENDCASE.


   DATA lv_kursk_before_ch TYPE kursk.
   DATA lv_kursk TYPE kursk.

   LOOP AT lt_mod_cells  INTO ls_mod_cell
                        WHERE fieldname = 'REV_PLAN' OR
                              fieldname = 'EXPECTED_PERCT' OR
                              fieldname = 'KURSK'.

     READ TABLE gcl_project->gt_var_revenue ASSIGNING <fs_var_rev>
                                        INDEX ls_mod_cell-row_id.


     lv_kursk_before_ch = <fs_var_rev>-kursk.

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'KURSK'
       IMPORTING
         e_value     = lv_value.

     lv_kursk = lv_value.

     IF gv_ui5_call = space.

       CALL FUNCTION 'HRCM_STRING_TO_AMOUNT_CONVERT'
         EXPORTING
           string              = ls_mod_cell-value
           decimal_separator   = lv_decimal_separator
           thousands_separator = lv_thousands_separator
           waers               = <fs_var_rev>-pwhie
         IMPORTING
           betrg               = ls_mod_cell-value
         EXCEPTIONS
           convert_error       = 1
           OTHERS              = 2.

       IF sy-subrc <> 0.

         IF gv_ui5_call IS INITIAL.
           MESSAGE s031(/noveco/epm) DISPLAY LIKE 'E'.
         ELSE.
           MESSAGE s031(/noveco/epm) INTO gv_ui5_message.
           gv_ui5_message_type = 'E'.
         ENDIF.

         CALL METHOD ir_data_changed->modify_cell
           EXPORTING
             i_row_id    = ls_mod_cell-row_id
             i_fieldname = 'KURSK'
             i_value     = lv_kursk_before_ch.

         RETURN.
       ENDIF.

     ELSE.

       TRY.
           REPLACE ALL OCCURRENCES OF ',' IN ls_mod_cell-value WITH '.'.
           REPLACE ALL OCCURRENCES OF '%' IN ls_mod_cell-value WITH ''.
           lv_value = ls_mod_cell-value.

         CATCH cx_sy_conversion_no_number.

           IF gv_ui5_call IS INITIAL.
