*&---------------------------------------------------------------------*
*&      Module  F4_EBELP  INPUT
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
 MODULE f4_ebelp INPUT.

   TYPES: BEGIN OF t_value_ebelp,
            ebeln TYPE ekpo-ebeln,
            ebelp TYPE ekpo-ebelp,
          END OF t_value_ebelp.

   DATA lt_value_ebelp TYPE STANDARD TABLE OF t_value_ebelp.
   DATA ls_value_ebelp TYPE t_value_ebelp.


   DATA lt_dynpfields TYPE STANDARD TABLE OF dynpread.
   DATA ls_dynpfields LIKE LINE OF lt_dynpfields.

   ls_dynpfields-fieldname = 'GS_QMEL-EBELN'.
   APPEND ls_dynpfields TO lt_dynpfields.


   CALL FUNCTION 'DYNP_VALUES_READ'
     EXPORTING
       dyname               = '/NOVECO/EVM_WORKBENCH'
       dynumb               = '0301'
     TABLES
       dynpfields           = lt_dynpfields
     EXCEPTIONS
       invalid_abapworkarea = 1
       invalid_dynprofield  = 2
       invalid_dynproname   = 3
       invalid_dynpronummer = 4
       invalid_request      = 5
       no_fielddescription  = 6
       invalid_parameter    = 7
       undefind_error       = 8
       double_conversion    = 9
       stepl_not_found      = 10
       OTHERS               = 11.
   IF sy-subrc <> 0.
   ENDIF.

   IF lt_dynpfields[] IS NOT INITIAL.
     READ TABLE lt_dynpfields INTO ls_dynpfields INDEX 1.

     DATA lv_ebeln TYPE ebeln.
     lv_ebeln = ls_dynpfields-fieldvalue.
   ENDIF.


   IF lv_ebeln  IS NOT INITIAL.
     SELECT ebeln ebelp FROM ekpo
       INTO CORRESPONDING FIELDS OF TABLE lt_value_ebelp
       WHERE ebeln = lv_ebeln .
   ENDIF.


   SORT lt_value_ebelp BY ebelp.
*  DELETE ADJACENT DUPLICATES FROM lt_value_ebelp COMPARING vbeln.

   CHECK lt_value_ebelp[] IS NOT INITIAL.

   CALL FUNCTION 'F4IF_INT_TABLE_VALUE_REQUEST'
     EXPORTING
*      DDIC_STRUCTURE  = ' '
       retfield        = 'EBELN'
       window_title    = 'Select PO Item'
       value_org       = 'S'
       dynprofield     = 'GS_QMEL-EBELN'
     TABLES
