*----------------------------------------------------------------------*
 FORM set_revenue_currencies USING  ir_data_changed TYPE REF TO cl_alv_changed_data_protocol
                                    ls_mod_cell TYPE lvc_s_modi
                                    lv_rev_plan.

   DATA: lv_waerk TYPE vbak-waerk,
         lv_pwhie TYPE ps_pwhie,
         lv_kwaer TYPE kwaer,
         lv_kursk TYPE kursk.

   DATA: lv_amount_in_sd_currency      TYPE wtgxxx,
         lv_amount_in_project_currency TYPE wogxxx,
         lv_amount_in_kokrs_currency   TYPE wkgxxx.

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'WAERK'
     IMPORTING
       e_value     = lv_waerk. " SO Currency

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'PWHIE'
     IMPORTING
       e_value     = lv_pwhie. " Project Currency

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'KWAER'
     IMPORTING
       e_value     = lv_kwaer. " COA Currency

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'KURSK'
     IMPORTING
       e_value     = lv_kursk.

   IF lv_kursk EQ 0.

     lv_kursk = '1.00000'.
     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'KURSK'
         i_value     = lv_kursk.
   ENDIF.

   lv_amount_in_sd_currency = lv_rev_plan.

   IF lv_waerk NE lv_pwhie.
     IF lv_kursk < 0 AND lv_kursk NE 0 .
       MULTIPLY lv_kursk BY -1.
       IF lv_kursk < 1.
         lv_amount_in_project_currency = lv_amount_in_sd_currency / lv_kursk.
       ELSE.
         lv_amount_in_project_currency = lv_amount_in_sd_currency * lv_kursk.
       ENDIF.
     ELSE.
       lv_amount_in_project_currency = lv_amount_in_sd_currency * lv_kursk.
     ENDIF.
   ELSE.
     lv_amount_in_project_currency = lv_amount_in_sd_currency.
   ENDIF.


   CALL METHOD ir_data_changed->modify_cell
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'WOG'
       i_value     = lv_amount_in_project_currency.


*  Convert controlling area currency value

   IF lv_pwhie NE lv_kwaer.

     CALL METHOD gcl_project->convert_to_currency
       EXPORTING
         i_date          = gs_qmel-erdat
         i_from_amount   = lv_amount_in_project_currency
         i_from_currency = lv_waerk
         i_to_currency   = lv_kwaer
         i_type_of_rate  = gs_qmel-kurst
       IMPORTING
         e_to_amount     = lv_amount_in_kokrs_currency.
   ELSE.
     lv_amount_in_kokrs_currency = lv_amount_in_project_currency.
   ENDIF.

   CALL METHOD ir_data_changed->modify_cell
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'WKG'
       i_value     = lv_amount_in_kokrs_currency.


 ENDFORM.                    " SET_REVENUE_CURRENCIES

