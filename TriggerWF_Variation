         lv_rev_index TYPE sy-tabix.

   DATA : ls_mod_cell TYPE lvc_s_modi,
          lv_value    TYPE lvc_value.


   READ TABLE ir_data_changed->mt_mod_cells INTO ls_mod_cell INDEX 1.
   lv_rev_index = ls_mod_cell-row_id.

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'MATNR'
     IMPORTING
       e_value     = lv_value.

   lv_matnr = lv_value.

   IF lv_matnr IS INITIAL.

     SELECT * INTO TABLE lt_epm_var FROM /noveco/epm_vrev.
     IF sy-subrc EQ 0.
       READ TABLE gcl_project->gt_var_revenue INTO ls_rev_item WITH KEY rev_item = lv_rev_index .

       SELECT SINGLE vkorg vtweg FROM vbak  INTO (lv_vkorg, lv_vtweg) WHERE vbeln = ls_rev_item-vbeln.

       IF sy-subrc EQ 0.
         READ TABLE lt_epm_var INTO ls_epm_var WITH KEY
                                     bukrs = gs_qmel-bukrs
                                     vkorg = lv_vkorg
                                     vtweg = lv_vtweg.
         IF sy-subrc EQ 0.
           lv_matnr = ls_epm_var-matnr.

           CALL METHOD ir_data_changed->modify_cell
             EXPORTING
               i_row_id    = ls_mod_cell-row_id
               i_fieldname = 'MATNR'
               i_value     = lv_matnr.

           MODIFY gcl_project->gt_var_revenue FROM ls_rev_item INDEX lv_rev_index TRANSPORTING matnr .

         ELSE.
         ENDIF.
       ENDIF.
     ENDIF.
   ELSE.
   ENDIF.


 ENDFORM.                    " SET_SALES_MATNR
*&---------------------------------------------------------------------*
*&      Form  F4_SALES_MATNR
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_P_ROW_ID  text
*----------------------------------------------------------------------*
 FORM f4_sales_matnr  USING  p_row_id
                             er_event_data TYPE REF TO cl_alv_event_data.

   TYPES: BEGIN OF t_value_matnr,
            matnr TYPE matnr,
            maktx TYPE maktx,
          END OF t_value_matnr.

   DATA: lt_matnr_list TYPE TABLE OF /noveco/epm_vrev,
         ls_matnr_list TYPE /noveco/epm_vrev,
         lv_matnr      TYPE matnr,
         lv_value      TYPE lvc_value,
         lv_vkorg      TYPE vkorg,
         lv_vtweg      TYPE vtweg,
         lv_maktx      TYPE maktx.

   FIELD-SYMBOLS: <modified_cells> TYPE lvc_t_modi.
   DATA ls_modified TYPE lvc_s_modi.

   DATA ls_revenue LIKE LINE OF gcl_project->gt_var_revenue.

   DATA: lt_value_matnr TYPE STANDARD TABLE OF t_value_matnr,
         ls_value_matnr TYPE t_value_matnr.

   DATA: lt_return_tab TYPE STANDARD TABLE OF ddshretval,
         ls_return_tab LIKE LINE OF lt_return_tab.

*   Get list from Configuration
   SELECT * INTO TABLE lt_matnr_list FROM /noveco/epm_vrev WHERE bukrs EQ gs_qmel-bukrs.
   ls_revenue = gcl_project->read_revenue_item( p_row_id ).

*   Make sure list of materials belongs to the right Co.Code, Sales Org and Dist.Channel
   IF ls_revenue-vbeln IS NOT INITIAL.
     SELECT SINGLE vkorg vtweg FROM vbak  INTO (lv_vkorg, lv_vtweg) WHERE vbeln = ls_revenue-vbeln.
     IF sy-subrc EQ 0.
       DELETE lt_matnr_list WHERE vkorg NE lv_vkorg.
       DELETE lt_matnr_list WHERE vtweg NE lv_vtweg.
     ENDIF.
   ENDIF.

*   Prepare list of material items
   LOOP AT lt_matnr_list INTO ls_matnr_list.
     CLEAR ls_value_matnr.
     ls_value_matnr-matnr = ls_matnr_list-matnr.
     SELECT SINGLE maktx FROM makt INTO lv_maktx WHERE matnr EQ ls_matnr_list-matnr
                                             AND spras EQ sy-langu.

     ls_value_matnr-maktx = lv_maktx.
     APPEND ls_value_matnr TO lt_value_matnr.
   ENDLOOP.

   CLEAR ls_value_matnr.
   INSERT ls_value_matnr INTO lt_value_matnr INDEX 1 .


*     Fill F4 list
   CALL FUNCTION 'F4IF_INT_TABLE_VALUE_REQUEST'
     EXPORTING
*      DDIC_STRUCTURE  = ' '
       retfield        = 'MATNR'
       window_title    = TEXT-t60
       value_org       = 'S'
     TABLES
       value_tab       = lt_value_matnr
       return_tab      = lt_return_tab
     EXCEPTIONS
       parameter_error = 1
       no_values_found = 2
       OTHERS          = 3.
   IF sy-subrc <> 0.
   ELSE.
     IF lt_return_tab[] IS NOT INITIAL.
       READ TABLE lt_return_tab INTO ls_return_tab INDEX 1.
       IF sy-subrc = 0.
         MOVE ls_return_tab-fieldval TO lv_matnr.
         ls_modified-row_id    = p_row_id.
         ls_modified-fieldname = 'MATNR'.
         MOVE lv_matnr TO lv_value.
         ls_modified-value = lv_value.

         ASSIGN er_event_data->m_data->* TO <modified_cells>.
         APPEND ls_modified TO <modified_cells>.
       ENDIF.
     ENDIF.

   ENDIF.

 ENDFORM.                    " F4_SALES_MATNR
*&---------------------------------------------------------------------*
*&      Form  CHECK_SALES_MATERIAL
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_IR_DATA_CHANGED  text
*      -->P_LS_MOD_CELL  text
*----------------------------------------------------------------------*
 FORM check_sales_material  USING    ir_data_changed TYPE REF TO cl_alv_changed_data_protocol
                                     ls_mod_cell TYPE lvc_s_modi.

   DATA: lt_matnr_list    TYPE TABLE OF /noveco/epm_vrev,
         ls_matnr_list    TYPE /noveco/epm_vrev,
         lv_matnr         TYPE matnr,
         lv_value         TYPE lvc_value,
         lv_vkorg         TYPE vkorg,
         lv_vtweg         TYPE vtweg,
         lv_maktx         TYPE maktx,
         ls_vbap_existing TYPE vbap,
         lv_new_item      TYPE char1.

   DATA ls_revenue LIKE LINE OF gcl_project->gt_var_revenue.

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'NEW_ITEM'
     IMPORTING
       e_value     = lv_new_item.

*   Get list from Configuration
   SELECT * INTO TABLE lt_matnr_list FROM /noveco/epm_vrev WHERE bukrs EQ gs_qmel-bukrs.
   ls_revenue = gcl_project->read_revenue_item( ls_mod_cell-row_id ).


   SELECT SINGLE * FROM vbap INTO ls_vbap_existing  WHERE vbeln =  ls_revenue-vbeln
                                                          AND posnr =  ls_revenue-posnr.
   IF sy-subrc EQ 0.
     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'MATNR'
         i_value     = ls_vbap_existing-matnr.

   ELSE.

*   Make sure list of materials belongs to the right Co.Code, Sales Org and Dist.Channel
     IF ls_revenue-vbeln IS NOT INITIAL.
       SELECT SINGLE vkorg vtweg FROM vbak  INTO (lv_vkorg, lv_vtweg) WHERE vbeln = ls_revenue-vbeln.
       IF sy-subrc EQ 0.
         DELETE lt_matnr_list WHERE vkorg NE lv_vkorg.
         DELETE lt_matnr_list WHERE vtweg NE lv_vtweg.
       ENDIF.
     ENDIF.

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'MATNR'
       IMPORTING
         e_value     = lv_value.

     lv_matnr = lv_value.


     DATA: lv_msgv1 TYPE string.

     IF lv_matnr IS INITIAL AND lv_new_item = 'X'.

       TRANSLATE: lv_matnr  TO UPPER CASE.

       lv_msgv1 = lv_matnr.
       CALL METHOD ir_data_changed->add_protocol_entry
         EXPORTING
           i_msgid     = 'IM'
           i_msgno     = '014'  " Enter Material number
           i_msgty     = 'E'
           i_msgv1     = lv_msgv1
           i_msgv2     = ''
           i_msgv3     = ''
           i_fieldname = ls_mod_cell-fieldname
           i_row_id    = ls_mod_cell-row_id.

       RETURN.

     ENDIF.

     IF lv_matnr IS INITIAL AND lv_new_item = space.
       RETURN.
     ENDIF.

* Check if material is maintained in configuration
     READ TABLE lt_matnr_list WITH KEY matnr = lv_matnr
                                      TRANSPORTING NO FIELDS.
     IF sy-subrc EQ 0.


       CALL FUNCTION 'CONVERSION_EXIT_MATN1_INPUT'
         EXPORTING
           input  = lv_matnr
         IMPORTING
           output = lv_matnr.

       CALL METHOD ir_data_changed->modify_cell
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'MATNR'
           i_value     = lv_matnr.
     ELSE.

       TRANSLATE: lv_matnr  TO UPPER CASE.

       CALL FUNCTION 'CONVERSION_EXIT_MATN1_OUTPUT'
         EXPORTING
           input  = lv_matnr
         IMPORTING
           output = lv_matnr.

       lv_msgv1 = lv_matnr.
       CALL METHOD ir_data_changed->add_protocol_entry
         EXPORTING
           i_msgid     = '/NOVECO/EPM'
           i_msgno     = '127'                 "Material & is not maintained in Plant &.
           i_msgty     = 'E'
           i_msgv1     = lv_msgv1
           i_msgv2     = ''
           i_msgv3     = ''
           i_fieldname = ls_mod_cell-fieldname
           i_row_id    = ls_mod_cell-row_id.

       CALL METHOD ir_data_changed->modify_cell
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'MATNR'
           i_value     = space.

     ENDIF.
   ENDIF.
 ENDFORM.                    " CHECK_SALES_MATERIAL
