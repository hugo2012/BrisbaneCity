*&---------------------------------------------------------------------*
*&      Form  ON_F4_REVENUE
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_E_FIELDNAME  text
*      -->P_ES_ROW_NO_ROW_ID  text
*      -->P_ER_EVENT_DATA  text
*      -->P_ET_BAD_CELLS  text
*      -->P_E_DISPLAY  text
*----------------------------------------------------------------------*
 FORM on_f4_revenue  USING    p_e_fieldname
                              p_row_id
                              p_er_event_data TYPE REF TO cl_alv_event_data
                              p_et_bad_cells
                              p_e_display.

   FIELD-SYMBOLS: <modified_cells> TYPE lvc_t_modi.
   DATA ls_modified TYPE lvc_s_modi.
   DATA lt_return_tab TYPE STANDARD TABLE OF ddshretval.
   DATA ls_return_tab LIKE LINE OF lt_return_tab.




   CASE p_e_fieldname.

*  Sales Order --------------------------------------------------------------------------
     WHEN 'VBELN'.

       TYPES: BEGIN OF t_value_vbeln,
                vbeln TYPE vbap-vbeln,
              END OF t_value_vbeln.

       DATA: lt_value_vbeln TYPE STANDARD TABLE OF t_value_vbeln,
             ls_value_vbeln TYPE t_value_vbeln,
             ls_vbap        TYPE /noveco/evm_vbap,
             lv_value       TYPE lvc_value,
             lv_vbeln       TYPE vbeln.

       LOOP AT gcl_project->gt_vbap INTO ls_vbap.
         IF lv_vbeln NE ls_vbap-vbeln.
           CLEAR ls_value_vbeln.
           ls_value_vbeln-vbeln = ls_vbap-vbeln.
           APPEND ls_value_vbeln TO lt_value_vbeln.
         ENDIF.
         lv_vbeln = ls_vbap-vbeln.
       ENDLOOP.

       CALL FUNCTION 'F4IF_INT_TABLE_VALUE_REQUEST'
         EXPORTING
*          DDIC_STRUCTURE  = ' '
           retfield        = 'VBELN'
           window_title    = TEXT-t20
           value_org       = 'S'
         TABLES
           value_tab       = lt_value_vbeln
           return_tab      = lt_return_tab
         EXCEPTIONS
           parameter_error = 1
           no_values_found = 2
           OTHERS          = 3.
       IF sy-subrc <> 0.
       ELSE.
         IF lt_return_tab[] IS NOT INITIAL.
           READ TABLE lt_return_tab INTO ls_return_tab INDEX 1.
           IF sy-subrc = 0.
             MOVE ls_return_tab-fieldval TO lv_vbeln.
             ls_modified-row_id    = p_row_id.
             ls_modified-fieldname = p_e_fieldname.
             MOVE lv_vbeln TO lv_value.
             ls_modified-value = lv_value.

             ASSIGN p_er_event_data->m_data->* TO <modified_cells>.
             APPEND ls_modified TO <modified_cells>.
           ENDIF.
         ENDIF.

       ENDIF.



*   Sales Order Item --------------------------------------------------------------------------
     WHEN 'POSNR'.


       TYPES: BEGIN OF t_value_posnr,
                posnr TYPE vbap-posnr,
                arkxt TYPE vbap-arktx,
              END OF t_value_posnr.
       DATA lt_value_posnr TYPE STANDARD TABLE OF t_value_posnr.
       DATA ls_value_posnr TYPE t_value_posnr.
       DATA ls_revenue LIKE LINE OF gcl_project->gt_var_revenue.
       DATA lv_posnr TYPE posnr.

       ls_revenue = gcl_project->read_revenue_item( p_row_id ).

       IF ls_revenue-vbeln IS NOT INITIAL.

         LOOP AT gcl_project->gt_vbap INTO ls_vbap WHERE vbeln = ls_revenue-vbeln.
           CLEAR ls_value_posnr.
           ls_value_posnr-posnr = ls_vbap-posnr.
           ls_value_posnr-arkxt = ls_vbap-arktx.
           APPEND ls_value_posnr TO lt_value_posnr.
         ENDLOOP.

         CALL FUNCTION 'F4IF_INT_TABLE_VALUE_REQUEST'
           EXPORTING
             retfield        = 'POSNR'
             window_title    = TEXT-t21
             value_org       = 'S'
           TABLES
             value_tab       = lt_value_posnr
             return_tab      = lt_return_tab
           EXCEPTIONS
             parameter_error = 1
             no_values_found = 2
             OTHERS          = 3.
         IF sy-subrc <> 0.
         ELSE.
           IF lt_return_tab[] IS NOT INITIAL.
             READ TABLE lt_return_tab INTO ls_return_tab INDEX 1.
             IF sy-subrc = 0.
               MOVE ls_return_tab-fieldval TO lv_posnr.
               ls_modified-row_id    = p_row_id.
               ls_modified-fieldname = p_e_fieldname.
               MOVE lv_posnr TO lv_value.
               ls_modified-value = lv_value.

               ASSIGN p_er_event_data->m_data->* TO <modified_cells>.
               APPEND ls_modified TO <modified_cells>.
             ENDIF.
           ENDIF.

         ENDIF.

       ENDIF.


*   WBS --------------------------------------------------------------------------
     WHEN 'PSPNR'.

       PERFORM f4_alv_wbs USING p_er_event_data
                                p_e_fieldname
                                p_row_id
                                'X'.   "billing elements only


     WHEN 'MATNR'.

       PERFORM f4_sales_matnr USING p_row_id
                                    p_er_event_data.

   ENDCASE.


 ENDFORM.                    " ON_F4_REVENUE

