*&---------------------------------------------------------------------*
*&      Form  F4_ALV_RES_NAME
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_P_ER_EVENT_DATA  text
*      -->P_P_E_FIELDNAME  text
*      -->P_P_ROW_ID  text
*----------------------------------------------------------------------*
 FORM f4_alv_res_name  USING p_er_event_data TYPE REF TO cl_alv_event_data
                             p_e_fieldname
                             p_row_id.


   FIELD-SYMBOLS: <modified_cells> TYPE lvc_t_modi.

   DATA ls_modified TYPE lvc_s_modi.
   DATA lt_return_tab TYPE STANDARD TABLE OF ddshretval.
   DATA ls_return_tab LIKE LINE OF lt_return_tab.

   DATA lt_field_tab TYPE STANDARD TABLE OF dfies.

   DATA lt_dynpfld_mapping TYPE STANDARD TABLE OF  dselc.

   DATA: lt_resources TYPE TABLE OF /noveco/resource,
         ls_resources TYPE /noveco/resource.

   TYPES: BEGIN OF t_res_name,
            acpos    TYPE acpos,
            res_name TYPE /noveco/res_name,
          END OF t_res_name.
   DATA lt_res_name TYPE STANDARD TABLE OF t_res_name.
   DATA ls_res_name TYPE t_res_name.

   DATA: ls_cost LIKE LINE OF gcl_project->gt_var_costs.
   FIELD-SYMBOLS: <fs_cost> LIKE LINE OF gcl_project->gt_var_costs.

   SELECT * FROM /noveco/resource INTO TABLE lt_resources.

   ls_cost = gcl_project->read_cost_item( p_row_id ).

   IF ls_cost-acpos IS NOT INITIAL.
     DELETE lt_resources WHERE acpos NE ls_cost-acpos.
   ENDIF.

   SORT lt_resources BY res_name.
   DELETE ADJACENT DUPLICATES FROM lt_resources COMPARING res_name.

   LOOP AT lt_resources INTO ls_resources.
     ls_res_name-acpos = ls_resources-acpos.
     ls_res_name-res_name = ls_resources-res_name.
     APPEND ls_res_name TO lt_res_name.
   ENDLOOP.

   CALL FUNCTION 'F4IF_INT_TABLE_VALUE_REQUEST'
     EXPORTING
       retfield        = 'RES_NAME'
*      window_title    = text-t56 " Select Network Activity
       value_org       = 'S'
     TABLES
       value_tab       = lt_res_name
       return_tab      = lt_return_tab
       field_tab       = lt_field_tab
       dynpfld_mapping = lt_dynpfld_mapping
     EXCEPTIONS
       parameter_error = 1
       no_values_found = 2
       OTHERS          = 3.
   IF sy-subrc <> 0.
   ELSE.

     IF lt_return_tab[] IS NOT INITIAL.
       READ TABLE lt_return_tab INTO ls_return_tab INDEX 1.
       IF sy-subrc = 0.
         ls_modified-row_id    = p_row_id.
         ls_modified-fieldname = p_e_fieldname.
         ls_modified-value = ls_return_tab-fieldval.

         ASSIGN p_er_event_data->m_data->* TO <modified_cells>.
         APPEND ls_modified TO <modified_cells>.

         IF ls_cost-acpos IS INITIAL.
           READ TABLE gcl_project->gt_var_costs_current ASSIGNING <fs_cost> INDEX p_row_id.
           READ TABLE lt_resources INTO ls_resources WITH KEY res_name = ls_return_tab-fieldval.
           CHECK sy-subrc EQ 0.
           <fs_cost>-acpos = ls_resources-acpos.
         ENDIF.

       ENDIF.
     ENDIF.
   ENDIF.

 ENDFORM.                    " F4_ALV_RES_NAME

