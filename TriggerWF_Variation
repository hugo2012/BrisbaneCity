*----------------------------------------------------------------------*
 FORM set_text .

   IF gv_text_editor_created IS INITIAL.


     CREATE OBJECT gr_editor_container
       EXPORTING
         container_name              = 'Z_TEXT_EDIT'
       EXCEPTIONS
         cntl_error                  = 1
         cntl_system_error           = 2
         create_error                = 3
         lifetime_error              = 4
         lifetime_dynpro_dynpro_link = 5.

     CREATE OBJECT gr_editor
       EXPORTING
         parent                     = gr_editor_container
         wordwrap_mode              = cl_gui_textedit=>wordwrap_at_fixed_position
         wordwrap_position          = 72
         wordwrap_to_linebreak_mode = cl_gui_textedit=>true.


     CALL METHOD gr_editor->set_readonly_mode.
     CALL METHOD gr_editor->set_toolbar_mode( 0 ).

     gv_text_editor_created = 'X'.

   ENDIF.

   IF gs_qmel-qmnum IS NOT INITIAL.

     IF gs_qmel-qmnum(1) NE '$'.

       REFRESH gt_text_lines.

       DATA: lv_tdname TYPE thead-tdname.

       lv_tdname = gs_qmel-qmnum.

       CALL FUNCTION 'READ_TEXT'
         EXPORTING
*          CLIENT                  = SY-MANDT
           id                      = 'LTXT'
           language                = sy-langu
           name                    = lv_tdname
           object                  = 'QMEL'
*          ARCHIVE_HANDLE          = 0
*          LOCAL_CAT               = ' '
*       IMPORTING
*          HEADER                  =
         TABLES
           lines                   = gt_text_lines
         EXCEPTIONS
           id                      = 1
           language                = 2
           name                    = 3
           not_found               = 4
           object                  = 5
           reference_check         = 6
           wrong_access_to_archive = 7
           OTHERS                  = 8.
       IF sy-subrc <> 0.

       ENDIF.


     ENDIF.
   ENDIF.

   TYPES: BEGIN OF t_text_table,
            text(72),
          END OF t_text_table.
   DATA: lt_text_table TYPE STANDARD TABLE OF t_text_table,
         ls_text_table TYPE t_text_table,
         ls_text_lines LIKE LINE OF gt_text_lines.

   REFRESH lt_text_table.
   LOOP AT gt_text_lines INTO ls_text_lines.
     CLEAR ls_text_table.
     ls_text_table-text = ls_text_lines-tdline.
     APPEND ls_text_table TO lt_text_table.
   ENDLOOP.

   CALL METHOD gr_editor->set_text_as_r3table( lt_text_table ).



 ENDFORM.                    " SET_TEXT
*&---------------------------------------------------------------------*
*&      Form  VALIDATE_KALKA_V
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_IR_DATA_CHANGED  text
*      -->P_LS_MOD_CELL  text
*----------------------------------------------------------------------*
 FORM validate_kalka_v  USING    ir_data_changed TYPE REF TO cl_alv_changed_data_protocol
                                 ls_mod_cell TYPE lvc_s_modi.

* Set pricing unit to 1
   DATA : lv_value       TYPE lvc_value,
          lv_sh_text     TYPE string,
          lv_acpos       TYPE acpos,
          lv_res_name    TYPE /noveco/res_name,
          lv_kstar_ktext TYPE /noveco/evm_kstar_ktext,
          ls_cska        TYPE cska,
          lv_kstar       TYPE kstar,
          ls_ktopl       TYPE ktopl,
          lv_msgv1       TYPE string,
          lv_msgv2       TYPE string,
          lv_preis       TYPE preis,
          lv_waers       TYPE waers,
          ls_cost        LIKE LINE OF gcl_project->gt_var_costs_current.

   DATA: lv_peinh TYPE peinh.

   DATA: ls_kstar_range  TYPE /noveco/kstar_range,
         lt_kstar_range  TYPE /noveco/kstar_range_t,
         lv_kstar_to_try TYPE kstar,
         lv_lstar        TYPE lstar,
         lv_parob        TYPE parob,
         lt_cskb         TYPE TABLE OF cskb,
         ls_cskb         TYPE cskb.

   DATA lv_valid VALUE space.

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'SH_TEXT'
     IMPORTING
       e_value     = lv_sh_text.

   READ TABLE gcl_project->gt_var_costs_current INTO ls_cost INDEX ls_mod_cell-row_id.

   IF ls_mod_cell-fieldname EQ 'ACPOS' OR ls_mod_cell-fieldname EQ 'RES_NAME'.

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'ACPOS'
       IMPORTING
         e_value     = lv_acpos.

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'RES_NAME'
       IMPORTING
         e_value     = lv_res_name.

     CALL METHOD gobj_epm_main->get_kstar_range_for_acpos_res
       EXPORTING
         l_kokrs        = gcl_database->ml_config-kokrs
         l_bukrs        = gcl_database->ml_config-bukrs
         l_werks        = space
         l_acpos        = lv_acpos
         l_res_name     = lv_res_name
         l_ktopl        = gcl_database->ml_config-ktopl
       IMPORTING
         pt_kstar_range = lt_kstar_range
         e_lstar        = lv_lstar.

     CLEAR lv_kstar.
     LOOP AT lt_kstar_range INTO ls_kstar_range.

       IF ls_kstar_range-high IS INITIAL.
         ls_kstar_range-high = ls_kstar_range-low.
       ELSEIF ls_kstar_range-low IS INITIAL.
         ls_kstar_range-low = ls_kstar_range-high.
       ENDIF.

       FREE lt_cskb.
       SELECT * FROM cskb INTO TABLE lt_cskb
                               WHERE kstar GE ls_kstar_range-low
                                 AND kstar LE ls_kstar_range-high
                                 AND kokrs EQ gcl_database->ml_config-kokrs
                                 AND datbi GE sy-datum.
       IF sy-subrc EQ 0.
         LOOP AT lt_cskb INTO ls_cskb.
           IF ls_cskb-katyp EQ '01' OR ls_cskb-katyp EQ '42' OR ls_cskb-katyp EQ '43'.
             lv_valid = 'X'.
           ELSE.
             CLEAR lv_valid.
           ENDIF.

           IF lv_valid = 'X'.
             lv_kstar = ls_cskb-kstar.
             CALL METHOD ir_data_changed->modify_cell
               EXPORTING
                 i_row_id    = ls_mod_cell-row_id
                 i_fieldname = 'KSTAR'
                 i_value     = lv_kstar.
             EXIT. " loop on cskb range
           ENDIF.
         ENDLOOP.
         IF lv_kstar IS NOT INITIAL.
           EXIT. " loop on kstar range
         ENDIF.
       ENDIF.
     ENDLOOP.

     IF lv_valid IS INITIAL.
       lv_msgv1 = lv_acpos.
       CALL METHOD ir_data_changed->add_protocol_entry
         EXPORTING
           i_msgid     = '/NOVECO/EVM'
           i_msgno     = '054'                 "Cost Element & category & not allowed.
           i_msgty     = 'E'
           i_msgv1     = lv_msgv1
           i_msgv2     = lv_msgv2
           i_msgv3     = ''
           i_fieldname = ls_mod_cell-fieldname
           i_row_id    = ls_mod_cell-row_id.

       CALL METHOD ir_data_changed->display_protocol.
       EXIT.
     ENDIF.

   ENDIF.

   CALL METHOD ir_data_changed->modify_cell
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'RESOURCE'
       i_value     = space.

   CALL METHOD ir_data_changed->modify_cell
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'PLANT_ACTIVITY'
       i_value     = space.

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'PEINH'
     IMPORTING
       e_value     = lv_value.
   lv_peinh = lv_value.
   IF lv_peinh = '0'.
     lv_peinh = '1'.

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'PEINH'
         i_value     = lv_peinh.

   ENDIF.

   CONCATENATE 'KL' '1000' '1234567890' lv_lstar INTO lv_parob.

   IF ls_mod_cell-fieldname EQ 'KSTAR'.
     lv_kstar = ls_mod_cell-value.
   ENDIF.

   CALL FUNCTION 'CONVERSION_EXIT_ALPHA_INPUT'
     EXPORTING
       input  = lv_kstar
     IMPORTING
       output = lv_kstar.

*  get parameter id 'KPL' field ls_ktopl.
   ls_ktopl = gcl_database->ml_config-ktopl.

   SELECT SINGLE * INTO ls_cska FROM cska WHERE ktopl = ls_ktopl AND kstar = lv_kstar.

   SELECT SINGLE ktext INTO lv_kstar_ktext FROM csku
          WHERE spras = sy-langu AND ktopl = ls_cska-ktopl AND kstar = ls_cska-kstar.

   IF sy-subrc IS INITIAL.
     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'KTEXT'
         i_value     = lv_kstar_ktext.

     IF lv_sh_text IS INITIAL OR ( lv_kstar NE ls_cost-kstar AND
                                  ls_cost-kstar IS NOT INITIAL ).

       CALL METHOD ir_data_changed->modify_cell
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'SH_TEXT'
           i_value     = lv_kstar_ktext.
     ENDIF.

   ENDIF.

   CHECK lv_kstar IS NOT INITIAL.
   CALL METHOD gcl_epm_items->get_acpos_for_kstar
     EXPORTING
       p_appl      = 'PS'
       p_kokrs     = gcl_database->ml_config-kokrs
       p_kstar     = lv_kstar
       pt_resource = ltb_resource
     IMPORTING
       p_acpos     = lv_acpos.

   CALL METHOD ir_data_changed->modify_cell
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'ACPOS'
       i_value     = lv_acpos.

   CALL METHOD gcl_epm_items->get_resname_for_kstar
     EXPORTING
       p_kokrs      = gcl_database->ml_config-kokrs
       p_kstar      = lv_kstar
       p_acpos      = lv_acpos
       p_werks      = space
       p_bukrs      = gcl_database->ml_config-bukrs
       p_parob      = lv_parob
       ptb_resource = ltb_resource
     RECEIVING
       p_res_name   = lv_res_name.

   CALL METHOD ir_data_changed->modify_cell
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'RES_NAME'
       i_value     = lv_res_name.


*  manage Unit of Measure

   IF lv_kstar IS NOT INITIAL.
     DATA: lv_meeht TYPE meins,
           lv_katyp TYPE katyp.

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'MEEHT'
       IMPORTING
         e_value     = lv_meeht.

     IF lv_meeht IS INITIAL.

       SELECT SINGLE katyp FROM cskb INTO lv_katyp WHERE
                                kokrs = gcl_database->ml_config-kokrs AND
                                kstar = lv_kstar AND
                                datbi >= sy-datum.

       IF lv_katyp = '01'.

         SELECT SINGLE msehi FROM t006 INTO lv_meeht WHERE msehi = 'EA'.
         IF sy-subrc NE 0.
           SELECT SINGLE msehi FROM t006 INTO lv_meeht WHERE msehi = 'ST'.
         ENDIF.
       ELSE.
         SELECT SINGLE msehi FROM t006 INTO lv_meeht WHERE msehi = 'H'.
       ENDIF.

       IF lv_meeht IS NOT INITIAL.
         CALL METHOD ir_data_changed->modify_cell
           EXPORTING
             i_row_id    = ls_mod_cell-row_id
             i_fieldname = 'MEEHT'
             i_value     = lv_meeht.

       ENDIF.

     ENDIF.
   ENDIF.


 ENDFORM.                    " VALIDATE_KALKA_V

