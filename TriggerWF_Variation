*&---------------------------------------------------------------------*
*&      Form  HANDLE_TOOLBAR_COST
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_E_OBJECT  text
*      -->P_E_INTERACTIVE  text
*----------------------------------------------------------------------*
 FORM handle_toolbar_costs  USING i_object TYPE REF TO cl_alv_event_toolbar_set
                                    e_interactive TYPE char01.


   DATA: ls_toolbar         TYPE stb_button,
         lc_spacer          VALUE 3,
         lc_menu_button     VALUE 2,
         lc_standard_button VALUE 0,
         lv_disabled        TYPE char1.


   IF  gv_manage_rev_or_cost = 'R'. " currently managing Revenue Items - disable toolbar
     lv_disabled = 'X'.
   ENDIF.

   IF gs_qmel-budget_updated NE 'X' OR gs_qmel-fcast_updated NE 'X' .


     IF gs_qmel-qmart IS NOT INITIAL.

       lv_update_type = gcl_project->get_update_type( gs_qmel-qmart ).

       IF gv_change_mode = 'X'.
*         Confirm
         CLEAR ls_toolbar.
         MOVE lc_standard_button TO ls_toolbar-butn_type.
         MOVE 'CONF' TO ls_toolbar-function.
         MOVE 'Confirm'(t02) TO ls_toolbar-text.
         MOVE c_icon-icon_checked TO ls_toolbar-icon.

         IF lv_update_type NE '1'.  "Costs Only
           MOVE TEXT-t22 TO ls_toolbar-quickinfo. " Copy Costs to Revenue Item

         ELSE.
           MOVE TEXT-t23 TO ls_toolbar-quickinfo. " Copy Costs to Revenue Item
         ENDIF.

         MOVE lv_disabled TO ls_toolbar-disabled.
         APPEND ls_toolbar TO i_object->mt_toolbar.

       ENDIF.

     ENDIF.


     IF gv_change_mode = 'X'.


       lv_update_type = gcl_project->get_update_type( gs_qmel-qmart ).

       IF ( lv_update_type EQ '2' AND gcl_project->rev_item IS NOT INITIAL ) " revenue & costs and Revenue Item is selected
          OR ( lv_update_type EQ '1' ).                                      " it is Cost variation only

         CLEAR ls_toolbar.
         MOVE lc_spacer TO ls_toolbar-butn_type.
         APPEND ls_toolbar TO i_object->mt_toolbar.

*    create Costing Items
         CLEAR ls_toolbar.
         MOVE lc_standard_button TO ls_toolbar-butn_type.
         MOVE 'CCOS' TO ls_toolbar-function.
         MOVE c_icon-icon_create TO ls_toolbar-icon.
         MOVE TEXT-t24 TO ls_toolbar-quickinfo. " Create Cost Item
         MOVE lv_disabled TO ls_toolbar-disabled.
         APPEND ls_toolbar TO i_object->mt_toolbar.

*   insert Cost Items
         CLEAR ls_toolbar.
         MOVE lc_standard_button TO ls_toolbar-butn_type.
         MOVE 'ICOS' TO ls_toolbar-function.
         MOVE c_icon-icon_insert_row TO ls_toolbar-icon.
         MOVE TEXT-t25  TO ls_toolbar-quickinfo. " Insert Cost Item
         MOVE lv_disabled TO ls_toolbar-disabled.
         APPEND ls_toolbar TO i_object->mt_toolbar.

*   delete Cost Items
         CLEAR ls_toolbar.
         MOVE lc_standard_button TO ls_toolbar-butn_type.
         MOVE 'DCOS' TO ls_toolbar-function.
         MOVE c_icon-icon_delete_row TO ls_toolbar-icon.
         MOVE TEXT-t26 TO ls_toolbar-quickinfo. " Delete Cost Items
         MOVE lv_disabled TO ls_toolbar-disabled.
         APPEND ls_toolbar TO i_object->mt_toolbar.

*   copy Cost Item
         CLEAR ls_toolbar.
         MOVE lc_standard_button TO ls_toolbar-butn_type.
         MOVE 'CCOP' TO ls_toolbar-function.
         MOVE c_icon-icon_copy_object TO ls_toolbar-icon.
         MOVE TEXT-t27 TO ls_toolbar-quickinfo. " Copy Cost Item
         MOVE lv_disabled TO ls_toolbar-disabled.
         APPEND ls_toolbar TO i_object->mt_toolbar.

         CLEAR ls_toolbar.
         MOVE lc_spacer TO ls_toolbar-butn_type.
         APPEND ls_toolbar TO i_object->mt_toolbar.

*   update Budget
         CLEAR ls_toolbar.
         MOVE lc_menu_button TO ls_toolbar-butn_type.
         MOVE 'UCOS' TO ls_toolbar-function.

       ENDIF.

       IF gs_qmel-budget_updated NE  'X'.

         IF gv_budget_upd_flg = 'X'. " gs_qmel-budget_upd_flg = 'X'.

           MOVE c_icon-icon_okay TO ls_toolbar-icon.
           MOVE TEXT-t28 TO ls_toolbar-text. " Budget Update
           MOVE TEXT-t29  TO ls_toolbar-quickinfo. " Update Costing with Cost Items

         ELSE.

           MOVE c_icon-icon_cancel TO ls_toolbar-icon.
           MOVE TEXT-t30 TO ls_toolbar-text.
           MOVE TEXT-t31  TO ls_toolbar-quickinfo..

         ENDIF.

         MOVE lv_disabled TO ls_toolbar-disabled.
         APPEND ls_toolbar TO i_object->mt_toolbar.

       ENDIF.



     ENDIF.

   ENDIF.


*********
*     update Forecast
   IF gv_change_mode = 'X'.

     CLEAR ls_toolbar.
     MOVE lc_menu_button TO ls_toolbar-butn_type.
     MOVE 'UFOR' TO ls_toolbar-function.

     IF gs_qmel-fcast_updated NE  'X'.

       IF gv_fcast_upd_flg = 'X' . "gs_qmel-fcast_upd_flg = 'X'.

         MOVE c_icon-icon_okay TO ls_toolbar-icon.
         MOVE TEXT-t32 TO ls_toolbar-text. " Forecast Update
         MOVE TEXT-t33  TO ls_toolbar-quickinfo. " Update Forecast with Cost Items

       ELSE.

         MOVE c_icon-icon_cancel TO ls_toolbar-icon.
         MOVE TEXT-t34 TO ls_toolbar-text. " No Forecast Update
         MOVE TEXT-t35  TO ls_toolbar-quickinfo..

       ENDIF.

       MOVE lv_disabled TO ls_toolbar-disabled.
       APPEND ls_toolbar TO i_object->mt_toolbar.

     ENDIF.

     CLEAR ls_toolbar.
     MOVE lc_spacer TO ls_toolbar-butn_type.
     APPEND ls_toolbar TO i_object->mt_toolbar.

   ENDIF.

*********

*     Budget Updated
   CLEAR ls_toolbar.
   MOVE lc_standard_button TO ls_toolbar-butn_type.
   MOVE 'BUDU' TO ls_toolbar-function.

   IF gs_qmel-budget_updated = 'X'.

     MOVE c_icon-icon_okay TO ls_toolbar-icon.
     MOVE TEXT-t36 TO ls_toolbar-text. " Budget Updated
     MOVE TEXT-t37  TO ls_toolbar-quickinfo. " Costing has been updated with Cost Items

   ELSE.

     MOVE c_icon-icon_cancel TO ls_toolbar-icon.
     MOVE TEXT-t38 TO ls_toolbar-text. " Budget Not Updated
     MOVE TEXT-t39  TO ls_toolbar-quickinfo.

   ENDIF.

   MOVE lv_disabled TO ls_toolbar-disabled.
   APPEND ls_toolbar TO i_object->mt_toolbar.


*    Forecast Updated
   CLEAR ls_toolbar.
   MOVE lc_standard_button TO ls_toolbar-butn_type.
   MOVE 'FORU' TO ls_toolbar-function.

   IF gs_qmel-fcast_updated = 'X'.

     MOVE c_icon-icon_okay TO ls_toolbar-icon.
     MOVE TEXT-t40 TO ls_toolbar-text. " Forecast Updated
     MOVE TEXT-t41  TO ls_toolbar-quickinfo. " Forecast has been updated with Cost Items

   ELSE.

     MOVE c_icon-icon_cancel TO ls_toolbar-icon.
     MOVE TEXT-t42 TO ls_toolbar-text. " Forecast Not Updated
     MOVE TEXT-t43  TO ls_toolbar-quickinfo.

   ENDIF.

   MOVE lv_disabled TO ls_toolbar-disabled.
   APPEND ls_toolbar TO i_object->mt_toolbar.

 ENDFORM.                    " HANDLE_TOOLBAR_COST
*&---------------------------------------------------------------------*
*&      Form  HANDLE_USER_COMMAND_COSTS
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_E_UCOMM  text
*----------------------------------------------------------------------*
 FORM handle_user_command_costs  USING i_ucomm.

   CASE i_ucomm .

*   Costs
     WHEN 'CCOS'.
       PERFORM create_cost_item.

     WHEN 'ICOS'.
       PERFORM insert_cost_item.

     WHEN 'DCOS'.
       PERFORM delete_cost_item.

     WHEN 'CCOP'.
       PERFORM copy_cost_item.


     WHEN 'CONF'.
       PERFORM confirm_cost_item.


     WHEN 'NBUD'.  "Set No Budget update
       CLEAR: gv_budget_upd_flg. " gs_qmel-budget_upd_flg.
       gcl_screen->gr_alv_costs->refresh( ).
       gv_changes_made = 'X'.

     WHEN 'YBUD'.  "Set Yes Budget update
       gv_budget_upd_flg = 'X'.   " gs_qmel-budget_upd_flg = 'X'.
       gcl_screen->gr_alv_costs->refresh( ).
       gv_changes_made = 'X'.

     WHEN 'UFO1'.  "Set Yes Forecast update
       gv_fcast_upd_flg = 'X'. " gs_qmel-fcast_upd_flg = 'X'.
       gcl_screen->gr_alv_costs->refresh( ).
       gv_changes_made = 'X'.

     WHEN 'UFO2'.  "Set No Forecast update
       CLEAR: gv_fcast_upd_flg. " gs_qmel-fcast_upd_flg.
       gcl_screen->gr_alv_costs->refresh( ).
       gv_changes_made = 'X'.

   ENDCASE.

   gs_qmel-budget_upd_flg = gv_budget_upd_flg.
   gs_qmel-fcast_upd_flg = gv_fcast_upd_flg.

 ENDFORM.                    " HANDLE_USER_COMMAND_COSTS
