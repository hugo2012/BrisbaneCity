   DATA : lv_value     TYPE lvc_value,
          lv_sh_text   TYPE string,
          lv_serv_text TYPE asktx,
          lv_acpos     TYPE acpos,
          lv_res_name  TYPE /noveco/res_name,
          lv_kalka     TYPE /noveco/var_cost-kalka,
          ls_cost      LIKE LINE OF gcl_project->gt_var_costs_current.

   READ TABLE gcl_project->gt_var_costs_current INTO ls_cost INDEX ls_mod_cell-row_id.

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'RESOURCE'
     IMPORTING
       e_value     = lv_value.

   DATA: lv_asnum TYPE asnum.
   lv_asnum = lv_value.

   TRANSLATE: lv_asnum  TO UPPER CASE.
   CALL FUNCTION 'CONVERSION_EXIT_ALPHA_OUTPUT'
     EXPORTING
       input  = lv_asnum
     IMPORTING
       output = lv_asnum.

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'SH_TEXT'
     IMPORTING
       e_value     = lv_value.

