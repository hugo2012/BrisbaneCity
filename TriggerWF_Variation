*&---------------------------------------------------------------------*
*&      Form  ADD_TO_FAVOR_LIST_PROJ
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
 FORM add_to_favor_list_proj .


   DATA: lt_index_rows TYPE lvc_t_row,
         lt_row_no     TYPE lvc_t_roid,
         ls_row_no     TYPE LINE OF lvc_t_roid,
         lv_modify.

   DATA ls_proj_list LIKE LINE OF gcl_screen->gt_open_proj_list.

   CALL METHOD gcl_screen->gr_open_grid->get_selected_rows
     IMPORTING
       et_index_rows = lt_index_rows
       et_row_no     = lt_row_no.

   IF lt_row_no IS INITIAL.
     MESSAGE s081(/noveco/epm) DISPLAY LIKE 'I' .
     EXIT.
   ENDIF.

   LOOP AT lt_row_no INTO ls_row_no.

     READ TABLE gcl_screen->gt_open_proj_list INTO ls_proj_list INDEX ls_row_no-row_id.

     READ TABLE gcl_screen->gt_open_proj_list WITH KEY proj_pspnr  = ls_proj_list-proj_pspnr
                                           wbs_pspnr   = ls_proj_list-wbs_pspnr
                                           proj_pspnr_to    = ls_proj_list-proj_pspnr_to
                                           wbs_pspnr_to     = ls_proj_list-wbs_pspnr_to
                                           vernr       = ls_proj_list-vernr
                                           type        = 1
                                           TRANSPORTING NO FIELDS.
     IF sy-subrc NE 0.
       ls_proj_list-type = 1. " Favourite
       MODIFY /noveco/wboplist FROM ls_proj_list.
       APPEND ls_proj_list TO gcl_screen->gt_open_proj_list.
       lv_modify  = abap_true.
     ENDIF.

   ENDLOOP.

   IF lv_modify = abap_true.
     COMMIT WORK.
     CALL METHOD gcl_screen->gr_open_grid->refresh_table_display.

   ENDIF.

 ENDFORM.                    " ADD_TO_FAVOR_LIST_PROJ
*&---------------------------------------------------------------------*
*&      Form  DELETE_FROM_LIST_PROJ
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
 FORM delete_from_list_proj .


   DATA: lt_index_rows     TYPE lvc_t_row,
         lt_row_no         TYPE lvc_t_roid,
         lt_open_proj_list LIKE  gcl_screen->gt_open_proj_list,
         ls_row_no         TYPE LINE OF lvc_t_roid,
         lv_modify.

   DATA ls_proj_list LIKE LINE OF gcl_screen->gt_open_proj_list.


   CALL METHOD gcl_screen->gr_open_grid->get_selected_rows
     IMPORTING
       et_index_rows = lt_index_rows
       et_row_no     = lt_row_no.

   IF lt_row_no IS INITIAL.
     MESSAGE s081(/noveco/epm) DISPLAY LIKE 'I' .
     EXIT.
   ENDIF.

   lt_open_proj_list[] = gcl_screen->gt_open_proj_list[].

   LOOP AT lt_row_no INTO ls_row_no.
     READ TABLE lt_open_proj_list INTO ls_proj_list INDEX ls_row_no-row_id.


     DELETE FROM /noveco/wboplist WHERE user_id          = ls_proj_list-user_id    AND
                                        proj_pspnr  = ls_proj_list-proj_pspnr AND
                                        wbs_pspnr   = ls_proj_list-wbs_pspnr  AND
                                        proj_pspnr_to    = ls_proj_list-proj_pspnr_to AND
                                        wbs_pspnr_to     = ls_proj_list-wbs_pspnr_to  AND
                                        vernr            = ls_proj_list-vernr   AND
                                        type             = ls_proj_list-type.

     lv_modify  = abap_true.
     DELETE  gcl_screen->gt_open_proj_list WHERE proj_pspnr  = ls_proj_list-proj_pspnr AND
                                     wbs_pspnr   = ls_proj_list-wbs_pspnr  AND
                                     proj_pspnr_to    = ls_proj_list-proj_pspnr_to AND
                                     wbs_pspnr_to     = ls_proj_list-wbs_pspnr_to  AND
                                     vernr       = ls_proj_list-vernr      AND
                                     type        = ls_proj_list-type.

   ENDLOOP.

   IF lv_modify = abap_true.
     COMMIT WORK.
     CALL METHOD gcl_screen->gr_open_grid->refresh_table_display.
   ENDIF.


 ENDFORM.                    " DELETE_FROM_LIST_PROJ



*&---------------------------------------------------------------------*
*&      Form  HANDLE_TOOLBAR_REVENUE
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_E_OBJECT  text
*      -->P_E_INTERACTIVE  text
*----------------------------------------------------------------------*
 FORM handle_toolbar_revenue  USING i_object TYPE REF TO cl_alv_event_toolbar_set
                                    e_interactive TYPE char01.


   DATA: ls_toolbar         TYPE stb_button,
         lc_spacer          VALUE 3,
         lc_menu_button     VALUE 2,
         lc_standard_button VALUE 0.


* go to Costing View
* only allowed if Costing Allowed in /NOVECO/EPM_VTYP
   IF gs_qmel-qmart IS NOT INITIAL.

     DATA lv_update_type TYPE  /noveco/epm_vtyp-update_type.
     lv_update_type = gcl_project->get_update_type( gs_qmel-qmart ).

     IF lv_update_type EQ '2'.   "Revenue and Costs

       CLEAR ls_toolbar.
       MOVE lc_standard_button TO ls_toolbar-butn_type.
       MOVE 'COST' TO ls_toolbar-function.
       MOVE 'Calculate Costs'(t58) TO ls_toolbar-text.
       MOVE c_icon-icon_unit_costing TO ls_toolbar-icon.
       MOVE TEXT-t57  TO ls_toolbar-quickinfo. " 'Go to Costing view'
       MOVE ' ' TO ls_toolbar-disabled.
       APPEND ls_toolbar TO i_object->mt_toolbar.

       CLEAR ls_toolbar.
       MOVE lc_spacer TO ls_toolbar-butn_type.
       APPEND ls_toolbar TO i_object->mt_toolbar.

     ENDIF.

   ENDIF.


* create Revenue Items
   IF gs_qmel-revenue_updated NE 'X'.

     IF gv_change_mode = 'X' AND gcl_project->rev_item IS INITIAL.

       CLEAR ls_toolbar.
       MOVE lc_standard_button TO ls_toolbar-butn_type.
       MOVE 'CREV' TO ls_toolbar-function.
       MOVE c_icon-icon_create TO ls_toolbar-icon.
       MOVE TEXT-t08 TO ls_toolbar-quickinfo. " 'Create Revenue Variation Items'
       MOVE ' ' TO ls_toolbar-disabled.
       APPEND ls_toolbar TO i_object->mt_toolbar.


*   insert Revenue Items
       CLEAR ls_toolbar.
       MOVE lc_standard_button TO ls_toolbar-butn_type.
       MOVE 'IREV' TO ls_toolbar-function.
       MOVE c_icon-icon_insert_row TO ls_toolbar-icon.
       MOVE TEXT-t09 TO ls_toolbar-quickinfo. " 'Insert Revenue Item'
       MOVE ' ' TO ls_toolbar-disabled.
       APPEND ls_toolbar TO i_object->mt_toolbar.

*   delete Revenue Items
       CLEAR ls_toolbar.
       MOVE lc_standard_button TO ls_toolbar-butn_type.
       MOVE 'DREV' TO ls_toolbar-function.
       MOVE icon_delete_row TO ls_toolbar-icon.
       MOVE TEXT-t10 TO ls_toolbar-quickinfo. " Delete Revenue Items.
       MOVE ' ' TO ls_toolbar-disabled.
       APPEND ls_toolbar TO i_object->mt_toolbar.


*     copy Revenue Item
       CLEAR ls_toolbar.
       MOVE lc_standard_button TO ls_toolbar-butn_type.
       MOVE 'RCOP' TO ls_toolbar-function.
       MOVE c_icon-icon_copy_object TO ls_toolbar-icon.
       MOVE TEXT-t11  TO ls_toolbar-quickinfo. "Copy Revenue Item
       MOVE ' ' TO ls_toolbar-disabled.
       APPEND ls_toolbar TO i_object->mt_toolbar.

       CLEAR ls_toolbar.
       MOVE lc_spacer TO ls_toolbar-butn_type.
       APPEND ls_toolbar TO i_object->mt_toolbar.

     ENDIF.
     IF gv_change_mode = 'X'.
*     update Revenue
       CLEAR ls_toolbar.
       MOVE lc_menu_button TO ls_toolbar-butn_type.
       MOVE 'UREV' TO ls_toolbar-function.

       IF gs_qmel-revenue_updated NE  'X'.

         IF gv_revenue_upd_flg = 'X'.

           MOVE c_icon-icon_okay TO ls_toolbar-icon.
           MOVE TEXT-t12 TO ls_toolbar-text. "Revenue Update
           MOVE TEXT-t13  TO ls_toolbar-quickinfo. " Update Costing with Revenue Items


         ELSE.

           MOVE c_icon-icon_cancel TO ls_toolbar-icon.
           MOVE TEXT-t14 TO ls_toolbar-text. "No Revenue Update
           MOVE TEXT-t15  TO ls_toolbar-quickinfo. " Do Not Update Costing with Revenue Items

         ENDIF.

         MOVE ' ' TO ls_toolbar-disabled.
         APPEND ls_toolbar TO i_object->mt_toolbar.

       ENDIF.
     ENDIF.


   ENDIF.


* Revenue Updated
   CLEAR ls_toolbar.
   MOVE lc_standard_button TO ls_toolbar-butn_type.
   MOVE 'REVU' TO ls_toolbar-function.

   IF gs_qmel-revenue_updated = 'X'.

     MOVE c_icon-icon_okay TO ls_toolbar-icon.
     MOVE TEXT-t16 TO ls_toolbar-text. " Revenue Updated
     MOVE TEXT-t17  TO ls_toolbar-quickinfo. " Costing has been updated with Revenue Items

   ELSE.

     MOVE c_icon-icon_cancel TO ls_toolbar-icon.
     MOVE TEXT-t18 TO ls_toolbar-text. " Revenue Not Updated
     MOVE TEXT-t19 TO ls_toolbar-quickinfo. " Costing has not been updated with Revenue Items

   ENDIF.

   MOVE ' ' TO ls_toolbar-disabled.
   APPEND ls_toolbar TO i_object->mt_toolbar.



 ENDFORM.                    " HANDLE_TOOLBAR_REVENUE

*&---------------------------------------------------------------------*
*&      Form  HANDLE_TREE_DOUBLE_CLICK
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_NODE_KEY  text
*      -->P_TEXT_I11  text
*----------------------------------------------------------------------*
 FORM handle_tree_double_click  USING    p_node_key
                                         p_text.

   DATA: ls_tree      LIKE LINE OF gcl_project->gt_tree,
         lv_parent_id TYPE seu_id.

   DATA: lt_index_rows TYPE lvc_t_row,
         lt_row_no     TYPE lvc_t_roid.

   DATA: revenue_item_selected,
         cost_item_selected.

   CHECK gv_template_list = space.

   CHECK gv_change_mode = abap_true.

   CALL METHOD gcl_screen->gr_tree->get_selected_level_parent
     EXPORTING
       i_key       = p_node_key
     IMPORTING
       e_parent_id = lv_parent_id.


   READ TABLE gcl_project->gt_tree INTO ls_tree WITH KEY id = lv_parent_id BINARY SEARCH.
   IF sy-subrc = 0.

*   Any Costing item selected?
     DATA lv_found.
     CLEAR lv_found.


     IF gs_qmel-qmart IS NOT INITIAL.
       DATA lv_update_type TYPE  /noveco/epm_vtyp-update_type.
       lv_update_type = gcl_project->get_update_type( gs_qmel-qmart ).
     ENDIF.

* Check if Revenue Item(s) selected
     CALL METHOD gcl_screen->gr_alv_revenue->gr_alv->get_selected_rows
       IMPORTING
         et_index_rows = lt_index_rows
         et_row_no     = lt_row_no.

     IF lt_index_rows IS NOT INITIAL.
       revenue_item_selected = abap_true.
     ENDIF.

     FREE: lt_index_rows, lt_row_no.

* Check if Cost Item(s) selected
     CALL METHOD gcl_screen->gr_alv_costs->gr_alv->get_selected_rows
       IMPORTING
         et_index_rows = lt_index_rows
         et_row_no     = lt_row_no.

     IF lt_index_rows IS NOT INITIAL.
       cost_item_selected = abap_true.
     ENDIF.

*   Cannot assign Project Tree if both Revenue and Cost Items are selected at the same time
     IF revenue_item_selected = abap_true AND cost_item_selected = abap_true.
       MESSAGE i058(/noveco/evm). "Select either Revenue or Cost Item(s), but not both at the same time
       RETURN.
     ENDIF.

     IF cost_item_selected = abap_true.
       PERFORM set_tree_object_in_costing USING ls_tree
                                          CHANGING lv_found.
     ENDIF.

     IF revenue_item_selected = abap_true.
       PERFORM set_tree_object_in_revenue USING ls_tree.
     ENDIF.

   ENDIF.



 ENDFORM.                    " HANDLE_TREE_DOUBLE_CLICK

