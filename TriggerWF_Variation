 FORM set_tree_object_in_costing  USING    p_tree TYPE /noveco/evm_ps_tree
                                  CHANGING p_found.

   CLEAR p_found.

   CHECK gv_change_mode = 'X'.

   CHECK gs_qmel-budget_updated NE 'X' AND gs_qmel-fcast_updated NE 'X'.


* only Planning Elements are allowed
   DATA: lv_plan_allowed VALUE space,
         lv_objnr        TYPE j_objnr.

   lv_objnr = p_tree-name.

*  call method gcl_database->is_planning_element
*    exporting
*      p_level = gcl_project->gv_plan_level
*      p_objnr = lv_objnr
*    importing
*      p_yes   = lv_plan_allowed.

   IF p_tree-plan_allowed NE 'X'.
     MESSAGE s037(/noveco/evm) DISPLAY LIKE 'E'.  "Planning not allowed on this project level.
     EXIT.
   ENDIF.


* get selected cost item(s)
   DATA lt_index_rows TYPE lvc_t_row.
   DATA lt_row_no TYPE lvc_t_roid.
   DATA lv_row TYPE i.

   CALL METHOD gcl_screen->gr_alv_costs->gr_alv->get_selected_rows
     IMPORTING
       et_index_rows = lt_index_rows
       et_row_no     = lt_row_no.

   DATA: lv_num_selected TYPE i VALUE 0.
   LOOP AT lt_index_rows TRANSPORTING NO FIELDS WHERE rowtype IS INITIAL.
     ADD 1 TO lv_num_selected.
   ENDLOOP.
   IF sy-subrc NE 0.
*    EXIT.
     MESSAGE i023(/noveco/evm).  "please select a row
*  ELSEIF lv_num_selected GT 1.
*    MESSAGE i022.   "select only one cost item
   ELSE.
     DATA ls_index_rows LIKE LINE OF lt_index_rows.
     LOOP AT lt_index_rows INTO ls_index_rows WHERE rowtype IS INITIAL.

       lv_row = ls_index_rows-index.


       CALL METHOD gcl_project->set_cost_item_project_object
         EXPORTING
           i_qmnum    = gs_qmel-qmnum
           i_rev_item = gcl_project->rev_item
           i_row      = lv_row
           i_tree     = p_tree.



     ENDLOOP.
     IF sy-subrc = 0.

       gcl_screen->gr_alv_costs->refresh( ).

       gv_changes_made = 'X'.

       p_found = 'X'.
     ENDIF.

   ENDIF.

 ENDFORM.                    " SET_TREE_OBJECT_IN_COSTING
*&---------------------------------------------------------------------*
*&      Form  SET_TREE_OBJECT_IN_REVENUE
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_LS_TREE  text
*----------------------------------------------------------------------*
 FORM set_tree_object_in_revenue  USING    p_tree TYPE /noveco/evm_ps_tree.


   CHECK gv_change_mode = 'X'.

   CHECK gs_qmel-budget_updated NE 'X' AND gs_qmel-fcast_updated NE 'X'.

* Check this is a Billing Element


* get selected revenue item, and ensure only one selected
   DATA lt_index_rows TYPE lvc_t_row.
   DATA lt_row_no TYPE lvc_t_roid.
   DATA lv_row TYPE i.

   CALL METHOD gcl_screen->gr_alv_revenue->gr_alv->get_selected_rows
     IMPORTING
       et_index_rows = lt_index_rows
       et_row_no     = lt_row_no.

   DATA: lv_num_selected TYPE i VALUE 0.
   LOOP AT lt_index_rows TRANSPORTING NO FIELDS WHERE rowtype IS INITIAL.
     ADD 1 TO lv_num_selected.
   ENDLOOP.
   IF sy-subrc NE 0.
     MESSAGE i008(/noveco/evm).  "please select a row
   ELSEIF lv_num_selected GT 1.
     MESSAGE i009(/noveco/evm).   "select only one rev item
   ELSE.
     DATA ls_index_rows LIKE LINE OF lt_index_rows.
     LOOP AT lt_index_rows INTO ls_index_rows WHERE rowtype IS INITIAL.

       lv_row = ls_index_rows-index.


       CALL METHOD gcl_project->set_rev_item_project_object
         EXPORTING
           i_qmnum             = gs_qmel-qmnum
           i_row               = lv_row
           i_tree              = p_tree
         EXCEPTIONS
           invalid_object_type = 1
           OTHERS              = 0.

       IF sy-subrc EQ 0.

*       Is this a Billing Element
         DATA ls_prps LIKE LINE OF gcl_database->mt_prps_r.

         READ TABLE gcl_database->mt_prps_r INTO ls_prps WITH KEY pspnr = p_tree-pspnr.
         IF sy-subrc = 0.
           IF ls_prps-fakkz NE 'X'.
*            raise not_billing_element.
             FIELD-SYMBOLS <fs_var_rev> TYPE /noveco/var_rev_alv.
*           clear WBS
             READ TABLE gcl_project->gt_var_revenue INDEX lv_row ASSIGNING <fs_var_rev>.
             IF sy-subrc = 0.
               CLEAR <fs_var_rev>-pspnr.
             ENDIF.
             MESSAGE i046(/noveco/evm).   "Revenue items must be assigned to a WBS that is a Billing Element.
           ENDIF.
         ENDIF.

         gcl_screen->gr_alv_revenue->refresh( ).

         gv_changes_made = 'X'.

         EXIT.

       ELSE.

         MESSAGE i024(/noveco/evm).   "select only WBS

       ENDIF.

     ENDLOOP.

   ENDIF.

 ENDFORM.                    " SET_TREE_OBJECT_IN_REVENUE

*&---------------------------------------------------------------------*
*&      Form  CHANGE_VARIATION
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
 FORM change_variation USING override .

* Toggle Display / Change Mode
   IF gv_change_mode IS INITIAL.

     DATA: error TYPE char1.
     PERFORM authority_check CHANGING error.
     IF error = 'X'.
       RETURN.
     ENDIF.

*   No Change if notification rejected
     DATA ls_epm_vupd TYPE /noveco/epm_vupd.
*     is it an rejected status via /NOVECO/EPM_VUPD?
     SELECT SINGLE * FROM /noveco/epm_vupd INTO ls_epm_vupd
       WHERE qmart = gs_qmel-qmart
         AND stsma = gs_qmel-stsma
         AND estat = gs_qmel-user_status
         AND var_stat = '03'.

     IF sy-subrc = 0.
*    IF gs_qmel-user_status_code = 'RJ'.  "Rejected.
       MESSAGE s028(/noveco/evm) WITH gs_qmel-qmnum  DISPLAY LIKE 'E'.
       MESSAGE s028(/noveco/evm) WITH gs_qmel-qmnum INTO gv_ui5_message.
       gv_ui5_message_type = 'E'.
       RETURN.
     ENDIF.

*   No Change if notification completed (but not Put Back In Process)

     IF gcl_project->claim_is_completed( gs_qmel-objnr ) = 'X' AND override IS INITIAL.
       MESSAGE s030(/noveco/evm) WITH gs_qmel-qmnum DISPLAY LIKE 'E'.    "Claim & was completed. No changes allowed.
       MESSAGE s030(/noveco/evm) WITH gs_qmel-qmnum INTO gv_ui5_message.
       gv_ui5_message_type = 'E'.
     ELSE.


       IF gs_qmel-qmnum IS NOT INITIAL AND gs_qmel-qmnum(1) NE '$'.
         IF gcl_project->lock_claim( gs_qmel-qmnum ) = 'X'.

           IF gcl_project->lock_sales_order( gs_qmel-vbeln ) = 'X'.
             gcl_project->get_claim_header( CHANGING c_qmel = gs_qmel ).
             gv_change_mode = 'X'.

             CLEAR gcl_project->rev_item.

*           update system status to I0070  (NOPR) Notification In Process
             DATA lv_objnr TYPE jest-objnr.
             DATA lt_status TYPE STANDARD TABLE OF jstat.
             DATA ls_status TYPE jstat.

             ls_status-stat  = 'I0070'.
             ls_status-inact = space.
             APPEND ls_status TO lt_status.

             ls_status-stat  = 'I0072'.
             ls_status-inact = 'X'.
             APPEND ls_status TO lt_status.

             lv_objnr = gs_qmel-objnr.

             CALL FUNCTION 'STATUS_CHANGE_INTERN'
               EXPORTING
*                CHECK_ONLY          = ' '
                 objnr               = lv_objnr
               TABLES
                 status              = lt_status
               EXCEPTIONS
                 object_not_found    = 1
                 status_inconsistent = 2
                 status_not_allowed  = 3
                 OTHERS              = 4.
             IF sy-subrc <> 0.
               MESSAGE s050(/noveco/evm) WITH gs_qmel-vbeln.   "Claim can not be put back in process.
             ELSE.
               COMMIT WORK AND WAIT.
             ENDIF.

           ELSE.
             MESSAGE s034(/noveco/evm) WITH gs_qmel-vbeln.  "Sales Order can not be locked
           ENDIF.

         ELSE.
           MESSAGE s026(/noveco/evm) WITH gs_qmel-qmnum.
         ENDIF.
       ELSE.
         gv_change_mode = 'X'.
         CLEAR gcl_project->rev_item.
       ENDIF.

     ENDIF.

   ELSE.

     IF gv_changes_made = 'X'.

       DATA: lv_abort, lv_response.
       PERFORM prompt_for_save_changes
                   CHANGING
                      lv_abort
                      lv_response.

       IF lv_response = 'N'. " 'N' - don't Save
         CLEAR: gcl_project->gt_var_revenue, gcl_project->gt_var_costs, gcl_project->gt_var_costs_current.
         CALL METHOD gcl_screen->show_both_alvs( ).
         PERFORM set_no_variation.

         IF lv_abort NE 'X'.
           CLEAR: gv_change_mode, gv_changes_made.

         ENDIF.
       ENDIF.
     ELSE.
       CLEAR: gv_change_mode.
     ENDIF.

     gcl_project->unlock_claim( gs_qmel-qmnum ).
     gcl_project->unlock_sales_order( gs_qmel-vbeln ).


   ENDIF.

   SELECT SINGLE * FROM /noveco/epm_vupd INTO ls_epm_vupd
     WHERE qmart = gs_qmel-qmart
       AND stsma = gs_qmel-stsma
       AND estat = gs_qmel-user_status.

   IF ls_epm_vupd-var_stat = c_approved_stat. "Approved

     IF gs_qmel-revenue_updated = space.
       CLEAR gv_revenue_upd_flg.
     ENDIF.

     IF gs_qmel-budget_updated = space.
       CLEAR gv_budget_upd_flg.
     ENDIF.

     IF gs_qmel-fcast_updated = space.
       CLEAR gv_fcast_upd_flg.
     ENDIF.


   ENDIF.

* Add new empty cost line
   IF gv_change_mode IS NOT INITIAL.
     PERFORM add_empty_cost_item.
   ENDIF.

   CALL METHOD gcl_screen->adjust_alv_visibility
     EXPORTING
       i_qmart       = gs_qmel-qmart
     CHANGING
       c_update_type = gs_qmel-update_type.

   IF gs_qmel-update_type = '1'. " Costs only
     gv_manage_rev_or_cost = 'C'. " manage costs items
   ELSE.
     gv_manage_rev_or_cost = 'R'. " manage revenue items
   ENDIF.

   PERFORM set_alv_read_only_status.

   IF gcl_project->claim_was_completed( gs_qmel ) = abap_false.
     PERFORM set_revenue_field_editability .
     PERFORM set_costs_field_editability.
   ENDIF.

   gcl_screen->gr_alv_revenue->refresh( ).
   gcl_screen->gr_alv_costs->refresh( ).

   DATA: lv_update_type TYPE /noveco/var_update.

   SELECT SINGLE update_type FROM /noveco/epm_vtyp
     INTO lv_update_type
     WHERE qmart = gs_qmel-qmart.

   IF lv_update_type = '1'. " Costs only
     gv_manage_rev_or_cost = 'C'. " manage costs items
   ELSE.
     gv_manage_rev_or_cost = 'R'. " manage revenue items
   ENDIF.


 ENDFORM.                    " CHANGE_VARIATION

