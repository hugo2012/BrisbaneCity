*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_LS_PROJ_PSPNR  text
*----------------------------------------------------------------------*
 FORM add_project  USING   p_proj TYPE proj.

   DATA: lt_rsthie_m      LIKE  gcl_database->mt_rsthie_m,
         lt_prps_r        LIKE gcl_database->mt_prps_r,
         lt_aufk_rep      LIKE gcl_database->mt_aufk_rep,
         ls_proj_selected TYPE /noveco/sel_proj_objects,
         lt_elm_ps        LIKE gcl_database->mt_elm_ps,
         lt_rpsco_m       LIKE gcl_database->mt_rpsco_m.

   DATA: ls_objnr_nwa TYPE /noveco/evm_objnr_nwa,
         ls_objnr_wbs TYPE /noveco/evm_objnr_wbs,
         ls_elm_ps    TYPE elm_ps.

*          Open new project
   lt_rsthie_m = gcl_database->mt_rsthie_m.
   lt_prps_r   = gcl_database->mt_prps_r.
   lt_aufk_rep = gcl_database->mt_aufk_rep.
   lt_elm_ps   = gcl_database->mt_elm_ps.
   lt_rpsco_m  = gcl_database->mt_rpsco_m.


   FREE gt_selected_proj_list.
   ls_proj_selected-pspid = p_proj-pspid.
   APPEND ls_proj_selected TO gt_selected_proj_list.

   CALL METHOD gcl_database->open_project
     EXPORTING
       p_pspnr = p_proj-pspnr
       p_date  = sy-datum.

* Add network activities
   LOOP AT gcl_database->mt_elm_ps INTO ls_elm_ps WHERE obtyp EQ gcl_project->gc_objtype_nwa OR
                                                        obtyp EQ gcl_project->gc_objtype_wbs.
     CASE ls_elm_ps-obtyp.
       WHEN gcl_project->gc_objtype_nwa.

         ls_objnr_nwa-objnr = ls_elm_ps-objnr.
         ls_objnr_nwa-aufnr = ls_elm_ps-aufnr.
         ls_objnr_nwa-vornr = ls_elm_ps-vornr.
         ls_objnr_nwa-ltxa1 = ls_elm_ps-ktext.

         APPEND ls_objnr_nwa TO gcl_project->gt_objnr_nwa.

       WHEN gcl_project->gc_objtype_wbs.

         ls_objnr_wbs-objnr = ls_elm_ps-objnr.
         ls_objnr_wbs-pspnr = ls_elm_ps-prps_int.

         APPEND ls_objnr_wbs TO gcl_project->gt_objnr_wbs.

     ENDCASE.


   ENDLOOP.

   APPEND LINES OF lt_rsthie_m TO gcl_database->mt_rsthie_m.
   APPEND LINES OF lt_prps_r   TO gcl_database->mt_prps_r.
   APPEND LINES OF lt_aufk_rep TO gcl_database->mt_aufk_rep.
   APPEND LINES OF lt_elm_ps   TO gcl_database->mt_elm_ps.
   APPEND LINES OF lt_rpsco_m  TO gcl_database->mt_rpsco_m.

 ENDFORM.                    " OPEN_ANOTHER_PROJECT
*&---------------------------------------------------------------------*
*&      Form  OPEN_ANOTHER_PROJECT
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_P_PSPID  text
*----------------------------------------------------------------------*
 FORM open_another_project  USING  p_pspid TYPE ps_pspid.

* check if Variation is an Adjustment.

   DATA: l_another_proj TYPE c.
   DATA: ls_var_cost TYPE /noveco/var_cost_alv,
         ls_proj     TYPE proj.

   PERFORM check_if_diff_project_allowed CHANGING l_another_proj.
   IF l_another_proj EQ 'N'.
     EXIT.
   ELSE.

     LOOP AT gcl_project->gt_var_costs INTO ls_var_cost.
       CHECK ls_var_cost-proj_pspid IS NOT INITIAL.

       IF ls_var_cost-proj_pspid NE p_pspid.
         SELECT SINGLE * FROM proj INTO ls_proj WHERE pspid = ls_var_cost-proj_pspid.
         IF sy-subrc EQ 0.
           PERFORM add_project USING ls_proj.
         ENDIF.
       ENDIF.

     ENDLOOP.

   ENDIF.




