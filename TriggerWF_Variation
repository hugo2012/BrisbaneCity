*----------------------------------------------------------------------*
 FORM clear_tree_completely .

   DATA ls_tree LIKE LINE OF gcl_project->gt_tree.
   DATA lv_node_key TYPE lvc_nkey.

   FIELD-SYMBOLS  <fs_tree> LIKE LINE OF gcl_project->gt_tree.


   LOOP AT gcl_project->gt_tree INTO ls_tree.

     IF ls_tree-revenue IS NOT INITIAL OR
        ls_tree-costs IS NOT INITIAL OR
        ls_tree-profit IS NOT INITIAL OR
        ls_tree-expected_reven IS NOT INITIAL OR
        ls_tree-expected_fcast IS NOT INITIAL OR
        ls_tree-expected_budget IS NOT INITIAL OR
        ls_tree-expected_profit IS NOT INITIAL.


       CLEAR lv_node_key.
       CALL METHOD gcl_screen->gr_tree->get_level_of_object_wth_id
         EXPORTING
           id       = ls_tree-id
         IMPORTING
           node_key = lv_node_key.

       CLEAR: ls_tree-revenue, ls_tree-costs, ls_tree-profit,
              ls_tree-expected_reven, ls_tree-expected_fcast,
              ls_tree-expected_budget, ls_tree-expected_profit.


       IF gv_ui5_call IS INITIAL.

         CALL METHOD gcl_screen->gr_tree->change_node
           EXPORTING
             i_node_key = lv_node_key
             i_data_row = ls_tree.

       ELSE.

         READ TABLE gcl_project->gt_tree ASSIGNING <fs_tree>
              WITH KEY id = ls_tree-id.
         MOVE-CORRESPONDING ls_tree TO <fs_tree>.
         UNASSIGN <fs_tree>.

       ENDIF.

     ENDIF.


   ENDLOOP.

 ENDFORM.                    " CLEAR_TREE_COMPLETELY

