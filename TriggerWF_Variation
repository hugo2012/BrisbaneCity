 FORM update_status CHANGING p_error_saving_status TYPE xfeld.

   DATA: ls_return TYPE bapiret2.

   CLEAR p_error_saving_status.

   IF gs_qmel-user_status_code NE gv_user_status_code.

     CALL METHOD gcl_project->update_user_status
       EXPORTING
         i_qmnum                    = gs_qmel-qmnum
         i_user_status_code         = gs_qmel-user_status_code
         i_stsma                    = gs_qmel-stsma
       IMPORTING
         e_return                   = ls_return
       EXCEPTIONS
         error_updating_user_status = 1
         OTHERS                     = 2.
     IF sy-subrc = 0.
       gv_user_status_code = gs_qmel-user_status_code.

       gcl_screen->gr_alv_variations->refresh( ).

     ELSE.
       p_error_saving_status = abap_true.
       gs_qmel-user_status_code = gv_user_status_code.

       MESSAGE i027(/noveco/evm).   "Error updating User Status.

       DATA: lv_msg_text TYPE string,
             lv_msg_id   TYPE  t100-arbgb,
             lv_msg_no   LIKE  t100-msgnr,
             lv_msg_var1 TYPE  balm-msgv1,
             lv_msg_var2 TYPE  balm-msgv2,
             lv_msg_var3 TYPE  balm-msgv3,
             lv_msg_var4 TYPE  balm-msgv4.

       lv_msg_id = ls_return-id.
       lv_msg_no = ls_return-number.
       lv_msg_var1 = ls_return-message_v1.
       lv_msg_var2 = ls_return-message_v2.
       lv_msg_var3 = ls_return-message_v3.
       lv_msg_var4 = ls_return-message_v4.

       CALL FUNCTION 'MESSAGE_PREPARE'
         EXPORTING
           language               = sy-langu
           msg_id                 = lv_msg_id
           msg_no                 = lv_msg_no
           msg_var1               = lv_msg_var1
           msg_var2               = lv_msg_var2
           msg_var3               = lv_msg_var3
           msg_var4               = lv_msg_var4
         IMPORTING
           msg_text               = lv_msg_text
         EXCEPTIONS
           function_not_completed = 1
           message_not_found      = 2
           OTHERS                 = 3.
       IF sy-subrc <> 0.

       ELSE.
         MESSAGE i000(/noveco/evm) WITH lv_msg_text.
       ENDIF.

       PERFORM set_current_variation.


     ENDIF.


   ENDIF.



