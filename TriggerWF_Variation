*&---------------------------------------------------------------------*
*&      Form  VALIDATE_KALKA_M
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_IR_DATA_CHANGED  text
*      -->P_LS_MOD_CELL  text
*----------------------------------------------------------------------*
 FORM validate_kalka_m  USING    ir_data_changed TYPE REF TO cl_alv_changed_data_protocol
                                 ls_mod_cell TYPE lvc_s_modi.

   DATA : lv_value    TYPE lvc_value,
          lv_sh_text  TYPE string,
          lv_acpos    TYPE acpos,
          lv_res_name TYPE /noveco/res_name,
          lv_kalka    TYPE /noveco/var_cost-kalka,
          lv_matkl    TYPE mara-matkl,
          ls_cost     LIKE LINE OF gcl_project->gt_var_costs_current.

   DATA: lv_werks TYPE werks_d.

   DATA: lv_msgv1 TYPE string,
         lv_msgv2 TYPE string.

*---- Get Material Number

   GET PARAMETER ID 'WRK' FIELD lv_werks.

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'RESOURCE'
     IMPORTING
       e_value     = lv_value.

   READ TABLE gcl_project->gt_var_costs_current INTO ls_cost INDEX ls_mod_cell-row_id.

   DATA: lv_matnr       TYPE matnr,
         lv_matnr_out   TYPE matnr,
         lv_matnr_input TYPE matnr.

   lv_matnr = lv_value.

   TRANSLATE: lv_matnr  TO UPPER CASE.

   CALL FUNCTION 'CONVERSION_EXIT_MATN1_OUTPUT'
     EXPORTING
       input  = lv_matnr
     IMPORTING
       output = lv_matnr_out.


   CALL FUNCTION 'CONVERSION_EXIT_MATN1_INPUT'
     EXPORTING
       input  = lv_matnr_out
     IMPORTING
       output = lv_matnr_input.

   IF sy-subrc <> 0.
* Implement suitable error handling here
   ENDIF.


*--------------------------------------------------------
   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'SH_TEXT'
     IMPORTING
       e_value     = lv_sh_text.

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'PLANT_ACTIVITY'
     IMPORTING
       e_value     = lv_value.

   IF lv_value IS NOT INITIAL.
     lv_werks = lv_value.

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'WERKS'
         i_value     = lv_werks.

   ELSE.

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'WERKS'
       IMPORTING
         e_value     = lv_value.

     IF lv_value IS NOT INITIAL.

       lv_werks = lv_value.

       CALL METHOD ir_data_changed->modify_cell
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'PLANT_ACTIVITY'
           i_value     = lv_werks.

     ELSEIF lv_werks IS NOT INITIAL.

       CALL METHOD ir_data_changed->modify_cell
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'PLANT_ACTIVITY'
           i_value     = lv_werks.

       CALL METHOD ir_data_changed->modify_cell
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'WERKS'
           i_value     = lv_werks.

     ENDIF.

   ENDIF.

   TRANSLATE: lv_werks  TO UPPER CASE.

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'MATKL'
     IMPORTING
       e_value     = lv_value.

   lv_matkl = lv_value.
   TRANSLATE: lv_matkl  TO UPPER CASE.

* check if material exists
   DATA: ls_mara TYPE mara.
   SELECT SINGLE * INTO ls_mara FROM mara WHERE matnr = lv_matnr_input.
   IF sy-subrc EQ 0.

*   Get Material Description
     DATA lv_maktx TYPE maktx.
     SELECT SINGLE maktx FROM makt INTO lv_maktx WHERE matnr EQ lv_matnr_input
                                            AND spras EQ sy-langu.

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'RESOURCE'
         i_value     = lv_matnr_out.

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'MATNR'
         i_value     = lv_matnr_input.

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'MEEHT'
         i_value     = ls_mara-meins.

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'MATKL'
         i_value     = ls_mara-matkl.

     IF lv_sh_text IS INITIAL OR ( lv_matnr_input NE ls_cost-matnr AND
                                   ls_cost-matnr IS NOT INITIAL ).
       CALL METHOD ir_data_changed->modify_cell
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'SH_TEXT'
           i_value     = lv_maktx.
     ENDIF.

   ELSEIF lv_matnr_input IS INITIAL AND ls_cost-matnr IS NOT INITIAL.

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'RESOURCE'
         i_value     = space.

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'MATNR'
         i_value     = space.

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'ACPOS'
         i_value     = space.

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'RES_NAME'
         i_value     = space.

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'MATKL'
         i_value     = space.

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'KSTAR'
         i_value     = space.

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'KTEXT'
         i_value     = space.

     EXIT.

   ELSEIF lv_matnr_input IS NOT INITIAL.

     lv_msgv1 = lv_matnr_out.

     CALL METHOD ir_data_changed->add_protocol_entry
       EXPORTING
         i_msgid     = 'M3'
         i_msgno     = '305'                 "Material does not exist
         i_msgty     = 'E'
         i_msgv1     = lv_msgv1
         i_msgv2     = ''
         i_msgv3     = ''
         i_fieldname = ls_mod_cell-fieldname
         i_row_id    = ls_mod_cell-row_id.

   ENDIF.


   IF lv_werks IS NOT INITIAL AND lv_matnr_input IS NOT INITIAL.

     SELECT COUNT(*) FROM marc
       WHERE matnr = lv_matnr_input
         AND werks = lv_werks.

     IF sy-subrc NE 0.

