*   Get Cost Element and Unit
   DATA: lv_kstar       TYPE /noveco/var_cost_alv-kstar,
         lv_kstar_ktext TYPE /noveco/evm_kstar_ktext,
         lv_meinh       TYPE meinh.

   IF lv_asnum IS NOT INITIAL AND lv_werks IS NOT INITIAL.

     CALL METHOD gcl_project->read_service_cost_elm
       EXPORTING
         i_asnum         = lv_asnum
         i_werks         = lv_werks
       IMPORTING
         e_kstar         = lv_kstar
         e_meinh         = lv_meinh
         e_kstar_ktext   = lv_kstar_ktext
       EXCEPTIONS
         invalid_service = 1
         OTHERS          = 2.

     IF sy-subrc NE 0.

       DATA: lv_msgv1 TYPE string,
             lv_msgv2 TYPE string.

       lv_msgv1 = lv_asnum.


       CALL METHOD ir_data_changed->add_protocol_entry
         EXPORTING
           i_msgid     = '/NOVECO/EVM'
           i_msgno     = '015'                 "Invalid Service Number.
           i_msgty     = 'E'
           i_msgv1     = lv_msgv1
           i_msgv3     = ''
           i_fieldname = ls_mod_cell-fieldname
           i_row_id    = ls_mod_cell-row_id.


       CALL METHOD ir_data_changed->display_protocol.

       EXIT.
     ELSE.

       CALL METHOD ir_data_changed->modify_cell
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'KSTAR'
           i_value     = lv_kstar.

       CALL METHOD ir_data_changed->modify_cell
         EXPORTING
