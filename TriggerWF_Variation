*&---------------------------------------------------------------------*
*&      Form  HANDLE_DATA_CHANGE_COSTS
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_ER_DATA_CHANGED  text
*      -->P_E_ONF4  text
*      -->P_E_ONF4_BEFORE  text
*      -->P_E_ONF4_AFTER  text
*      -->P_E_UCOMM  text
*----------------------------------------------------------------------*
 FORM handle_data_change_costs  USING    ir_data_changed TYPE REF TO cl_alv_changed_data_protocol
                                       p_e_onf4
                                       p_e_onf4_before
                                       p_e_onf4_after
                                       p_e_ucomm.


   DATA : lt_mod_cell TYPE lvc_t_modi,
          ls_mod_cell TYPE lvc_s_modi,
          lv_value    TYPE lvc_value,
          lv_kalka    TYPE /noveco/var_cost-kalka.

   lt_mod_cell[] = ir_data_changed->mt_mod_cells[].

*   Show Hide Fields depending on Costing Key
   PERFORM set_cost_alv_field_visibilty USING ir_data_changed.

* Handle entry of Resource, Plant/Activity, Work Centre and Plant for the different Costing Types
   SORT ir_data_changed->mt_mod_cells BY row_id .

   LOOP AT lt_mod_cell INTO ls_mod_cell
                          WHERE ( fieldname = 'RESOURCE' OR fieldname = 'PLANT_ACTIVITY'
                             OR fieldname = 'ARBPL' OR fieldname = 'WERKS'
                             OR fieldname = 'KSTAR' OR fieldname = 'ACPOS' OR fieldname = 'RES_NAME'  ).


     IF  ls_mod_cell-fieldname NE 'ACPOS' AND ls_mod_cell-fieldname NE 'RES_NAME' AND
         ls_mod_cell-fieldname NE 'KSTAR' AND ls_mod_cell-fieldname NE 'PLANT_ACTIVITY' AND
         ls_mod_cell-fieldname NE 'RESOURCE'.

       CHECK ls_mod_cell-value IS NOT INITIAL.
     ENDIF.

*   Get Costing Key
     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'KALKA'
       IMPORTING
         e_value     = lv_value.

     lv_kalka = lv_value.

     CASE lv_kalka.

       WHEN 'M'.


         PERFORM validate_kalka_m USING ir_data_changed
                                          ls_mod_cell.

       WHEN 'E'.

         PERFORM validate_kalka_e USING ir_data_changed
                                        ls_mod_cell.

       WHEN 'S'.

         PERFORM validate_kalka_s USING ir_data_changed
                                        ls_mod_cell.

       WHEN 'V'.

         PERFORM validate_kalka_v USING ir_data_changed
                                        ls_mod_cell.
       WHEN space OR '?'.

         CALL METHOD ir_data_changed->add_protocol_entry
           EXPORTING
             i_msgid     = '/NOVECO/ESTIMATING'
             i_msgno     = '122'                 " Enter Costing key
             i_msgty     = 'E'
             i_msgv1     = ''
             i_msgv2     = ''
             i_msgv3     = ''
             i_fieldname = 'KALKA'
             i_row_id    = ls_mod_cell-row_id.
     ENDCASE.  "KALKA


   ENDLOOP.

* Only WBS or Network can be chosen, not both
   PERFORM validate_costing_assignment USING lt_mod_cell
                                             ir_data_changed.

* Material Group must be valid for Material (if exists)
   PERFORM validate_material_group USING lt_mod_cell
                                         ir_data_changed.

* Cost Element Category must be appropriate for Costing Key V
   PERFORM validate_cost_element_v USING lt_mod_cell
                                         ir_data_changed.

* set total
   PERFORM validate_qty_and_price USING lt_mod_cell
                                        ir_data_changed.

* Add new empty cost line
   IF gv_change_mode IS NOT INITIAL.
     PERFORM add_empty_cost_item.
   ENDIF.

 ENDFORM.                    " HANDLE_DATA_CHANGE_COSTS
