*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
 FORM set_alv_0510 .

   DATA: ls_epm_proj TYPE /noveco/epm_proj.

   DATA: lt_index_rows TYPE lvc_t_row,
         ls_index_rows TYPE lvc_s_row,
         lt_row_no     TYPE lvc_t_roid,
         ls_row_no     TYPE lvc_s_roid.

   FIELD-SYMBOLS: <fs_proj_list> TYPE /noveco/wboplist.

*  Select Project List
   REFRESH gcl_screen->gt_open_proj_list.

   SELECT * FROM /noveco/wboplist INTO TABLE gcl_screen->gt_open_proj_list WHERE
                       user_id = sy-uname AND wbs_pspnr = '00000000'.

   LOOP AT gcl_screen->gt_open_proj_list ASSIGNING <fs_proj_list>.
     SELECT SINGLE * FROM /noveco/epm_proj  INTO ls_epm_proj WHERE pspnr = <fs_proj_list>-proj_pspnr.
     <fs_proj_list>-plan_period = ls_epm_proj-plan_period.
   ENDLOOP.

   SORT gcl_screen->gt_open_proj_list BY timestamp DESCENDING.

   IF gcl_screen->gr_open_grid IS INITIAL.

     gcl_screen->set_open_proj_alv( TEXT-t61 ).

     SET HANDLER gr_event_handler->handle_toolbar_proj_list FOR gcl_screen->gr_open_grid.
     SET HANDLER gr_event_handler->handle_user_command_proj_list FOR gcl_screen->gr_open_grid.
     SET HANDLER gr_event_handler->double_click_proj_list FOR gcl_screen->gr_open_grid.
     SET HANDLER gr_event_handler->hotspot_click_proj_list FOR gcl_screen->gr_open_grid.

     CALL METHOD gcl_screen->gr_open_grid->set_ready_for_input
       EXPORTING
         i_ready_for_input = 1.


     CALL METHOD gcl_screen->gr_open_grid->set_toolbar_interactive.

   ELSE.

     CALL METHOD gcl_screen->gr_open_grid->refresh_table_display.

   ENDIF.
 ENDFORM.                    " SET_ALV_0510
*&---------------------------------------------------------------------*
*&      Form  UPDATE_USER_PROJECT_LIST
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
 FORM update_user_project_list .

   DATA: ls_proj      TYPE proj,
         ls_prps      TYPE prps,
         lv_pspnr     TYPE ps_intnr,
         lv_timestamp TYPE timestampl,
         ls_tcj04     TYPE tcj04,
         ls_proj_list TYPE /noveco/wboplist.

   DATA: lt_open_proj_list  LIKE gcl_screen->gt_open_proj_list,
         ls_proj_list_check TYPE /noveco/wboplist,
         lv_lines           TYPE i.


* Project Definition

   CALL FUNCTION 'CONVERSION_EXIT_KONPD_INPUT'
     EXPORTING
       input     = p_pspid
     IMPORTING
       output    = lv_pspnr
     EXCEPTIONS
       not_found = 1
       OTHERS    = 2.

   SELECT SINGLE * INTO ls_proj FROM proj WHERE pspnr = lv_pspnr.

   CHECK sy-subrc EQ 0.

   ls_proj_list-mandt = sy-mandt.
   ls_proj_list-user_id = sy-uname.
   ls_proj_list-proj_pspnr = ls_proj-pspnr.
   ls_proj_list-proj_posid = ls_proj-pspid.
   ls_proj_list-proj_post1 = ls_proj-post1.
   ls_proj_list-icon       = '@EC@'. " Icon Project Definition
   ls_proj_list-type = 2. " Recent

   CONVERT DATE sy-datum TIME sy-uzeit INTO TIME STAMP lv_timestamp TIME ZONE sy-zonlo.
   ls_proj_list-timestamp = lv_timestamp.

* Check if there is more than 99 projects in the list
* Prevent from Recent list growing indefinitely.

   lt_open_proj_list = gcl_screen->gt_open_proj_list.
   DELETE lt_open_proj_list WHERE type = 1. "remove all favourtes
   DESCRIBE TABLE lt_open_proj_list LINES lv_lines .
   ADD 1 TO lv_lines.
   IF lv_lines > 99.
     SUBTRACT 1 FROM lv_lines.
     READ TABLE lt_open_proj_list INTO ls_proj_list_check INDEX lv_lines.

*   Remove
     DELETE FROM /noveco/wboplist WHERE user_id     = ls_proj_list_check-user_id    AND
                                        proj_pspnr  = ls_proj_list_check-proj_pspnr AND
                                        wbs_pspnr   = ls_proj_list_check-wbs_pspnr AND
                                        proj_pspnr_to    = ls_proj_list_check-proj_pspnr_to AND
                                        wbs_pspnr_to     = ls_proj_list_check-wbs_pspnr_to  AND
                                        vernr            = ls_proj_list_check-vernr      AND
                                        type             = ls_proj_list_check-type.
   ENDIF.

*--------------------------------------------------------------------------------

   MODIFY /noveco/wboplist FROM ls_proj_list.
   COMMIT WORK.

   CHECK gv_ui5_call IS INITIAL.

   DATA: lt_index_rows TYPE lvc_t_row,
         lt_row_no     TYPE lvc_t_roid.

   CALL METHOD gcl_screen->gr_open_grid->set_selected_rows
     EXPORTING
       it_index_rows = lt_index_rows
       it_row_no     = lt_row_no.


 ENDFORM.                    " UPDATE_USER_PROJECT_LIST
