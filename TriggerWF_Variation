     ENDIF.

   ENDIF.

*  Service Text
   CALL FUNCTION 'CONVERSION_EXIT_ALPHA_INPUT'
     EXPORTING
       input  = lv_asnum
     IMPORTING
       output = lv_asnum.

   SELECT SINGLE asktx FROM asmdt INTO lv_serv_text WHERE
                  asnum = lv_asnum AND spras = sy-langu.

