*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_LS_INDEX_ROWS  text
*----------------------------------------------------------------------*
 FORM select_rev_item_for_costing  USING    p_index_rows TYPE lvc_s_row.

   DATA ls_var_revenue LIKE LINE OF gcl_project->gt_var_revenue.

   IF gv_changes_made IS INITIAL.
     CLEAR gcl_project->rev_item.
   ENDIF.

   IF gcl_project->rev_item IS NOT INITIAL.

     PERFORM confirm_cost_item.

     CLEAR gcl_project->rev_item.

   ENDIF.


   READ TABLE gcl_project->gt_var_revenue INTO ls_var_revenue INDEX p_index_rows-index.
   IF sy-subrc = 0.

     gcl_project->rev_item = ls_var_revenue-rev_item.
*   open up costs ALV
     CALL METHOD gcl_screen->show_both_alvs( ).

     DATA: lt_index_rows TYPE lvc_t_row,
           lt_row_no     TYPE lvc_t_roid,
           lv_value      TYPE lvc_value.

     CALL METHOD gcl_screen->gr_alv_revenue->gr_alv->get_selected_rows
       IMPORTING
         et_index_rows = lt_index_rows
         et_row_no     = lt_row_no.

     CALL METHOD gcl_project->get_revenue_item_costs
       EXPORTING
         i_qmnum    = ls_var_revenue-qmnum
         i_rev_item = ls_var_revenue-rev_item
         i_call     = 'X'.

     gv_manage_rev_or_cost = 'C'. " manage cost items
     PERFORM set_alv_read_only_status.

     PERFORM set_costs_field_editability.

*   set grid title
     DATA: lv_grid_title TYPE lvc_title.
     IF ls_var_revenue-sh_text IS NOT INITIAL.
       CONCATENATE ls_var_revenue-sh_text ls_var_revenue-rev_item
         INTO lv_grid_title SEPARATED BY ' - '.
     ELSE.
       lv_grid_title = ls_var_revenue-rev_item.
     ENDIF.

* Add new empty cost line
     IF gv_change_mode IS NOT INITIAL.
       PERFORM add_empty_cost_item.
     ENDIF.

     gcl_screen->gr_alv_costs->set_title( lv_grid_title ).
     gcl_screen->gr_alv_costs->refresh( ).

     gcl_screen->gr_alv_revenue->set_read_only( 'X' ).
     gcl_screen->gr_alv_revenue->refresh( ).


   ENDIF.

 ENDFORM.                    " SELECT_REV_ITEM_FOR_COSTING

