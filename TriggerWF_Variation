*&---------------------------------------------------------------------*
*&      Form  HANDLE_USER_COMMAND_PROJ_LIST
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_E_UCOMM  text
*----------------------------------------------------------------------*
 FORM handle_user_command_proj_list  USING i_ucomm.

   CASE i_ucomm .

     WHEN 'ADD_TO_FAVOR'.

       PERFORM add_to_favor_list_proj.

     WHEN 'LIST_RECENT'.

       gv_open_proj_list_type = 2.

       CALL METHOD gcl_screen->gr_open_grid->set_gridtitle
         EXPORTING
           i_gridtitle = TEXT-t61.

       PERFORM set_filter_proj_list.

     WHEN 'LIST_FAVOR'.

       gv_open_proj_list_type = 1.

       CALL METHOD gcl_screen->gr_open_grid->set_gridtitle
         EXPORTING
           i_gridtitle = TEXT-t62.

       PERFORM set_filter_proj_list.

     WHEN 'DELETE_LINE'.

       PERFORM delete_from_list_proj.

   ENDCASE.

 ENDFORM.                    " HANDLE_USER_COMMAND_PROJ_LIST
