*&---------------------------------------------------------------------*
*&      Form  HANDLE_DOUBLE_CLICK_CLAIMS
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_E_ROW  text
*      -->P_E_COLUMN  text
*      -->P_ES_ROW_NO  text
*----------------------------------------------------------------------*
 FORM variation_selected USING i_row TYPE lvc_s_row
                                        i_column TYPE lvc_s_col
                                        is_row_no TYPE lvc_s_roid.

   DATA ls_qmel LIKE LINE OF gcl_project->gt_qmel.
   DATA lv_visible.

   IF gs_qmel-qmnum(1) = '$'AND gs_qmel-qmart IS INITIAL.
     EXIT.
   ENDIF.

   IF gv_changes_made = 'X'.

     DATA: lv_abort, lv_response.
     PERFORM prompt_for_save_changes CHANGING lv_abort
                                              lv_response.
     IF lv_abort = 'X'.
       RETURN.
     ENDIF.

   ENDIF.

   IF i_row-rowtype(1) NE 'S' AND i_row-rowtype(1) NE 'T'.  "not a sub-total row
     CLEAR: gv_revenue_upd_flg, gv_budget_upd_flg, gv_fcast_upd_flg.

     READ TABLE gcl_project->gt_qmel INTO ls_qmel INDEX i_row-index.
     IF sy-subrc = 0.

*     set dislay only
       gv_change_mode = space.

*     previous variation?
       IF gs_qmel-qmnum(1) NE '$'.
         PERFORM clear_tree_completely.
         gcl_project->unlock_claim( gs_qmel-qmnum ).
         gcl_project->unlock_sales_order( gs_qmel-vbeln ).
       ENDIF.

       CLEAR gs_qmel.
       MOVE-CORRESPONDING ls_qmel TO gs_qmel.

       REFRESH gt_text_lines.

*     set ALVs depending on Variation Update Type
       CALL METHOD gcl_screen->adjust_alv_visibility
         EXPORTING
           i_qmart       = gs_qmel-qmart
         CHANGING
           c_update_type = gs_qmel-update_type.

       IF gs_qmel-update_type = '1'. " Costs Only
         gv_manage_rev_or_cost = 'C'.
       ELSE.
         gv_manage_rev_or_cost = 'R'.
       ENDIF.

*      Initiall change mode
       gcl_screen->gr_alv_revenue->set_read_only( abap_true ).
       gcl_screen->gr_alv_costs->set_read_only( abap_true ).



       gcl_project->clear_current_rev_item( ).

       gcl_project->get_claim_header( CHANGING c_qmel = gs_qmel ).

       gcl_project->get_claim_revenue( gs_qmel-qmnum ).

       gcl_project->get_claim_costs( gs_qmel-qmnum ).

       gcl_project->read_claim_created_by( CHANGING i_qmel = gs_qmel ).

       gcl_screen->gr_alv_costs->set_title( 'Costing Items'(t59) ).

       gv_user_status_code = gs_qmel-user_status_code.

       PERFORM set_current_variation.

       PERFORM set_text.

*     update tree with revenue, costs and profit from this variations items
       PERFORM update_tree.

       PERFORM open_another_project USING p_pspid.

       lv_visible =  gcl_screen->gr_alv_revenue->is_visible( ).
       IF lv_visible = 'X'.
         gcl_screen->gr_alv_revenue->refresh( ).
       ENDIF.


       lv_visible =  gcl_screen->gr_alv_costs->is_visible( ).
       IF lv_visible = 'X'.
         gcl_screen->gr_alv_costs->refresh( ).
       ENDIF.

       CLEAR gv_changes_made.

       DATA: lv_update_type TYPE /noveco/var_update.

       SELECT SINGLE update_type FROM /noveco/epm_vtyp
         INTO lv_update_type
         WHERE qmart = gs_qmel-qmart.

       IF lv_update_type = '1'. " Costs only
         gv_manage_rev_or_cost = 'C'. " manage costs items
       ELSE.
         gv_manage_rev_or_cost = 'R'. " manage revenue items
       ENDIF.


     ENDIF.

     SET CURSOR FIELD 'GS_QMEL-QMART'.

     CALL SCREEN '0300'.


   ENDIF.

 ENDFORM.                    " HANDLE_DOUBLE_CLICK_CLAIMS

