             MESSAGE s031(/noveco/epm) DISPLAY LIKE 'E'.
           ELSE.
             MESSAGE s031(/noveco/epm) INTO gv_ui5_message.
             gv_ui5_message_type = 'E'.
           ENDIF.

           RETURN.
       ENDTRY.

       CALL METHOD ir_data_changed->get_cell_value
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'REV_PLAN'
         IMPORTING
           e_value     = lv_rev_plan.

     ENDIF.

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'COST'
       IMPORTING
         e_value     = lv_cost.

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'EXPECTED_PERCT'
       IMPORTING
         e_value     = lv_expected_perct.

     IF lv_expected_perct > 100.
       CALL METHOD ir_data_changed->add_protocol_entry
         EXPORTING
           i_msgid     = '/NOVECO/EVM'
           i_msgno     = '056'                 " cannot be greater than 100%
           i_msgty     = 'E'
           i_msgv1     = ''
           i_msgv3     = ''
           i_fieldname = ls_mod_cell-fieldname
           i_row_id    = ls_mod_cell-row_id.

       lv_expected_perct = <fs_var_rev>-expected_perct.

     ENDIF.

     CALL METHOD gcl_project->calculate_profit
       EXPORTING
         i_revenue = lv_rev_plan
         i_cost    = lv_cost
       IMPORTING
         e_profit  = lv_profit
         e_margin  = lv_margin.

     lv_expected_value = lv_rev_plan * lv_expected_perct / 100.

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'PROFIT'
         i_value     = lv_profit.

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'MARGIN'
         i_value     = lv_margin.

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'EXPECTED_REVEN'
         i_value     = lv_expected_value.


     PERFORM set_revenue_currencies USING ir_data_changed
                                          ls_mod_cell
                                          lv_rev_plan.

     IF ls_mod_cell-fieldname = 'EXPECTED_PERCT'.

       LOOP AT gcl_project->gt_var_revenue ASSIGNING <fs_var_rev>.
         <fs_var_rev>-expected_perct = lv_expected_perct.
         <fs_var_rev>-expected_reven  =  <fs_var_rev>-rev_plan * lv_expected_perct / 100.
       ENDLOOP.

     ENDIF.


   ENDLOOP.
   IF sy-subrc = 0.

* Sum Revenue into header
     CALL METHOD gcl_project->sum_revenue( CHANGING cs_qmel = gs_qmel ).

     PERFORM set_current_variation.


   ENDIF.

* Check if WBS field to be closed or opened
   LOOP AT lt_mod_cells INTO ls_mod_cell.

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'VBELN'
       IMPORTING
         e_value     = lv_vbeln.

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'POSNR'
       IMPORTING
         e_value     = lv_posnr.

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'NEW_ITEM'
       IMPORTING
         e_value     = lv_new_item.

     IF lv_vbeln IS NOT INITIAL AND lv_posnr IS NOT INITIAL AND
        lv_new_item IS INITIAL.
       CALL METHOD ir_data_changed->modify_style
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'PSPNR'
           i_style     = cl_gui_alv_grid=>mc_style_disabled.

     ELSE.
       CALL METHOD ir_data_changed->modify_style
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'PSPNR'
           i_style     = cl_gui_alv_grid=>mc_style_enabled.

     ENDIF.
   ENDLOOP.


* Check Material entereed
   LOOP AT lt_mod_cells  INTO ls_mod_cell
                        WHERE fieldname = 'MATNR' .

     PERFORM check_sales_material USING ir_data_changed
                                         ls_mod_cell.

   ENDLOOP.

 ENDFORM.                    " HANDLE_DATA_CHANGE_REV
