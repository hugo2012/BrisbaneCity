*&---------------------------------------------------------------------*
*&      Module  COMMAND_0300  INPUT
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
 MODULE command_0300 INPUT.

   DATA: user_selected TYPE sy-ucomm.

   DATA: cursorfield TYPE string.
   GET CURSOR FIELD cursorfield.
   IF cursorfield = 'GS_QMEL-QMNUM' AND sy-ucomm = 'CHAN' AND
          gs_qmel-qmnum(1) NE '$'.
     sy-ucomm = 'DISP_QMNUM'.
   ENDIF.

   CASE sy-ucomm.

*   Main Toolbar
     WHEN 'OPEN'.

       IF gv_changes_made = 'X'.

         DATA: lv_abort, lv_response.
         PERFORM prompt_for_save_changes CHANGING lv_abort
                                                  lv_response.

         IF lv_response = 'N' OR lv_response = 'J'. " User selected: "Do Not Save" or "Yes Save"

           CLEAR: gcl_project->gt_var_revenue, gcl_project->gt_var_costs, gcl_project->gt_var_costs_current.
           CALL METHOD gcl_screen->show_both_alvs( ).
           PERFORM set_no_variation.

*           call screen 0500 starting at 04 09
*                            ending at 65 11.

           CALL SCREEN 0510 STARTING AT 04 07
                         ENDING AT 110 30.

         ENDIF.

       ELSE.

*         call screen 0500 starting at 04 09
*                            ending at 65 11.

         CALL SCREEN 0510 STARTING AT 04 07
                         ENDING AT 110 25.


       ENDIF.


     WHEN 'CREA'.

       PERFORM create_variation.

     WHEN 'CHAN'.
       PERFORM change_variation USING space.

     WHEN 'COPY'.
       gv_template_list = space.
       gs_qmel-template = space.
       PERFORM handle_user_command_vars USING 'VAR_LIST'.
       PERFORM copy_variation.
       gcl_screen->gr_alv_variations->gr_alv->refresh_table_display( ).

     WHEN 'SAVE'.
       PERFORM save_variation.

     WHEN 'PROC'.
       PERFORM put_back_in_process.

     WHEN 'SAVE_AS_T'.
       gv_template_list = 'X'.
       gs_qmel-template = 'X'.
       PERFORM handle_user_command_vars USING 'TEMP_LIST'.
       PERFORM copy_variation.
       gcl_screen->gr_alv_variations->gr_alv->refresh_table_display( ).
       PERFORM clear_tree_completely.

*   top line
     WHEN 'QMART'.

       DATA: error TYPE char1.
       PERFORM authority_check CHANGING error.
       IF error = 'X'.
         RETURN.
       ENDIF.

       CALL METHOD gcl_screen->adjust_alv_visibility
         EXPORTING
           i_qmart       = gs_qmel-qmart
         CHANGING
           c_update_type = gs_qmel-update_type.

       IF gs_qmel-update_type = '1'. " Costs Only
         gv_manage_rev_or_cost = 'C'.
       ELSE.
         gv_manage_rev_or_cost = 'R'.
       ENDIF.

       PERFORM set_alv_read_only_status.

       IF gv_change_mode IS NOT INITIAL.
*     Add new empty revenue item
         PERFORM add_empty_revenue_item.

*     Add new empty cost line
         PERFORM add_empty_cost_item.
       ENDIF.

       gcl_screen->gr_alv_revenue->refresh( ).
       gcl_screen->gr_alv_costs->refresh( ).

     WHEN 'USTAT'.
       PERFORM set_initial_user_status.

     WHEN 'USTAT_CODE'.
       PERFORM change_user_status.

     WHEN 'TAB1'.
       gv_tab_screen_number = '0301'.
       gv_tabstrip-activetab = 'TAB1'.

     WHEN 'TAB2'.
       gv_tab_screen_number = '0302'.
       gv_tabstrip-activetab = 'TAB2'.


     WHEN 'EXIT' OR 'BACK'.

       user_selected = sy-ucomm.

       IF sy-tcode = '/NOVECO/EVM_CALL'.
         user_selected = 'EXIT'.
       ENDIF.

       CALL METHOD gcl_screen->save_screen_layout.

       IF gv_changes_made = 'X'.

         PERFORM prompt_for_save_changes CHANGING lv_abort
                                                  lv_response.

         IF lv_abort NE 'X'. "User Selected "Cancel" or "No"
           IF lv_response = 'A'. "Cancel pop-up message, user stays in Variation Screen
             LEAVE TO SCREEN '0300'.
           ELSEIF lv_response = 'N'. " user stays "No" to chages and exist Variation transaction.

             IF user_selected = 'EXIT'.
               LEAVE PROGRAM.

             ELSE. "User selected "BACK"

               CLEAR: gcl_project->gt_var_revenue, gcl_project->gt_var_costs, gcl_project->gt_var_costs_current.
               CALL METHOD gcl_screen->show_both_alvs( ).
               PERFORM set_no_variation.
               LEAVE TO SCREEN '0300'.
             ENDIF.
           ENDIF.

         ELSE. " User Selected "Yes" to Save Change and exists Variation transaction.
           IF user_selected = 'EXIT'.
             LEAVE PROGRAM.
           ELSE.
             CLEAR: gcl_project->gt_var_revenue, gcl_project->gt_var_costs, gcl_project->gt_var_costs_current.
             CALL METHOD gcl_screen->show_both_alvs( ).
             PERFORM set_no_variation.
             LEAVE TO SCREEN '0300'.
           ENDIF.
         ENDIF.

       ELSE.
         IF user_selected = 'EXIT'.
           LEAVE PROGRAM.
         ELSE.  "User selected "BACK"

           IF gs_qmel-qmnum IS NOT INITIAL.
             CLEAR: gcl_project->gt_var_revenue, gcl_project->gt_var_costs, gcl_project->gt_var_costs_current.
             CALL METHOD gcl_screen->show_both_alvs( ).

             PERFORM set_no_variation.
             LEAVE TO SCREEN '0300'.

           ELSE.
             LEAVE PROGRAM.
           ENDIF.
         ENDIF.
       ENDIF.

     WHEN 'DISP_QMNUM'.

       SET PARAMETER ID 'IQM' FIELD gs_qmel-qmnum.

       CALL FUNCTION 'AUTHORITY_CHECK_TCODE'
         EXPORTING
           tcode  = 'CLM3'
         EXCEPTIONS
           ok     = 1
           not_ok = 2
           OTHERS = 3.

       IF sy-subrc NE 1.
         MESSAGE e063(/noveco/epm) WITH 'CLM3'.
         RETURN.
       ENDIF.

       CALL TRANSACTION 'CLM3' AND SKIP FIRST SCREEN.

     WHEN 'CHANGE_QMNUM'.

       SET PARAMETER ID 'IQM' FIELD gs_qmel-qmnum.

       CALL FUNCTION 'AUTHORITY_CHECK_TCODE'
         EXPORTING
           tcode  = 'CLM2'
         EXCEPTIONS
           ok     = 1
           not_ok = 2
           OTHERS = 3.

       IF sy-subrc NE 1.
         MESSAGE e063(/noveco/epm) WITH 'CLM2'.
         RETURN.
       ENDIF.

       CALL TRANSACTION 'CLM2' AND SKIP FIRST SCREEN.

   ENDCASE.

   CLEAR sy-ucomm.


 ENDMODULE.                 " COMMAND_0300  INPUT
*&---------------------------------------------------------------------*
*&      Module  STATUS_0300  OUTPUT
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
 MODULE status_0300 OUTPUT.

   DATA exclude_fcode TYPE TABLE OF sy-ucomm.

   DATA l_epm_vupd TYPE /noveco/epm_vupd.

* Hide functions depending on the mode
   IF gv_project_open IS INITIAL.
     APPEND 'CREA' TO exclude_fcode.
     APPEND 'COPY' TO exclude_fcode.
     APPEND 'CHAN' TO exclude_fcode.
     APPEND 'PROC' TO exclude_fcode.
     APPEND 'SAVE_AS_T' TO exclude_fcode.
   ELSE.

     REFRESH exclude_fcode.

     IF gs_qmel-qmnum IS INITIAL OR gs_qmel-qmnum(1) EQ '$'.
       APPEND 'COPY' TO exclude_fcode.
       APPEND 'CHAN' TO exclude_fcode.
       APPEND 'PROC' TO exclude_fcode.
       APPEND 'SAVE_AS_T' TO exclude_fcode.
     ENDIF.

     SELECT SINGLE * FROM /noveco/epm_vupd INTO l_epm_vupd
       WHERE qmart = gs_qmel-qmart
         AND stsma = gs_qmel-stsma
         AND estat = gs_qmel-user_status.

     IF gs_qmel-status NE 'I0072' OR  " System Status is Not Completed yet
           l_epm_vupd-var_stat = c_rejected_stat. " or it was already rejected
       APPEND 'PROC' TO exclude_fcode.
     ENDIF.

   ENDIF.

   IF gv_change_mode NE 'X'.
     APPEND 'SAVE' TO exclude_fcode.
   ENDIF.


   SET PF-STATUS '0100' EXCLUDING exclude_fcode.

   DATA: titel_text TYPE string.

   IF gv_template_list IS INITIAL.
     titel_text = TEXT-t03.
   ELSE.
     CONCATENATE TEXT-t03 TEXT-t64 INTO titel_text SEPARATED BY space.
   ENDIF.

   IF gs_qmel-qmnum IS NOT INITIAL.
     IF gv_change_mode = 'X'.
       IF gs_qmel-qmnum(1) = '$'.
         SET TITLEBAR '100' WITH titel_text gs_qmel-qmnum 'Create'(t06).
       ELSE.
         SET TITLEBAR '100' WITH titel_text gs_qmel-qmnum 'Change'(t04).
       ENDIF.
     ELSE.
       SET TITLEBAR '100' WITH titel_text gs_qmel-qmnum 'Display'(t05).
     ENDIF.
   ELSE.
     SET TITLEBAR '100' WITH 'Project Variation Management Workbench'(t01).
   ENDIF.

   LOOP AT SCREEN.

*   set fields display only in Display Mode
     IF screen-group1 = 'DIS'.
       IF gv_change_mode NE 'X'.
         screen-input = 0.
       ELSE.
         screen-input = 1.
       ENDIF.
       MODIFY SCREEN.
     ENDIF.

*   Set Mandatory fields required in Change Mode
     IF screen-group2 = 'MAN'.
       IF gv_change_mode EQ 'X' AND gs_qmel-qmnum(1) EQ '$'.
         screen-input = 1.
         screen-required = 1.
       ELSE.
         screen-input = 0.
         screen-required = 0.
       ENDIF.
       MODIFY SCREEN.
     ENDIF.

*   Set Mandatory field depending on other field
     IF screen-group2 = 'M1'.
       IF gv_change_mode EQ 'X'.
         IF gs_qmel-qmart IS NOT INITIAL.
           screen-required = 1.
         ELSE.
           screen-required = 0.
         ENDIF.
       ELSE.
         screen-required = 0.
       ENDIF.
       MODIFY SCREEN.
     ENDIF.

*  User Status Read only until variation saved
     IF screen-name = 'GS_QMEL-USER_STATUS_CODE'.
       IF gs_qmel-qmnum IS NOT INITIAL.
         IF gs_qmel-qmnum(1) = '$'.
           screen-input = 0.
         ELSE.
           IF gv_change_mode EQ 'X'.
             screen-input = 1.
           ELSE.
             screen-input = 0.
           ENDIF.
         ENDIF.
       ELSE.
         screen-input = 0.
       ENDIF.
       MODIFY SCREEN.
     ENDIF.

     IF screen-name = 'VIEW_CLAIM'.
       IF gs_qmel-qmnum(1) = '$' OR gs_qmel-qmnum IS INITIAL.
         screen-input = 0.
       ENDIF.
       MODIFY SCREEN.
     ENDIF.

     IF screen-name = 'CHANGE_CLAIM'.
       IF gs_qmel-qmnum(1) = '$' OR
          gs_qmel-qmnum IS INITIAL OR gs_qmel-status EQ 'I0072'.
         screen-input = 0.
       ENDIF.
       MODIFY SCREEN.
     ENDIF.

     IF screen-name = 'GS_QMEL-QMART'.
       IF gs_qmel-qmart IS INITIAL AND gv_change_mode EQ 'X'.
         screen-input = 1.
       ELSE.
         screen-input = 0.
       ENDIF.
       MODIFY SCREEN.
     ENDIF.

   ENDLOOP.




   IF gs_qmel-qmart IS INITIAL.
     SET CURSOR FIELD 'GS_QMEL-QMART'.
   ENDIF.

 ENDMODULE.                 " STATUS_0300  OUTPUT
*&---------------------------------------------------------------------*
*&      Form  CREATE_VARIATION
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
 FORM create_variation .

* check for changes
   IF gv_changes_made = 'X'.

     DATA: lv_abort, lv_response.
     PERFORM prompt_for_save_changes
                 CHANGING
                    lv_abort
                    lv_response.
     IF lv_abort EQ 'X'.
       RETURN.
     ENDIF.

   ENDIF.

   CALL METHOD gcl_screen->show_both_alvs( ).

   CALL METHOD gcl_project->create_variation
     IMPORTING
       e_qmel = gs_qmel.

   gv_change_mode = 'X'.
   gv_changes_made = 'X'.

   CLEAR: gv_budget_upd_flg, gv_fcast_upd_flg, gv_revenue_upd_flg.

   CALL METHOD gcl_screen->adjust_alv_visibility
     EXPORTING
       i_qmart       = gs_qmel-qmart
     CHANGING
       c_update_type = gs_qmel-update_type.

   IF gs_qmel-update_type = '1'. " Costs only
     gv_manage_rev_or_cost = 'C'. " manage costs items
   ELSE.
     gv_manage_rev_or_cost = 'R'. " manage revenue items
   ENDIF.

   PERFORM set_alv_read_only_status.

   PERFORM set_current_variation.

   REFRESH gt_text_lines.

   gcl_screen->gr_alv_revenue->refresh( ).
   gcl_screen->gr_alv_costs->refresh( ).

   PERFORM clear_tree_completely.

   CALL METHOD /noveco/est_gos_manager=>gos_toolbar.

 ENDFORM.                    " CREATE_VARIATION
*&---------------------------------------------------------------------*
*&      Form  SAVE_VARIATION
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
 FORM save_variation .

   CHECK gs_qmel-qmart IS NOT INITIAL.
   CHECK gs_qmel-qmtxt IS NOT INITIAL.

   DATA lv_qmnum TYPE qmnum.
   DATA lv_error_saving_status TYPE xfeld.
   DATA ls_return TYPE bapireturn.

   IF gv_change_mode IS NOT INITIAL.
     CALL METHOD gcl_project->remove_empty_revenue_item.
     CALL METHOD gcl_project->remove_empty_cost_item.
   ENDIF.

* Validate Revenue Items
   CALL METHOD gcl_project->validate_revenue_items
     CHANGING
       is_qmel                   = gs_qmel
     EXCEPTIONS
       sales_order_item_required = 1
       wbs_required              = 2
       OTHERS                    = 3.
   IF sy-subrc <> 0.
     CASE sy-subrc.

       WHEN 1.
         MESSAGE i043(/noveco/evm).  "Revenue Item must have Sales Order Item if Sales Order specified.
       WHEN 2.
         MESSAGE i044(/noveco/evm).  "Revenue Item must be assigned to WBS Element.

     ENDCASE.
     EXIT.
   ENDIF.

   CALL METHOD gcl_project->validate_cost_items
     EXPORTING
       i_rev_item     = gcl_project->rev_item
     CHANGING
       is_qmel        = gs_qmel
     EXCEPTIONS
       costs_not_zero = 1 " adjustmenbt
       costs_negative = 2 " contingency
       OTHERS         = 3.
   IF sy-subrc <> 0.
     CASE sy-subrc.
       WHEN 1.
         MESSAGE i033(/noveco/evm). "Costs must total 0 for Adjustment
       WHEN 2.
         MESSAGE i057(/noveco/evm). "Contingency Cost Balance must not be negative
       WHEN OTHERS.
     ENDCASE.
     EXIT.
   ENDIF.

   IF gcl_project->rev_item IS NOT INITIAL.

     CALL METHOD gcl_project->confirm_cost_items
       EXPORTING
         i_qmnum           = gs_qmel-qmnum
         i_rev_item        = gcl_project->rev_item
       EXCEPTIONS
         no_wbs_or_network = 1
         no_cost_element   = 2
         no_costing_key    = 3
         OTHERS            = 4.

     IF sy-subrc NE 0 AND gs_qmel-template = space.

       CASE sy-subrc .

         WHEN '1'.
           MESSAGE i031(/noveco/evm). "Costing Items must be assigned either WBS or Network.

         WHEN '2'.
           MESSAGE i040(/noveco/evm). "All Costing Items must be assigned to a Cost Element.

         WHEN '3'.
           MESSAGE i042(/noveco/evm). "All Costing Items must have a Costing Key.


       ENDCASE.

       EXIT.
     ENDIF.

   ELSE.
*   Is this a Costs Only Variation?
     DATA: lv_update_type TYPE /noveco/var_update.
     CLEAR lv_update_type.

     IF gs_qmel-qmart IS NOT INITIAL.

       lv_update_type = gcl_project->get_update_type( gs_qmel-qmart ).

       IF sy-subrc = 0 AND lv_update_type = '1'.


         CALL METHOD gcl_project->confirm_cost_items_no_revenue
           EXPORTING
             i_qmnum           = gs_qmel-qmnum
           EXCEPTIONS
             no_wbs_or_network = 1
             no_cost_element   = 2
             no_costing_key    = 3
             OTHERS            = 4.

         IF sy-subrc <> 0 AND gs_qmel-template = space.
           CASE sy-subrc .

             WHEN '1'.
               MESSAGE i031(/noveco/evm). "Costing Items must be assigned either WBS or Network.

             WHEN '2'.
               MESSAGE i040(/noveco/evm). "All Costing Items must be assigned to a Cost Element.

             WHEN '3'.
               MESSAGE i042(/noveco/evm). "All Costing Items must have a Costing Key.


           ENDCASE.

           EXIT.
         ENDIF.

       ENDIF.

     ENDIF.

   ENDIF.



   IF gs_qmel-qmnum(1) = '$'.

     CALL METHOD gcl_project->save_variation
       IMPORTING
         e_qmnum              = lv_qmnum
         e_return             = ls_return
       CHANGING
         c_qmel               = gs_qmel
       EXCEPTIONS
         error_saving_revenue = 1
         error_saving_costs   = 2
         error_changing_claim = 3
         OTHERS               = 4.
     .

     IF sy-subrc NE 0.
       CLEAR sy-ucomm.

       CASE sy-subrc.
         WHEN 1.
           MESSAGE e006(/noveco/evm).   "Error saving Revenue Items
         WHEN 2.
           MESSAGE e016(/noveco/evm).   "Error saving Cost Items
         WHEN 3.
           MESSAGE e047(/noveco/evm).   "Error changing Claim
       ENDCASE.

     ENDIF.

     IF ls_return-type = 'E'.

       MESSAGE ID ls_return-code(2) TYPE 'I'
               NUMBER ls_return-code+2(3)
               WITH ls_return-message_v1 ls_return-message_v2
                    ls_return-message_v3 ls_return-message_v4.


     ELSE.

       PERFORM update_status CHANGING lv_error_saving_status.

       IF lv_error_saving_status EQ abap_false.

         PERFORM update_costing.


         gs_qmel-qmnum = lv_qmnum.
         PERFORM set_current_variation.

         MESSAGE s001(/noveco/evm) WITH gs_qmel-qmnum.   "Variation Created


*     refresh list of variations
         gcl_screen->gr_alv_variations->refresh( ).

         CLEAR gv_changes_made.
       ELSE.
         PERFORM change_user_status.
         RETURN.
       ENDIF.

     ENDIF.
   ELSE.

*   Existing
*  change mode

     CALL METHOD gcl_project->save_variation
       IMPORTING
         e_qmnum              = lv_qmnum
         e_return             = ls_return
       CHANGING
         c_qmel               = gs_qmel
       EXCEPTIONS
         error_saving_revenue = 1
         error_saving_costs   = 2
         error_changing_claim = 3
         OTHERS               = 4.
     .

     IF sy-subrc NE 0.
       CLEAR sy-ucomm.
       CASE sy-subrc.
         WHEN 1.
           MESSAGE e006(/noveco/evm).   "Error saving Revenue Items
         WHEN 2.
           MESSAGE e016(/noveco/evm).   "Error saving Cost Items
         WHEN 3.
           MESSAGE e047(/noveco/evm).   "Error changing Claim
       ENDCASE.

       IF ls_return-type = 'E'.

         MESSAGE ID ls_return-code(2) TYPE 'I'
                 NUMBER ls_return-code+2(3)
                 WITH ls_return-message_v1 ls_return-message_v2
                      ls_return-message_v3 ls_return-message_v4.
         RETURN.
       ENDIF.

     ELSE.

       MESSAGE s007(/noveco/evm) WITH gs_qmel-qmnum.   "Variation Changed

       PERFORM update_status CHANGING lv_error_saving_status.

       IF lv_error_saving_status EQ abap_false.

         PERFORM update_costing.

         PERFORM update_texts.

*     is status Pending? PD

         DATA ls_epm_vupd TYPE /noveco/epm_vupd.
*     is it an non-approved status via /NOVECO/EPM_VUPD?
         SELECT SINGLE * FROM /noveco/epm_vupd INTO ls_epm_vupd
           WHERE qmart = gs_qmel-qmart
             AND stsma = gs_qmel-stsma
             AND estat = gs_qmel-user_status
             AND var_stat = '01'.
         IF sy-subrc = 0.

           PERFORM variation_update
                      USING  gv_budget_upd_flg
                             gv_revenue_upd_flg
                             gv_fcast_upd_flg.

*       Read Variation Status (in case it was completed)
           gcl_project->get_claim_header( CHANGING c_qmel = gs_qmel ).

         ENDIF.

         CLEAR gv_changes_made.
       ELSE.
         PERFORM change_user_status.
         RETURN.
       ENDIF.
     ENDIF.

   ENDIF.
