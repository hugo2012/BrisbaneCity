     EXPORTING
       p_kokrs      = gcl_database->ml_config-kokrs
       p_kstar      = lv_kstar
       p_acpos      = lv_acpos
       p_werks      = lv_werks
       p_bukrs      = gcl_database->ml_config-bukrs
       p_parob      = space
       ptb_resource = ltb_resource
     RECEIVING
       p_res_name   = lv_res_name.

   CALL METHOD ir_data_changed->modify_cell
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'RES_NAME'
       i_value     = lv_res_name.

 ENDFORM.                    " VALIDATE_KALKA_S
*&---------------------------------------------------------------------*
*&      Form  VALIDATE_MATERIAL_GROUP
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_IR_DATA_CHANGED  text
*----------------------------------------------------------------------*
 FORM validate_material_group  USING  lt_mod_cell TYPE lvc_t_modi
                                      ir_data_changed TYPE REF TO cl_alv_changed_data_protocol.


   DATA : ls_mod_cell TYPE lvc_s_modi,
          lv_value    TYPE lvc_value.

   LOOP AT lt_mod_cell INTO ls_mod_cell
                         WHERE  fieldname = 'MATKL' .

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'MATNR'
       IMPORTING
         e_value     = lv_value.

     DATA lv_matnr TYPE matnr.
     lv_matnr = lv_value.

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'MATKL'
       IMPORTING
         e_value     = lv_value.

     DATA lv_matkl TYPE mara-matkl.
     lv_matkl = lv_value.

     IF lv_matkl IS NOT INITIAL AND lv_matnr IS NOT INITIAL.


       SELECT COUNT(*) FROM mara
           WHERE matnr = lv_matnr
            AND matkl = lv_matkl.

       IF sy-subrc NE 0.

         DATA: lv_msgv1 TYPE string,
               lv_msgv2 TYPE string.

         lv_msgv1 = lv_matnr.
         lv_msgv2 = lv_matkl.

         CALL METHOD ir_data_changed->add_protocol_entry
           EXPORTING
             i_msgid     = '/NOVECO/EVM'
             i_msgno     = '011'                 "Material and Material Group Combination invalid.
             i_msgty     = 'E'
             i_msgv1     = lv_msgv1
             i_msgv2     = lv_msgv2
             i_msgv3     = ''
             i_fieldname = ls_mod_cell-fieldname
             i_row_id    = ls_mod_cell-row_id.

         CALL METHOD ir_data_changed->display_protocol.

         EXIT.

       ENDIF.


     ELSE.
*     If Material Group and Plant only, determine Cost Element from Material Group
       IF lv_matkl IS NOT INITIAL AND lv_matnr IS INITIAL.

         CALL METHOD ir_data_changed->get_cell_value
           EXPORTING
             i_row_id    = ls_mod_cell-row_id
             i_fieldname = 'WERKS'
           IMPORTING
             e_value     = lv_value.

         DATA lv_werks TYPE werks_d.
         lv_werks = lv_value.
         IF lv_werks IS NOT INITIAL.

           DATA lv_kstar TYPE kstar.

           CALL METHOD gcl_project->read_material_group_cost_elm
             EXPORTING
               i_matkl = lv_matkl
               i_werks = lv_werks
             IMPORTING
               e_kstar = lv_kstar.

           CALL METHOD ir_data_changed->modify_cell
             EXPORTING
               i_row_id    = ls_mod_cell-row_id
               i_fieldname = 'KSTAR'
               i_value     = lv_kstar.

         ENDIF.


       ENDIF.


     ENDIF.
   ENDLOOP.
 ENDFORM.                    " VALIDATE_MATERIAL_GROUP
*&---------------------------------------------------------------------*
*&      Form  VALIDATE_QTY_AND_PRICE
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_IR_DATA_CHANGED  text
*----------------------------------------------------------------------*
 FORM validate_qty_and_price  USING  lt_mod_cells TYPE lvc_t_modi
                                     ir_data_changed TYPE REF TO cl_alv_changed_data_protocol.


   DATA : ls_mod_cell  TYPE lvc_s_modi,
          lv_cost_plan TYPE wogxxx,
          ls_costs     LIKE LINE OF gcl_project->gt_var_costs.

   DATA: lv_perct TYPE /noveco/percent,
         lv_value TYPE wogxxx.

   DATA: lv_msgv1 TYPE string,
         lv_msgv2 TYPE string.


   LOOP AT lt_mod_cells INTO ls_mod_cell
                             WHERE  ( fieldname = 'PREIS'
                                 OR fieldname = 'PREIS_TCURR'
                                 OR fieldname = 'TWAER'
                                 OR fieldname = 'PEINH'
                                 OR fieldname = 'MENGE' ).


     PERFORM update_cost_total_price USING ir_data_changed
                                           ls_mod_cell.


   ENDLOOP.

* Handle Risk Values
   FIELD-SYMBOLS: <fs_var_cost> LIKE LINE OF gcl_project->gt_var_costs.

   LOOP AT lt_mod_cells  INTO ls_mod_cell
                       WHERE fieldname = 'FCAST_EXPECTED_PERCT' OR
                             fieldname =  'BUDGET_EXPECTED_PERCT'.

     READ TABLE  gcl_project->gt_var_costs INTO ls_costs INDEX ls_mod_cell-row_id.

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'WOG'
       IMPORTING
         e_value     = lv_cost_plan.

     IF ls_mod_cell-fieldname = 'FCAST_EXPECTED_PERCT'.
       CALL METHOD ir_data_changed->get_cell_value
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'FCAST_EXPECTED_PERCT'
         IMPORTING
           e_value     = lv_perct.

       IF lv_perct > '100.00'.
         CALL METHOD ir_data_changed->add_protocol_entry
           EXPORTING
             i_msgid     = '/NOVECO/EVM'
             i_msgno     = '056'                 " cannot be greater than 100%
             i_msgty     = 'E'
             i_msgv1     = ''
             i_msgv3     = ''
             i_fieldname = ls_mod_cell-fieldname
             i_row_id    = ls_mod_cell-row_id.

         lv_perct = ls_costs-fcast_expected_perct.

       ENDIF.

       lv_value = lv_cost_plan * lv_perct / 100.

       CALL METHOD ir_data_changed->modify_cell
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'FCAST_EXPECTED_VALUE'
           i_value     = lv_value.

       LOOP AT gcl_project->gt_var_costs ASSIGNING <fs_var_costs>.
         <fs_var_costs>-fcast_expected_perct = lv_perct.
         <fs_var_costs>-fcast_expected_value  =  <fs_var_costs>-wog * lv_perct / 100.
       ENDLOOP.

       LOOP AT gcl_project->gt_var_costs_current ASSIGNING <fs_var_costs>.
         <fs_var_costs>-fcast_expected_perct = lv_perct.
         <fs_var_costs>-fcast_expected_value  =  <fs_var_costs>-wog * lv_perct / 100.
       ENDLOOP.

     ELSE.

       CALL METHOD ir_data_changed->get_cell_value
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'BUDGET_EXPECTED_PERCT'
         IMPORTING
           e_value     = lv_perct.

       IF lv_perct > '100.00'.
         CALL METHOD ir_data_changed->add_protocol_entry
           EXPORTING
             i_msgid     = '/NOVECO/EVM'
             i_msgno     = '056'                 " cannot be greater than 100%
             i_msgty     = 'E'
             i_msgv1     = ''
             i_msgv3     = ''
             i_fieldname = ls_mod_cell-fieldname
             i_row_id    = ls_mod_cell-row_id.

         lv_perct = ls_costs-budget_expected_perct.

       ENDIF.

       lv_value = lv_cost_plan * lv_perct / 100.

       CALL METHOD ir_data_changed->modify_cell
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'BUDGET_EXPECTED_VALUE'
           i_value     = lv_value.

       LOOP AT gcl_project->gt_var_costs ASSIGNING <fs_var_costs>.
         <fs_var_costs>-budget_expected_perct = lv_perct.
         <fs_var_costs>-budget_expected_value  =  <fs_var_costs>-wog * lv_perct / 100.
       ENDLOOP.

       LOOP AT gcl_project->gt_var_costs_current ASSIGNING <fs_var_costs>.
         <fs_var_costs>-budget_expected_perct = lv_perct.
         <fs_var_costs>-budget_expected_value  =  <fs_var_costs>-wog * lv_perct / 100.
       ENDLOOP.
     ENDIF.

   ENDLOOP.

 ENDFORM.                    " VALIDATE_QTY_AND_PRICE
*&---------------------------------------------------------------------*
*&      Form  SET_TOTAL_PRICE_COST
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_LV_MENGE  text
*      -->P_LV_MEINS  text
*      -->P_LV_PEINH  text
*      -->P_IR_DATA_CHANGED  text
*----------------------------------------------------------------------*
 FORM set_total_price_cost  USING    p_menge TYPE menge_d
                                     p_preis TYPE preis
                                     p_preis_tcurr TYPE preis
                                     p_peinh TYPE peinh
                                     ir_data_changed TYPE REF TO cl_alv_changed_data_protocol
                                     p_row_id.

   DATA: lv_total TYPE wtgxxx.

   DATA: lv_expected_perct TYPE /noveco/percent,
         lv_expected_value TYPE wogxxx.

   CALL METHOD gcl_project->calculate_total_price
     EXPORTING
       i_menge = p_menge
       i_preis = p_preis_tcurr
       i_peinh = p_peinh
     IMPORTING
       e_total = lv_total.

   CALL METHOD ir_data_changed->modify_cell
     EXPORTING
       i_row_id    = p_row_id
       i_fieldname = 'WTG'
       i_value     = lv_total.

* convert to Project currency
   DATA: lv_twaer TYPE twaer.

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = p_row_id
       i_fieldname = 'TWAER'
     IMPORTING
       e_value     = lv_twaer.

   DATA: lv_owaer TYPE owaer.
   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = p_row_id
       i_fieldname = 'OWAER'
     IMPORTING
       e_value     = lv_owaer.


   DATA: lv_amount_in_project_currency TYPE wogxxx.

*  call method gcl_project->convert_to_currency
*    exporting
*      i_date          = gs_qmel-erdat
*      i_from_amount   = lv_total
*      i_from_currency = lv_twaer
*      i_to_currency   = lv_owaer
*    importing
*      e_to_amount     = lv_amount_in_project_currency.

   CALL METHOD gcl_project->calculate_total_price
     EXPORTING
       i_menge = p_menge
       i_preis = p_preis
       i_peinh = p_peinh
     IMPORTING
       e_total = lv_amount_in_project_currency.

   CALL METHOD ir_data_changed->modify_cell
     EXPORTING
       i_row_id    = p_row_id
       i_fieldname = 'WOG'
       i_value     = lv_amount_in_project_currency.

* Set Forecast Costs Expected Value
   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = p_row_id
       i_fieldname = 'FCAST_EXPECTED_PERCT'
     IMPORTING
       e_value     = lv_expected_perct.

   lv_expected_value = lv_amount_in_project_currency * lv_expected_perct / 100.

   CALL METHOD ir_data_changed->modify_cell
     EXPORTING
       i_row_id    = p_row_id
       i_fieldname = 'FCAST_EXPECTED_VALUE'
       i_value     = lv_expected_value.

* Set Budget Costs Expected Value
   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = p_row_id
       i_fieldname = 'BUDGET_EXPECTED_PERCT'
     IMPORTING
       e_value     = lv_expected_perct.

   lv_expected_value = lv_amount_in_project_currency * lv_expected_perct / 100.

   CALL METHOD ir_data_changed->modify_cell
     EXPORTING
       i_row_id    = p_row_id
       i_fieldname = 'BUDGET_EXPECTED_VALUE'
       i_value     = lv_expected_value.


*  Convert controlling area currency value
   DATA: lv_kwaer                    TYPE kwaer,
         lv_amount_in_kokrs_currency TYPE wkgxxx.

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = p_row_id
       i_fieldname = 'KWAER'
     IMPORTING
       e_value     = lv_kwaer.

   CALL METHOD gcl_project->convert_to_currency
     EXPORTING
       i_date          = gs_qmel-erdat
       i_from_amount   = lv_amount_in_project_currency
       i_from_currency = lv_owaer
       i_to_currency   = lv_kwaer
       i_type_of_rate  = gs_qmel-kurst
     IMPORTING
       e_to_amount     = lv_amount_in_kokrs_currency.

   CALL METHOD ir_data_changed->modify_cell
     EXPORTING
       i_row_id    = p_row_id
       i_fieldname = 'WKG'
       i_value     = lv_amount_in_kokrs_currency.


 ENDFORM.                    " SET_TOTAL_PRICE_COST

*&---------------------------------------------------------------------*
*&      Form  UPDATE_COST_TOTAL_PRICE
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_IR_DATA_CHANGED  text
*----------------------------------------------------------------------*
 FORM update_cost_total_price  USING ir_data_changed TYPE REF TO cl_alv_changed_data_protocol
                                     ls_mod_cell TYPE lvc_s_modi.

   DATA : lv_value       TYPE lvc_value,
          lv_row_id      TYPE i,
          lv_preis       TYPE preis,
          lv_preis_tcurr TYPE preis,
          lv_peinh       TYPE peinh,
          lv_waers       TYPE waers,
          lv_twaer       TYPE waers,
          lv_menge       TYPE menge_d.

   lv_row_id = ls_mod_cell-row_id.

* Get Object Currency
   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = lv_row_id
       i_fieldname = 'PREIS'
     IMPORTING
       e_value     = lv_value.

* Catch Conversion overflow
   TRY.
       lv_preis = lv_value.
     CATCH cx_sy_conversion_overflow.
       lv_preis = 0.

       CALL METHOD ir_data_changed->modify_cell
         EXPORTING
           i_row_id    = lv_row_id
           i_fieldname = 'PREIS'
           i_value     = space.
       MESSAGE s055(/noveco/evm) DISPLAY LIKE 'E'.
       EXIT.
   ENDTRY.

* Get Transactional Currency
   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = lv_row_id
       i_fieldname = 'PREIS_TCURR'
     IMPORTING
       e_value     = lv_value.

* Catch arithmetic overflow
   TRY.
       lv_preis_tcurr = lv_value.
     CATCH cx_sy_arithmetic_overflow.
       lv_preis = 0.
       CALL METHOD ir_data_changed->modify_cell
         EXPORTING
           i_row_id    = lv_row_id
           i_fieldname = 'PREIS_TCURR'
           i_value     = space.

       MESSAGE s055(/noveco/evm) DISPLAY LIKE 'E'.
       EXIT.
   ENDTRY.

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = lv_row_id
       i_fieldname = 'OWAER'
     IMPORTING
       e_value     = lv_value.

   lv_waers = lv_value.

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = lv_row_id
       i_fieldname = 'TWAER'
     IMPORTING
       e_value     = lv_value.

   lv_twaer = lv_value.

   IF ls_mod_cell-fieldname EQ 'PREIS_TCURR'." or ls_mod_cell-fieldname eq 'TWAER'.

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = lv_row_id
         i_fieldname = 'OWAER'
       IMPORTING
         e_value     = lv_value.

     lv_waers = lv_value.

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = lv_row_id
         i_fieldname = 'TWAER'
       IMPORTING
         e_value     = lv_value.

     lv_twaer = lv_value.

*     convert Transaction To Object currency
     PERFORM convert_price_currency USING lv_twaer " from
                                          lv_waers " to
                                          lv_preis_tcurr " from
                                 CHANGING lv_preis. "to

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = lv_row_id
         i_fieldname = 'PREIS'
         i_value     = lv_preis.

   ELSE.
*     convert Object Curr To Transaction Currency
     PERFORM convert_price_currency USING lv_waers "from
                                          lv_twaer " to
                                          lv_preis " from
                                 CHANGING lv_preis_tcurr. " to

     CALL METHOD ir_data_changed->modify_cell
       EXPORTING
         i_row_id    = lv_row_id
         i_fieldname = 'PREIS_TCURR'
         i_value     = lv_preis_tcurr.

   ENDIF.

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = lv_row_id
       i_fieldname = 'PEINH'
     IMPORTING
       e_value     = lv_value.

   lv_peinh = lv_value.

   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = lv_row_id
       i_fieldname = 'MENGE'
     IMPORTING
       e_value     = lv_value.


* Catch Conversion overflow
   TRY.
       lv_menge = lv_value.
     CATCH cx_sy_conversion_overflow.
       lv_menge = 0.
       CALL METHOD ir_data_changed->modify_cell
         EXPORTING
           i_row_id    = lv_row_id
           i_fieldname = 'MENGE'
           i_value     = space.
       MESSAGE s055(/noveco/evm) DISPLAY LIKE 'E'.
       EXIT.
   ENDTRY.

* Catch arithmetic overflow
   TRY.
       lv_menge = lv_value.
     CATCH cx_sy_arithmetic_overflow.
       lv_menge = 0.
       CALL METHOD ir_data_changed->modify_cell
         EXPORTING
           i_row_id    = lv_row_id
           i_fieldname = 'MENGE'
           i_value     = space.
       MESSAGE s055(/noveco/evm) DISPLAY LIKE 'E'.
       EXIT.
   ENDTRY.


   PERFORM set_total_price_cost USING lv_menge
                                      lv_preis
                                      lv_preis_tcurr
                                      lv_peinh
                                      ir_data_changed
                                      lv_row_id.


 ENDFORM.                    " UPDATE_COST_TOTAL_PRICE
*&---------------------------------------------------------------------*
*&      Form  CONFIRM_COST_ITEM
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
 FORM confirm_cost_item .

   DATA lv_update_type TYPE  /noveco/epm_vtyp-update_type.

   lv_update_type = gcl_project->get_update_type( gs_qmel-qmart ).

   IF gv_change_mode IS NOT INITIAL.
     CALL METHOD gcl_project->remove_empty_cost_item.
     CALL METHOD gcl_project->remove_empty_revenue_item.
   ENDIF.

   IF lv_update_type NE '1'.  "Costs Only

     CALL METHOD gcl_project->validate_cost_items
       EXPORTING
         i_rev_item     = gcl_project->rev_item
       CHANGING
         is_qmel        = gs_qmel
       EXCEPTIONS
         costs_not_zero = 1
         costs_negative = 2 " contingency
         OTHERS         = 3.

     IF sy-subrc <> 0 AND gs_qmel-template = space.
       CASE sy-subrc.
         WHEN 1.
           MESSAGE i033(/noveco/evm). "Costs must total 0 for Adjustment
         WHEN 2.
           MESSAGE i057(/noveco/evm). "Contingency Cost Balance must not be negative
         WHEN OTHERS.
       ENDCASE.
       EXIT.
     ENDIF.

     CALL METHOD gcl_project->confirm_cost_items
       EXPORTING
         i_qmnum           = gs_qmel-qmnum
         i_rev_item        = gcl_project->rev_item
       EXCEPTIONS
         no_wbs_or_network = 1
         no_cost_element   = 2
         no_costing_key    = 3
         OTHERS            = 2.

     IF sy-subrc NE 0 AND gs_qmel-template = space.

       CASE sy-subrc .

         WHEN '1'.
           MESSAGE i031(/noveco/evm). "Costing Items must be assigned either WBS or Network.

         WHEN '2'.
           MESSAGE i040(/noveco/evm). "All Costing Items must be assigned to a Cost Element.

         WHEN '3'.
           MESSAGE i042(/noveco/evm). "All Costing Items must have a Costing Key.

       ENDCASE.

       RETURN.
     ELSE.
* Sum Revenue into header
       CALL METHOD gcl_project->sum_revenue( CHANGING cs_qmel = gs_qmel ).

       PERFORM set_current_variation.
       PERFORM update_tree.
       gcl_screen->gr_alv_revenue->refresh( ).

     ENDIF.

   ELSE.

     CALL METHOD gcl_project->validate_cost_items
       EXPORTING
         i_rev_item     = '00'
       CHANGING
         is_qmel        = gs_qmel
       EXCEPTIONS
         costs_not_zero = 1
         costs_negative = 2 " contingency
         OTHERS         = 3.

     IF sy-subrc <> 0 AND gs_qmel-template = space.
       CASE sy-subrc.
         WHEN 1.
           MESSAGE i033(/noveco/evm). "Costs must total 0 for Adjustment
         WHEN 2.
           MESSAGE i057(/noveco/evm). "Contingency Cost Balance must not be negative
         WHEN OTHERS.
       ENDCASE.
       EXIT.
     ENDIF.

*   Costs Only
     CALL METHOD gcl_project->confirm_cost_items_no_revenue
       EXPORTING
         i_qmnum           = gs_qmel-qmnum
       EXCEPTIONS
         no_wbs_or_network = 1
         no_cost_element   = 2
         no_costing_key    = 3
         OTHERS            = 4.
     IF sy-subrc <> 0 AND gs_qmel-template = space.

       CASE sy-subrc .

         WHEN '1'.
           MESSAGE i031(/noveco/evm). "Costing Items must be assigned either WBS or Network.

         WHEN '2'.
           MESSAGE i040(/noveco/evm). "All Costing Items must be assigned to a Cost Element.

         WHEN '3'.
           MESSAGE i042(/noveco/evm). "All Costing Items must have a Costing Key.

       ENDCASE.

       RETURN.
     ENDIF.


   ENDIF.


   CALL METHOD gcl_project->sum_costs
     CHANGING
       cs_qmel = gs_qmel.

   IF gs_qmel-date_appr IS INITIAL.
     gs_qmel-date_appr = sy-datum.
     CLEAR gs_qmel-use_date_appr.
   ENDIF.

   IF gs_qmel-erdat IS INITIAL.
     gs_qmel-erdat = sy-datum.
   ENDIF.

   gv_changes_made = 'X'.

   IF gs_qmel-qmnum IS NOT INITIAL.

     IF gs_qmel-qmnum(1) NE '$'.

       CALL METHOD gcl_project->save_variation
         EXPORTING
           i_calc_only          = 'X'
         CHANGING
           c_qmel               = gs_qmel
         EXCEPTIONS
           error_saving_revenue = 1
           error_saving_costs   = 2
           OTHERS               = 3.
       IF sy-subrc <> 0.

       ENDIF.

     ENDIF.

   ENDIF.

   gv_confirmed = 'X'.

   gcl_project->clear_current_rev_item( ).

   PERFORM clear_tree_completely.

   IF lv_update_type NE '1'.  "Costs Only
     gcl_screen->gr_alv_costs->set_read_only( 'X' ).
     gcl_project->set_costs_read_only( ).
     gv_manage_rev_or_cost = 'R'. " manage revenue items
   ENDIF.

   gcl_screen->gr_alv_revenue->set_read_only( ' ' ).

   PERFORM update_tree.

   PERFORM set_current_variation.

* Add new empty cost line
   PERFORM add_empty_cost_item.

   gcl_screen->gr_alv_revenue->refresh( ).

   gcl_screen->gr_alv_costs->refresh( ).

   gcl_screen->gr_alv_variations->refresh( ).

 ENDFORM.                    " CONFIRM_COST_ITEM
*&---------------------------------------------------------------------*
*&      Form  CLEAR_TREE_CURRENT_VARIATION
