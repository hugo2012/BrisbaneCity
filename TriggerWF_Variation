   FIELD-SYMBOLS <fs_var_rev> TYPE /noveco/var_rev_alv.

* Sales Order must belong to Project ------------------------------------------------------
   lt_mod_cells[] = ir_data_changed->mt_mod_cells[].
   SORT lt_mod_cells BY row_id .

   LOOP AT lt_mod_cells INTO ls_mod_cell
                       WHERE fieldname = 'VBELN' .

     READ TABLE gcl_project->gt_var_revenue ASSIGNING <fs_var_rev> INDEX ls_mod_cell-row_id.

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'VBELN'
       IMPORTING
         e_value     = lv_value.

     DATA: lv_vbeln TYPE vbeln.
     lv_vbeln = lv_value.

     IF lv_vbeln IS INITIAL.

       CALL METHOD ir_data_changed->modify_cell
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'POSNR'
           i_value     = space.

       CALL METHOD ir_data_changed->modify_cell
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'NEW_ITEM'
           i_value     = space.

       CALL METHOD ir_data_changed->modify_cell
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'MATNR'
           i_value     = space.

       CALL METHOD ir_data_changed->modify_style
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'POSNR'
           i_style     = cl_gui_alv_grid=>mc_style_disabled.

       EXIT.

     ELSE.

       CALL METHOD ir_data_changed->modify_style
         EXPORTING
           i_row_id    = ls_mod_cell-row_id
           i_fieldname = 'POSNR'
           i_style     = cl_gui_alv_grid=>mc_style_enabled.

     ENDIF.

     DATA lv_posnr TYPE posnr.
