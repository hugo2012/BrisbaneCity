   CALL METHOD ir_data_changed->get_cell_value
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'PLANT_ACTIVITY'
     IMPORTING
       e_value     = lv_value.

   DATA: lv_werks TYPE werks_d.
   lv_werks = lv_value.

   TRANSLATE: lv_werks  TO UPPER CASE.
   CALL FUNCTION 'CONVERSION_EXIT_ALPHA_OUTPUT'
     EXPORTING
       input  = lv_werks
     IMPORTING
       output = lv_werks.

   CALL METHOD ir_data_changed->modify_cell
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'ASNUM'
       i_value     = lv_asnum.


   CALL METHOD ir_data_changed->modify_cell
     EXPORTING
       i_row_id    = ls_mod_cell-row_id
       i_fieldname = 'WERKS'
       i_value     = lv_werks.


   IF lv_asnum IS INITIAL AND ls_cost-asnum IS NOT INITIAL.
     CALL METHOD ir_data_changed->modify_cell
