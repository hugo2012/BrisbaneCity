       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'POSNR'
       IMPORTING
         e_value     = lv_value.

     lv_posnr = lv_value.

     IF lv_vbeln IS NOT INITIAL.

       READ TABLE gcl_project->gt_vbap TRANSPORTING NO FIELDS WITH KEY vbeln = lv_vbeln.
       IF sy-subrc NE 0.

         CALL FUNCTION 'CONVERSION_EXIT_ALPHA_OUTPUT'
           EXPORTING
             input  = lv_vbeln
           IMPORTING
             output = lv_value.

         CALL METHOD ir_data_changed->add_protocol_entry
           EXPORTING
             i_msgid     = '/NOVECO/EVM'
             i_msgno     = '002'                 "Sales Order & is not related to this Project.
