*----------------------------------------------------------------------*
 FORM validate_cost_element_v  USING  lt_mod_cells TYPE lvc_t_modi
                                      ir_data_changed TYPE REF TO cl_alv_changed_data_protocol.


   DATA : ls_mod_cell TYPE lvc_s_modi.

   DATA: ls_kstar_range  TYPE /noveco/kstar_range,
         lt_kstar_range  TYPE /noveco/kstar_range_t,
         lv_kstar_to_try TYPE kstar.

   DATA lv_valid VALUE space.

* If Cost Element entered, ensure the category is appropriate
   DATA: lv_kstar       TYPE kstar,
         lv_katyp       TYPE cskb-katyp,
         lv_no_exist    VALUE space,
         lv_kalka       TYPE /noveco/var_cost-kalka,
         lv_acpos       TYPE acpos,
         lv_res_name    TYPE /noveco/res_name,
         lv_msgv1       TYPE string,
         lv_msgv2       TYPE string,
         lv_waers       TYPE waers,
         lv_preis       TYPE preis,
         lv_preis_tcurr TYPE preis.

   LOOP AT lt_mod_cells INTO ls_mod_cell
                              WHERE  ( fieldname = 'KSTAR' OR fieldname = 'KALKA' ).

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'KSTAR'
       IMPORTING
         e_value     = lv_kstar.

     CALL METHOD ir_data_changed->get_cell_value
       EXPORTING
         i_row_id    = ls_mod_cell-row_id
         i_fieldname = 'KALKA'
       IMPORTING
         e_value     = lv_kalka.

     IF lv_kalka = 'V' AND lv_kstar IS NOT INITIAL.

       CALL METHOD gcl_project->validate_cost_element
         EXPORTING
           i_kstar    = lv_kstar
         IMPORTING
           e_valid    = lv_valid
           e_katyp    = lv_katyp
           e_no_exist = lv_no_exist.

       IF lv_no_exist = 'X'.

         lv_msgv1 = lv_kstar.
         SHIFT lv_msgv1 LEFT DELETING LEADING '0'.

         CALL METHOD ir_data_changed->add_protocol_entry
           EXPORTING
             i_msgid     = '/NOVECO/EVM'
             i_msgno     = '041'                 "Cost Element & does not exist.
             i_msgty     = 'E'
             i_msgv1     = lv_msgv1
             i_msgv2     = ''
             i_msgv3     = ''
             i_fieldname = 'KSTAR'
             i_row_id    = ls_mod_cell-row_id.


         CALL METHOD ir_data_changed->display_protocol.

         EXIT.

       ENDIF.


       IF lv_valid NE 'X'.

         CALL FUNCTION 'CONVERSION_EXIT_MATN1_OUTPUT'
           EXPORTING
             input  = lv_kstar
           IMPORTING
             output = lv_kstar.

         lv_msgv1 = lv_kstar.
         lv_msgv2 = lv_katyp.

         CALL METHOD ir_data_changed->add_protocol_entry
           EXPORTING
             i_msgid     = '/NOVECO/EVM'
             i_msgno     = '039'                 "Cost Element & category & not allowed.
             i_msgty     = 'E'
             i_msgv1     = lv_msgv1
             i_msgv2     = lv_msgv2
             i_msgv3     = ''
             i_fieldname = ls_mod_cell-fieldname
             i_row_id    = ls_mod_cell-row_id.


         CALL METHOD ir_data_changed->display_protocol.

         EXIT.

       ENDIF.



     ENDIF.

   ENDLOOP.

 ENDFORM.                    " VALIDATE_COST_ELEMENT_V
