*----------------------------------------------------------------------*
 FORM handle_data_change_rev  USING    ir_data_changed TYPE REF TO cl_alv_changed_data_protocol
                                       p_e_onf4
                                       p_e_onf4_before
                                       p_e_onf4_after
                                       p_e_ucomm.


   DATA : ls_mod_cell TYPE lvc_s_modi,
          lv_value    TYPE lvc_value,
          lv_new_item TYPE xfeld.

   DATA: "lv_revenue        type /noveco/wogxxx,
     lv_rev_plan       TYPE /noveco/wogxxx,
     lv_cost           TYPE /noveco/wogxxx,
     lv_profit         TYPE /noveco/wogxxx,
     ls_revenue        LIKE LINE OF gcl_project->gt_var_revenue,
     lv_margin         TYPE /noveco/profit_perc,
     lv_expected_perct TYPE /noveco/percent,
     lv_expected_value TYPE wogxxx.


