                EXCEPTIONS
                  no_recipients_found     = 1                " No recipients found
                  OTHERS                  = 2.
              IF sy-subrc <> 0.
*                          MESSAGE ID SY-MSGID TYPE SY-MSGTY NUMBER SY-MSGNO
*                            WITH SY-MSGV1 SY-MSGV2 SY-MSGV3 SY-MSGV4.
              ENDIF.
            ENDIF.
          ENDIF.
        ENDIF.
      ENDIF.

