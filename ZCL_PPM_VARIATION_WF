         processed_by          = ls_holder-emailaddress "mail
         local_created_by      = ls_lastitem_step-localcreatedby
         local_created_at      = ls_lastitem_step-localcreatedat
         local_last_changed_by = ls_holder-userid
         local_last_changed_at = lv_local_changed_at
         last_changed_at       = lv_local_changed_at ).

    MODIFY zppm_variat_step FROM ls_variations_step.
    IF sy-subrc IS NOT INITIAL.
      RAISE save_data_failed.
    ELSE.
      COMMIT WORK AND WAIT.
*       Send mail to PM and cancel workflow in case of rejection.
      IF iv_decision_wi_result = zif_ppm_variation_wf_c=>c_decision_outcome_id-approve.
        "Send notification mail to PM recipient
        IF lv_lastlevelapproval = abap_false.
          DATA(lv_evt_type) = zif_ppm_variation_wf_c=>c_action_event-step_approved.
        ELSEIF  lv_lastlevelapproval = abap_true.
          lv_evt_type = zif_ppm_variation_wf_c=>c_action_event-complete_approved.
        ENDIF.
      ELSEIF iv_decision_wi_result = zif_ppm_variation_wf_c=>c_decision_outcome_id-requestinformation.
        lv_evt_type = zif_ppm_variation_wf_c=>c_action_event-requestinformation.
        " Restart workflow.
*          TRY.
*             CALL METHOD me->restart_approval.
*          CATCH cx_swf_evt_invalid_objtype
*                cx_swf_evt_invalid_event.
*            ENDTRY.

      ELSEIF iv_decision_wi_result = zif_ppm_variation_wf_c=>c_decision_outcome_id-resubmit.
        lv_evt_type = zif_ppm_variation_wf_c=>c_action_event-ReSubmit.
      ELSEIF iv_decision_wi_result = zif_ppm_variation_wf_c=>c_decision_outcome_id-reject.
        lv_evt_type = zif_ppm_variation_wf_c=>c_action_event-rejected.
        "1. Cancel workflow.
        CALL FUNCTION 'SAP_WAPI_ADM_WORKFLOW_CANCEL'
          EXPORTING
            workitem_id    = iv_workitemid
            actual_agent   = ls_holder-userid
            language       = sy-langu
            do_commit      = 'X'
          IMPORTING
            return_code    = lv_return_code
            new_status     = lv_new_status
          TABLES
            message_lines  = lt_message_lines
            message_struct = lt_message_struct.

      ENDIF.

      "2. Send notification mail to PM recipient
      " get process email.
      IF iv_pmapprover IS NOT INITIAL.

        lr_usrids_pm = VALUE #(
         sign   = 'I'
         option = 'EQ'
         ( low =  iv_pmapprover+2 )
         ).
        SELECT userid, emailaddress, fullname
         FROM zi_positionholder_dp WITH PRIVILEGED ACCESS
         WHERE userid IN @lr_usrids_pm
         INTO TABLE @lt_recipients .
        IF sy-subrc IS INITIAL.
          IF lt_recipients IS NOT INITIAL.

            IF iv_deep_link_url IS NOT INITIAL.
              LOOP AT iv_deep_link_url  INTO DATA(ls_url).
                lv_deep_link_url = lv_deep_link_url  && ls_url-tdline.
              ENDLOOP.
            ENDIF.
            DATA ls_variation_head TYPE /noveco/var_head.
            ls_variation_head = CORRESPONDING #( is_variationhead ).
            CALL METHOD me->sendmail_approval
              EXPORTING
                iv_variationnumber      = iv_variation_number              " Notification Number
                iv_deep_link_url        = lv_deep_link_url          " URL
                iv_curr_workflow_action = iv_workflow_action              " Workflow Action
                it_recipients           = lt_recipients
                is_variationhead        = ls_variation_head               " EVM Variation List
                iv_action_event         = lv_evt_type
              EXCEPTIONS
                no_recipients_found     = 1                " No recipients found
                OTHERS                  = 2.
            IF sy-subrc <> 0.
*              MESSAGE ID SY-MSGID TYPE SY-MSGTY NUMBER SY-MSGNO
*                WITH SY-MSGV1 SY-MSGV2 SY-MSGV3 SY-MSGV4.
            ENDIF.
          ENDIF.
        ENDIF.

      ENDIF.
      IF iv_interes_approver IS NOT INITIAL.
        IF  lv_evt_type = zif_ppm_variation_wf_c=>c_action_event-rejected OR
           lv_evt_type = zif_ppm_variation_wf_c=>c_action_event-complete_approved.
          IF iv_interes_approver IS NOT INITIAL.
            lr_usrids_inters = VALUE #(
            ( sign = 'I' option = 'EQ' low = iv_interes_approver+2 )
            ).
            CLEAR: lt_recipients .
            SELECT userid, emailaddress, fullname
             FROM zi_positionholder_dp WITH PRIVILEGED ACCESS
             WHERE userid IN @lr_usrids_inters
             INTO TABLE @lt_recipients .
            IF sy-subrc IS INITIAL.
              IF lt_recipients IS NOT INITIAL.
                CLEAR: lv_deep_link_url.
                IF iv_deep_link_url IS NOT INITIAL.
                  CLEAR: ls_url.
                  LOOP AT iv_deep_link_url  INTO ls_url.
                    lv_deep_link_url = lv_deep_link_url  && ls_url-tdline.
                  ENDLOOP.
                ENDIF.
                "DATA ls_variation_head TYPE /noveco/var_head.
                ls_variation_head = CORRESPONDING #( is_variationhead ).
                CALL METHOD me->sendmail_approval
                  EXPORTING
                    iv_variationnumber      = iv_variation_number
                    iv_deep_link_url        = lv_deep_link_url
                    iv_curr_workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-interested
                    it_recipients           = lt_recipients
                    is_variationhead        = ls_variation_head
                    iv_action_event         = lv_evt_type
                  EXCEPTIONS
                    no_recipients_found     = 1
                    OTHERS                  = 2.
                IF sy-subrc <> 0.
*                      MESSAGE ID SY-MSGID TYPE SY-MSGTY NUMBER SY-MSGNO
*                        WITH SY-MSGV1 SY-MSGV2 SY-MSGV3 SY-MSGV4.
                ENDIF.
              ENDIF.
            ENDIF.
            "
          ENDIF.
        ENDIF.
      ENDIF.

      IF iv_decision_wi_result = zif_ppm_variation_wf_c=>c_decision_outcome_id-approve
        OR iv_decision_wi_result = zif_ppm_variation_wf_c=>c_decision_outcome_id-resubmit.
*  ***------------------------------------------------
*   get the next approver based on the project role table
*   then update back to container WORKFLOW_ACTION
*  ---------------------------------------------------
        IF lv_current_itnumber < lv_total_steps.
          DATA  lv_iv_curr_step TYPE mmpur_wf_current_approval_step .
          IF lv_rework = 'X'.
            lv_iv_curr_step  = iv_stepnumber.
          ELSE.
            CLEAR lv_iv_curr_step.
          ENDIF.
          CALL METHOD me->build_next_step
            EXPORTING
              iv_variation_number     = iv_variation_number        " Notification Number
              iv_current_step         = lv_iv_curr_step                           " Current Approval Step
              iv_ppm_id               = iv_ppm_item                 " Business Object ID
              iv_ppm_wf_action        = iv_workflow_action            " Workflow Action
              iv_variation_type       = iv_variation_type           " Notification Type
              iv_wf_path              = lv_wf_path                  " Approval path
              iv_workitemid           = iv_workitemid               " Work item ID
              iv_created_by           = ls_holder-userid             " user name of the current approver
              iv_wfinst_main          = ls_lastitem_step-wfinst_main
            IMPORTING
              ev_wf_act_next_approver = ev_workflow_action          " Workflow Action of the next approver
              ev_stepnumber           = ev_stepnumber               " Var WF Sequence of the next approver
              ev_workflow_action_text = ev_workflow_action_text     " Workflow action text of the next approver
              ev_governancerole_text  = ev_governancerole_text.      " Governance role of the next approver
        ENDIF.

      ENDIF.
    ENDIF.
*****End of Update Decision action for the current step and build the next step.************************************
*---------------------------------------------------

  ENDMETHOD.


* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Public Method ZCL_PPM_VARIATION_WF->VALIDATE_TRIGGER_WORKFLOW
* +-------------------------------------------------------------------------------------------------+
* | [--->] IS_VARIATIONHEAD               TYPE        /NOVECO/VAR_HEAD(optional)
* | [--->] IV_WF_PATH                     TYPE        ZDE_APPRV_PATH
* | [<---] R_RESULT                       TYPE        BOOLE_D
* | [EXC!] FAILEDTOTRIGGERWORKFLOW
* | [EXC!] NO_AGENT_FOUND
* +--------------------------------------------------------------------------------------</SIGNATURE>
  METHOD validate_trigger_workflow.

    DATA: lr_actions TYPE RANGE OF zwrkflow_act,
          lsr_action LIKE LINE OF lr_actions.
    DATA lv_pspid TYPE /rpm/tv_extid.

    CALL FUNCTION 'CONVERSION_EXIT_ABPSN_OUTPUT'
      EXPORTING
        input  = is_variationhead-pspid
      IMPORTING
        output = lv_pspid.
    r_result = abap_false.



*	Checking approvers by reading the “Project roles Table”
*" Modern internal table population using VALUE operator with conditional logic
    lr_actions = VALUE #(
      sign   = 'I'
      option = 'EQ'
      ( low = zif_ppm_variation_wf_c=>c_workflow_action-endorser )
      " The base sign/option carry over to subsequent rows if they aren't explicitly overridden
      ( low = zif_ppm_variation_wf_c=>c_workflow_action-approver_phase )
      ( low = zif_ppm_variation_wf_c=>c_workflow_action-approver_invest )
      ( low = zif_ppm_variation_wf_c=>c_workflow_action-decpnt_manager )
    ).
    SELECT portfolioitem,
            counter,
            positionid,
            rolename,
            roleposition,
            role,
            roleadditionalresponsible,
            decpointgovernancerole,
            workflowaction,
            workflowsequence,
            variationsequence
       FROM zi_ppm_projectroles
       WHERE portfolioitem = @lv_pspid
         AND workflowaction IN @lr_actions
         AND positionid IS NOT INITIAL
       INTO TABLE @DATA(lt_approvers).
    IF sy-subrc <> 0.
      MESSAGE e000(zppm_var) .
      "RAISE no_agent_found.
    ELSE.
      IF iv_wf_path = zif_ppm_variation_wf_c=>c_workflow_type-internal."Internal
        SELECT *
         FROM @lt_approvers AS approvers
         WHERE variationsequence IS NOT INITIAL
         INTO TABLE @DATA(lt_approver_inter).
        IF sy-subrc <> 0.
          MESSAGE e001(zppm_var).
        ENDIF.

      ELSEIF iv_wf_path = zif_ppm_variation_wf_c=>c_workflow_type-external."External
        SELECT *
         FROM @lt_approvers AS approvers
         WHERE workflowsequence IS NOT INITIAL
         INTO TABLE @DATA(lt_approver_exter).
        IF sy-subrc <> 0.
          MESSAGE e002(zppm_var) .
        ENDIF.
      ENDIF.

    ENDIF.
*     Checking Variation cost exist
    IF is_variationhead-estimated_costs <= 0.
      MESSAGE e003(zppm_var) .
    ENDIF.

    r_result = abap_true.

  ENDMETHOD.                                             "#EC CI_VALPAR


