* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Public Method ZCL_PPM_VARIATION_WF->GET_VARIATION_URL
* +-------------------------------------------------------------------------------------------------+
* | [--->] IV_PORTFOLIO_ITEM              TYPE        /RPM/TV_EXTID
* | [<---] ET_URL_LINK                    TYPE        TSFTEXT
* +--------------------------------------------------------------------------------------</SIGNATURE>
  METHOD get_variation_url.

    DATA lt_url    TYPE tsftext.
    DATA lv_webgui_base_url TYPE string.
    DATA: lv_part1 TYPE char80,
          lv_part2 TYPE char80.
    DATA:  lv_location TYPE string.

       cl_http_server=>get_location(
         EXPORTING
           protocol = 'HTTPS'
         IMPORTING
           host     = lv_location " Returns something like "sap-server.domain.com:44300"
       ).
       IF lv_location IS NOT INITIAL.
         DATA(lv_transaction_params) = |&~transaction=*ZPPM_NOVECO_EVM%20P_PROJ={ iv_portfolio_item }#|.
         lv_webgui_base_url  = |https://{ lv_location }/sap/bc/gui/sap/its/webgui/|
               && |?sap-client={ sy-mandt }|
               && |{ lv_transaction_params }|.
       ENDIF.

    " Split the string at the question mark
    SPLIT lv_webgui_base_url  AT '?' INTO lv_part1 lv_part2.

    " Add the question mark back to the end of the base URL path
    IF lv_part1 IS NOT INITIAL.
      lv_part1 = lv_part1 && '?'.
    ENDIF.

    " 4. Append to your internal text table safely
    APPEND VALUE #( tdformat = '' tdline = CONV #( lv_part1 ) ) TO lt_url.
    APPEND VALUE #( tdformat = '' tdline = CONV #( lv_part2 ) ) TO lt_url.
    et_url_link = COND #( WHEN lt_url IS NOT INITIAL THEN lt_url ).
  ENDMETHOD.                                             "#EC CI_VALPAR


