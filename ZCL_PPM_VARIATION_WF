  METHOD start_workflow.

    DATA: lo_event           TYPE REF TO if_swf_evt_event,
          lv_object_id       TYPE mmpur_key,
          lo_event_container TYPE REF TO if_swf_ifs_parameter_container,
          lv_r_result        TYPE boole_d.
    DATA: lv_wfinst_main    TYPE rpm_tv_guid,
          lv_chk_crt_wfinst TYPE boole_d,
          lv_step_uuid      TYPE rpm_tv_guid,
          lr_actions        TYPE RANGE OF zwrkflow_act,
          lsr_action        LIKE LINE OF lr_actions..


   "DATA(ls_variationhead) = VALUE #( it_variation_head[ 1 ] OPTIONAL ).
    DATA ls_variation_head  TYPE /noveco/var_head .

    ls_variation_head  = it_variation_head..

    lv_object_id = iv_variationnumber.
    lv_chk_crt_wfinst = abap_true.

* Get the first step number instead of using the Iv_stepnumber.

    " Modern internal table population using VALUE operator with conditional logic
    lr_actions = VALUE #(
      sign   = 'I'
      option = 'EQ'
      ( low =  zif_ppm_variation_wf_c=>c_workflow_action-endorser )
      " The base sign/option carry over to subsequent rows if they aren't explicitly overridden
      ( low = zif_ppm_variation_wf_c=>c_workflow_action-approver_phase )
      ( low = zif_ppm_variation_wf_c=>c_workflow_action-approver_invest )
      "( low = zif_ppm_variation_wf_c=>c_workflow_action-decpnt_manager )
    ).
    " read project role.
      SELECT portfolioitem,
        counter,
        positionid,
        rolename,
        roleposition,
        role,
        roleadditionalresponsible,
        decpointgovernancerole,
        workflowaction,
        workflowsequence,
        variationsequence
       FROM zi_ppm_projectroles
     WHERE portfolioitem = @iv_portfolioitem
      AND workflowaction IN @lr_actions
      AND positionid IS NOT INITIAL INTO TABLE @DATA(lt_proj_roles).
     IF sy-subrc IS INITIAL.
         IF iv_wf_path = zif_ppm_variation_wf_c=>c_workflow_type-internal."Internal
          DATA(lv_wf_path) = zif_ppm_variation_wf_c=>c_workflow_type-internal.
          " read project role.

          DELETE lt_proj_roles  WHERE variationsequence IS INITIAL.
          SORT lt_proj_roles BY variationsequence  ASCENDING.
            "DATA(lv_total_steps) = lines( lt_proj_roles ).
          DATA(ls_proj_roles) = VALUE #( lt_proj_roles[ 1 ]  OPTIONAL ).
          DATA(lv_step_number_first) =  ls_proj_roles-variationsequence.
          DATA(lv_workflow_seq_var)      = lv_step_number_first.
          DATA(lv_total_steps) = lines( lt_proj_roles ).
          " DATA(lv_wf_path) = '01'.
        ELSEIF iv_wf_path = zif_ppm_variation_wf_c=>c_workflow_type-external."External

          DELETE lt_proj_roles WHERE workflowsequence IS INITIAL.
          SORT lt_proj_roles BY workflowsequence ASCENDING.
            "lv_total_steps = lines( lt_proj_roles ).
          ls_proj_roles = VALUE #( lt_proj_roles[ 1 ]  OPTIONAL ).
          lv_step_number_first =  ls_proj_roles-workflowsequence.
          DATA(lv_workflow_seq)      = lv_step_number_first.
          lv_total_steps = lines( lt_proj_roles ).
          lv_wf_path = zif_ppm_variation_wf_c=>c_workflow_type-external.
        ENDIF.
     ENDIF.

    "read the portfolio item details for parent bucket and portfolio UUIDs
    SELECT SINGLE ProjectPortfolioUUID,
                  ProjectPortfolioItemUUID,
                  ProjPrtfloItemParentObjectUUID,
                   ProjectPortfolioItem
      FROM ZI_ProjectPortfolioItemBasic WITH PRIVILEGED ACCESS
     WHERE ProjectPortfolioItem = @iv_portfolioitem
     INTO @DATA(ls_portfolio_item).
    IF sy-subrc IS INITIAL.
      DATA(lv_item_guid)  = ls_portfolio_item-ProjectPortfolioItemUUID.
    ENDIF.


*   Must to validate variation data before call trigger workflow.
    CALL METHOD me->validate_trigger_workflow
      EXPORTING
        is_variationhead        = ls_variation_head
        iv_wf_path              = iv_wf_path
      IMPORTING
        r_result                = lv_r_result
      EXCEPTIONS
        failedtotriggerworkflow = 1 " Failed to trigger workflow
        OTHERS                  = 2.
    IF sy-subrc <> 0.
*       MESSAGE ID SY-MSGID TYPE SY-MSGTY NUMBER SY-MSGNO
*         WITH SY-MSGV1 SY-MSGV2 SY-MSGV3 SY-MSGV4.
    ENDIF.
*     for tesing in d41 100
*        CHECK lv_r_result = abap_true.

    IF lv_r_result = abap_true.
*---------------------------------------------------------------
*     Create instance for workflow.
      SELECT SINGLE status FROM zi_ppm_variat_appr WITH PRIVILEGED ACCESS "#EC CI_ALL_FIELDS_NEEDED
      WHERE itemguid = @ls_portfolio_item-projectportfolioitemuuid
        AND variation_number = @iv_variationnumber
        AND status = @zif_ppm_variation_wf_c=>c_flow_status-in_progress
       INTO @DATA(lv_variat_appr_stat).
      IF sy-subrc IS INITIAL.

        IF lv_variat_appr_stat = zif_ppm_variation_wf_c=>c_flow_status-in_progress.
          lv_chk_crt_wfinst = abap_false.
          MESSAGE e005(zppm_var) WITH iv_variationnumber.
          RETURN.
*              ELSEIF  ls_variat_appr_chk-status = zif_ppm_variation_wf_c=>c_flow_status-approved.
*                lv_chk_crt_wfinst = abap_false.
*                MESSAGE e006(zppm_var) WITH iv_variationnumber.
*                RETURN.
*              ELSEIF  ls_variat_appr_chk-status = zif_ppm_variation_wf_c=>c_flow_status-rejected
*                OR ls_variat_appr_chk-status = zif_ppm_variation_wf_c=>c_flow_status-cancelled.
*                lv_chk_crt_wfinst = abap_true.
        ENDIF.
      ELSE.
        lv_chk_crt_wfinst = abap_true.
      ENDIF.
      IF  lv_chk_crt_wfinst = abap_true.

        " Declares a variable inline and fills it with the current timestamp (YYYYMMDDHHMMSS)
        GET TIME STAMP FIELD DATA(lv_current_timestamp).
        " You can then assign it directly inside your VALUE expression:
        DATA(lv_local_created_at) = lv_current_timestamp.
        CALL METHOD me->generate_uuid
