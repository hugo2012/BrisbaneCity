  METHOD read_noveco_epm_vrej.
    SELECT SINGLE  VarRejreasDesc
      FROM zi_eppm_variation_rejs
      INTO @DATA(lv_var_rej_reason)
      WHERE  varrejreas = @iv_var_rej_reas.
