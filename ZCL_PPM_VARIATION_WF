* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Public Method ZCL_PPM_VARIATION_WF->BUILD_NEXT_STEP
* +-------------------------------------------------------------------------------------------------+
* | [--->] IV_VARIATION_NUMBER            TYPE        QMNUM(optional)
* | [--->] IV_CURRENT_STEP                TYPE        MMPUR_WF_CURRENT_APPROVAL_STEP(optional)
* | [--->] IV_PPM_ID                      TYPE        /RPM/TV_EXTID(optional)
* | [--->] IV_PPM_WF_ACTION               TYPE        ZWRKFLOW_ACT(optional)
* | [--->] IV_VARIATION_TYPE              TYPE        QMART(optional)
* | [--->] IV_WF_PATH                     TYPE        ZDE_APPRV_PATH(optional)
* | [--->] IV_WORKITEMID                  TYPE        SWW_WIID(optional)
* | [--->] IV_CREATED_BY                  TYPE        SY-UNAME(optional)
* | [--->] IV_WFINST_MAIN                 TYPE        RPM_TV_GUID(optional)
* | [<---] EV_WF_ACT_NEXT_APPROVER        TYPE        ZWRKFLOW_ACT
* | [<---] EV_STEPNUMBER                  TYPE        ZWRKFLOW_SEQ1
* | [<---] EV_WORKFLOW_ACTION_TEXT        TYPE        CHAR80
* | [<---] EV_GOVERNANCEROLE_TEXT         TYPE        CHAR80
* +--------------------------------------------------------------------------------------</SIGNATURE>
  METHOD build_next_step.

    DATA : ls_next_post_appr TYPE  zeppm_proj_roles,
           lv_next_counter   TYPE crmt_item_no,
           lv_wfinst_main    TYPE rpm_tv_guid,
           lv_step_uuid      TYPE rpm_tv_guid,
           lv_curr_step_uuid TYPE rpm_tv_guid.
*  ***------------------------------------------------
*   get the next approver based on the project role table
*   then update back to container WORKFLOW_ACTION
*  ---------------------------------------------------
    CALL FUNCTION 'ZPPM_FM_GET_ACTION_NEXT_VAR'
      EXPORTING
        iv_variation_number          = iv_variation_number
        iv_current_step              = iv_current_step
        iv_ppm_id                    = iv_ppm_id
        iv_ppm_wf_action             = iv_ppm_wf_action
        iv_variation_type            = iv_variation_type
        iv_wf_path                   = iv_wf_path
        iv_workitemid                = iv_workitemid
        iv_wfinst_main               = iv_wfinst_main
      IMPORTING
        ev_wfinst_main               = lv_wfinst_main
        ev_wf_act_next_approver      = ev_wf_act_next_approver
        ev_stepnumber                = ev_stepnumber
        ev_wf_next_counter           = lv_next_counter
        es_next_post_appr            = ls_next_post_appr
        es_curr_step_uuid            = lv_curr_step_uuid
      EXCEPTIONS
        no_agent_next_approver_found = 1
        OTHERS                       = 2.
    IF sy-subrc <> 0.
*   Implement suitable error handling here
    ELSE.
*         Insert new record into table ZPPM_VARIAT_STEP for the next step of approver*********
      " Declares a variable inline and fills it with the current timestamp (YYYYMMDDHHMMSS)
      GET TIME STAMP FIELD DATA(lv_current_timestamp).
      " You can then assign it directly inside your VALUE expression:
      DATA(lv_local_created_at) = lv_current_timestamp.
      IF  iv_wf_path = zif_ppm_variation_wf_c=>c_workflow_type-internal."Internal.
        DATA(workflow_seq_var) = ls_next_post_appr-workflow_seq_var.
      ELSEIF  iv_wf_path = zif_ppm_variation_wf_c=>c_workflow_type-external."External..
        "Active
        DATA(workflow_seq) = ls_next_post_appr-workflow_seq.
      ENDIF.

      IF iv_current_step IS NOT INITIAL.
        lv_step_uuid =   lv_curr_step_uuid.
      ELSE.
        CALL METHOD me->generate_uuid
          IMPORTING
            ev_guid = lv_step_uuid.
      ENDIF.

      DATA(ls_step) = VALUE zppm_variat_step( step_uuid  = lv_step_uuid
                              wfinst_main =  iv_wfinst_main
                              counter = lv_next_counter
                              wi_id = iv_workitemid
                              ppm_item = iv_ppm_id
                              variation_number = iv_variation_number
                              variation_type = iv_variation_type
                              workflow_seq_var = workflow_seq_var
                              workflow_seq = workflow_seq
                              workflow_action = ls_next_post_appr-workflow_action
                              prjrole_role = ls_next_post_appr-prjrole_role
                              govern_role = ls_next_post_appr-des_point_govrole
                              position_id = ls_next_post_appr-position_id
                              local_created_by = iv_created_by
                              local_created_at = lv_local_created_at ).

      MODIFY zppm_variat_step FROM ls_step.
      IF sy-subrc IS INITIAL.
        COMMIT WORK AND WAIT.
      ENDIF.
*         *************************************************************************************

      IF ev_wf_act_next_approver = zif_ppm_variation_wf_c=>c_workflow_action-endorser.
        ev_workflow_action_text = zif_ppm_variation_wf_c=>c_workflow_action_text-endorser.
        ev_governancerole_text = zif_ppm_variation_wf_c=>c_governance_role_action-pp_endorser.
      ELSEIF ev_wf_act_next_approver = zif_ppm_variation_wf_c=>c_workflow_action-approver_phase.
        ev_workflow_action_text = zif_ppm_variation_wf_c=>c_workflow_action_text-approver_phase.
        ev_governancerole_text = zif_ppm_variation_wf_c=>c_governance_role_action-pp_approver.
      ELSEIF  ev_wf_act_next_approver = zif_ppm_variation_wf_c=>c_workflow_action-approver_invest.
        ev_workflow_action_text = zif_ppm_variation_wf_c=>c_workflow_action_text-approver_invest.
        ev_governancerole_text = zif_ppm_variation_wf_c=>c_governance_role_action-inv_approver.
      ENDIF.
    ENDIF.
  ENDMETHOD.


