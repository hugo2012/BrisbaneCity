* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Public Method ZCL_PPM_VARIATION_WF->SETFLOWSTATUS
* +-------------------------------------------------------------------------------------------------+
* | [--->] IV_WFINST_MAIN                 TYPE        RPM_TV_GUID(optional)
* | [--->] IV_VARIATION_NUMBER            TYPE        QMNUM(optional)
* | [--->] IV_DECISION_WI_RESULT          TYPE        SWD_RETUR_(optional)
* | [--->] IV_WORKFLOW_ACTION             TYPE        ZWRKFLOW_ACT(optional)
* | [--->] IV_CURRENT_STEP_UUID           TYPE        SYSUUID_X16(optional)
* | [--->] IV_FINAL_STEP_UUID             TYPE        SYSUUID_X16(optional)
* | [--->] IV_LASTLEVELAPPROVAL           TYPE        BOOLE_D(optional)
* | [--->] IV_LAST_CHANGED_BY             TYPE        SY-UNAME(optional)
* | [<---] R_RESULT                       TYPE        BOOLE_D
* | [EXC!] UPDATE_CURR_STAT_STEP_FAILED
* | [EXC!] UPDATE_FINAL_STAT_STEP_FAILED
* +--------------------------------------------------------------------------------------</SIGNATURE>
  METHOD setflowstatus.

    DATA lv_flow_status TYPE numc5.
    r_result = abap_false.
    IF iv_decision_wi_result = zif_ppm_variation_wf_c=>c_decision_outcome_id-approve.
      IF iv_workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-approver_phase
        OR iv_workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-approver_invest.
        IF iv_lastlevelapproval = abap_true.
          lv_flow_status = zif_ppm_variation_wf_c=>c_flow_status-approved.
        ELSE.
          lv_flow_status = zif_ppm_variation_wf_c=>c_flow_status-in_progress.
        ENDIF.
      ELSEIF iv_workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-endorser.
        lv_flow_status = zif_ppm_variation_wf_c=>c_flow_status-in_progress.
      ENDIF.

    ELSEIF iv_decision_wi_result = zif_ppm_variation_wf_c=>c_decision_outcome_id-requestinformation.
      IF iv_workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-approver_phase
        OR iv_workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-approver_invest.
        lv_flow_status = zif_ppm_variation_wf_c=>c_flow_status-in_progress.
      ELSEIF iv_workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-endorser.
        lv_flow_status = zif_ppm_variation_wf_c=>c_flow_status-in_progress.
      ENDIF.
    ELSEIF iv_decision_wi_result = zif_ppm_variation_wf_c=>c_decision_outcome_id-reject.
      IF iv_workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-approver_phase
        OR iv_workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-approver_invest.
        lv_flow_status = zif_ppm_variation_wf_c=>c_flow_status-rejected.
      ELSEIF iv_workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-endorser.
        lv_flow_status = zif_ppm_variation_wf_c=>c_flow_status-rejected.
      ENDIF.
     ELSEIF iv_decision_wi_result = zif_ppm_variation_wf_c=>c_decision_outcome_id-resubmit.
      IF iv_workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-approver_phase
        OR iv_workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-approver_invest.
        lv_flow_status = zif_ppm_variation_wf_c=>c_flow_status-in_progress.
      ELSEIF iv_workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-endorser.
        lv_flow_status = zif_ppm_variation_wf_c=>c_flow_status-in_progress.
      ENDIF.
    ENDIF.
    "Commit to db table
    " Declares a variable inline and fills it with the current timestamp (YYYYMMDDHHMMSS)
    GET TIME STAMP FIELD DATA(lv_current_timestamp).
    " You can then assign it directly inside your VALUE expression:
    DATA(lv_local_changed_at) = lv_current_timestamp.
    SELECT SINGLE wfinstmain
       FROM zi_ppm_variat_appr WITH PRIVILEGED ACCESS
    WHERE wfinstmain  = @iv_wfinst_main
      AND variation_number = @iv_variation_number INTO @DATA(lv_wfinstmain_ck) .
    IF sy-subrc IS INITIAL.
      IF iv_lastlevelapproval = abap_true AND iv_final_step_uuid IS NOT INITIAL.
        UPDATE zppm_variat_appr
        SET current_step_uuid = iv_current_step_uuid final_step_uuid = iv_final_step_uuid status = lv_flow_status
            local_last_changed_by = iv_last_changed_by
            local_last_changed_at = lv_local_changed_at
            last_changed_at = lv_local_changed_at
        WHERE wfinst_main = iv_wfinst_main
        AND variation_number = iv_variation_number.
        IF sy-subrc IS INITIAL.
          COMMIT WORK AND WAIT.
        ELSE.
          RAISE update_final_stat_step_failed.
        ENDIF.
      ELSE.
        UPDATE zppm_variat_appr
        SET current_step_uuid = iv_current_step_uuid status = lv_flow_status
            local_last_changed_by = iv_last_changed_by
            local_last_changed_at = lv_local_changed_at
            last_changed_at = lv_local_changed_at
        WHERE wfinst_main = iv_wfinst_main
        AND variation_number = iv_variation_number.
        IF sy-subrc IS INITIAL.
          COMMIT WORK AND WAIT.
        ELSE.
          RAISE update_curr_stat_step_failed.
        ENDIF.
      ENDIF.
    ENDIF.

    r_result = abap_true.

  ENDMETHOD.                                             "#EC CI_VALPAR


