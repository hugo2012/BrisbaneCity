      locallastchangedby,
      locallastchangedat,
      lastchangedat
     FROM zi_ppm_variation_steps WITH PRIVILEGED ACCESS
     WHERE wfinst_main = @iv_wfinst_main
     " AND WorkitemId = @iv_workitemid
      AND ppmitem = @iv_ppm_item
      "AND variationnumber = @iv_variation_number
      ORDER BY counter DESCENDING INTO TABLE @DATA(lt_variation_steps).
    IF sy-subrc IS INITIAL.
      "get last step.
      DATA(ls_lastitem_step) = VALUE #( lt_variation_steps[ 1 ] ).
      DATA(lv_current_itnumber) = ls_lastitem_step-counter .
*    ELSE.
*      lv_current_itnumber = 1.
    ENDIF.
    lv_rework = ''.
    IF lv_variatwftype = zif_ppm_variation_wf_c=>c_workflow_type-internal."Internal
      IF ls_lastitem_step-WorkflowSeqVar = iv_stepnumber  .
        lv_exist = abap_true.
        DATA(lv_workflow_seq_var)      = iv_stepnumber.
      ELSE.
        ls_lastitem_step = VALUE #( lt_variation_steps[ WorkflowSeqVar = iv_stepnumber ] ).
        lv_current_itnumber = ls_lastitem_step-counter .
        lv_workflow_seq_var      = iv_stepnumber.
        lv_rework = 'X'.
      ENDIF.
      DATA(lv_wf_path) = zif_ppm_variation_wf_c=>c_workflow_type-internal.
    ELSEIF lv_variatwftype = zif_ppm_variation_wf_c=>c_workflow_type-external."External
      IF  ls_lastitem_step-WorkflowSeq  = iv_stepnumber .
        lv_exist = abap_true.
        DATA(lv_workflow_seq)          = iv_stepnumber.
      ELSE.
        ls_lastitem_step = VALUE #( lt_variation_steps[ WorkflowSeq = iv_stepnumber ] ).
        lv_current_itnumber = ls_lastitem_step-counter .
        lv_workflow_seq    = iv_stepnumber.
        lv_rework = 'X'.
      ENDIF.
      lv_wf_path = zif_ppm_variation_wf_c=>c_workflow_type-external.
    ENDIF.
    " Modern internal table population using VALUE operator with conditional logic
    lr_actions = VALUE #(
      sign   = 'I'
      option = 'EQ'
      ( low =  zif_ppm_variation_wf_c=>c_workflow_action-endorser )
      " The base sign/option carry over to subsequent rows if they aren't explicitly overridden
      ( low = zif_ppm_variation_wf_c=>c_workflow_action-approver_phase )
      ( low = zif_ppm_variation_wf_c=>c_workflow_action-approver_invest )
      "( low = zif_ppm_variation_wf_c=>c_workflow_action-decpnt_manager )
    ).
        " read project role.
      SELECT portfolioitem,
          counter,
          positionid,
          rolename,
          roleposition,
          role,
          roleadditionalresponsible,
          decpointgovernancerole,
          workflowaction,
          workflowsequence,
          variationsequence
      FROM zi_ppm_projectroles
    WHERE portfolioitem = @iv_ppm_item
    "  AND variationsequence = @lv_workflow_seq_var
     AND workflowaction IN @lr_actions
     AND positionid IS NOT INITIAL INTO TABLE @DATA(lt_proj_roles)   .
    IF sy-subrc IS INITIAL.
        IF lv_variatwftype = zif_ppm_variation_wf_c=>c_workflow_type-internal."Internal
        " read project role.

        DELETE lt_proj_roles WHERE variationsequence IS INITIAL.
        SORT lt_proj_roles BY variationsequence  ASCENDING.
        DATA(ls_proj_roles) = VALUE #( lt_proj_roles[ variationsequence = lv_workflow_seq_var ]  OPTIONAL ).
        DATA(lv_total_steps) = lines( lt_proj_roles ).

      ELSEIF lv_variatwftype = zif_ppm_variation_wf_c=>c_workflow_type-external."External

       DELETE lt_proj_roles WHERE workflowsequence IS INITIAL.
       SORT lt_proj_roles  BY workflowsequence ASCENDING.
       ls_proj_roles = VALUE #( lt_proj_roles[ workflowsequence  = lv_workflow_seq ]  OPTIONAL ).
       lv_total_steps = lines( lt_proj_roles ).

      ENDIF.

    ENDIF.

    "Update total steps
    ev_total_steps = lv_total_steps.
    " get workflow item Actual agent.
    "get SAP user id
    DATA(lv_wi_actual_agent) = iv_local_created_by+2.
    " get process email.
    SELECT userid, emailaddress
     FROM zi_positionholder_dp WITH PRIVILEGED ACCESS
     WHERE
      positionid = @ls_proj_roles-positionid
      AND UserID = @lv_wi_actual_agent
     INTO TABLE @DATA(lt_holders).
    IF sy-subrc IS INITIAL.
      DATA(ls_holder) = VALUE #( lt_holders[ UserID = lv_wi_actual_agent ] OPTIONAL ). "#EC CI_NOORDER
    ELSE.
    ENDIF.
    " Declares a variable inline and fills it with the current timestamp (YYYYMMDDHHMMSS)
