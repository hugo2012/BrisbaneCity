* | Instance Public Method ZCL_PPM_VARIATION_WF->SENDMAIL_APPROVAL
* +-------------------------------------------------------------------------------------------------+
* | [--->] IV_VARIATIONNUMBER             TYPE        QMNUM(optional)
* | [--->] IV_DEEP_LINK_URL               TYPE        LCM_URL(optional)
* | [--->] IV_CURR_WORKFLOW_ACTION        TYPE        ZWRKFLOW_ACT(optional)
* | [--->] IV_ACTION_EVENT                TYPE        CHAR20(optional)
* | [--->] IT_RECIPIENTS                  TYPE        ZPPM_TT_VARIATION_HOLDER(optional)
* | [--->] IS_VARIATIONHEAD               TYPE        /NOVECO/VAR_HEAD(optional)
* | [EXC!] NO_RECIPIENTS_FOUND
* +--------------------------------------------------------------------------------------</SIGNATURE>
  METHOD sendmail_approval.

    DATA: lv_text1 TYPE char255.
*-- Local data declaration for sending mail
    DATA: lo_send_request  TYPE REF TO cl_bcs,
          lo_document      TYPE REF TO cl_document_bcs,
          lo_sender        TYPE REF TO cl_sapuser_bcs,
          lv_sub           TYPE char50,
          lo_recipient     TYPE REF TO if_recipient_bcs,
          lt_contents      TYPE STANDARD TABLE OF soli,
          lv_doc_len       TYPE so_obj_len,
          lv_cnt           TYPE sy-tabix,
          lv_result        TYPE sy-binpt,
          lv_subj          TYPE string,
          lo_bcs_exception TYPE REF TO cx_bcs,
          lv_deep_url_link TYPE lcm_url..

    DATA: lv_mail_address TYPE ad_smtpadr.
    DATA: lv_address      TYPE REF TO cl_cam_address_bcs.
    DATA: lv_addname      TYPE ad_smtpadr.
    DATA lv_emailid TYPE adr6-smtp_addr.
    DATA lv_pspid TYPE /rpm/tv_extid.
    CONSTANTS: lc_new_line TYPE char255 VALUE '<br>',
               lc_htm      TYPE char3 VALUE 'HTM'.

    IF it_recipients IS INITIAL.
      RAISE no_recipients_found.
    ENDIF.

    " 4. Dynamic Workflow Action / Role
    CASE iv_curr_workflow_action .
      WHEN zif_ppm_variation_wf_c=>c_workflow_action-approver_phase.
        DATA(lv_wf_action_text) = zif_ppm_variation_wf_c=>c_workflow_action_text-approver_phase.
        DATA(lv_governancerole_text) = zif_ppm_variation_wf_c=>c_governance_role_action-pp_approver.
      WHEN zif_ppm_variation_wf_c=>c_workflow_action-approver_invest.
        lv_wf_action_text = zif_ppm_variation_wf_c=>c_workflow_action_text-approver_invest.
         lv_governancerole_text = zif_ppm_variation_wf_c=>c_governance_role_action-inv_approver.
      WHEN zif_ppm_variation_wf_c=>c_workflow_action-endorser .
        lv_wf_action_text = zif_ppm_variation_wf_c=>c_workflow_action_text-endorser .
        lv_governancerole_text = zif_ppm_variation_wf_c=>c_governance_role_action-pp_endorser.
      WHEN zif_ppm_variation_wf_c=>c_workflow_action-decpnt_manager.
        lv_wf_action_text = zif_ppm_variation_wf_c=>c_workflow_action_text-decpnt_manager.
         lv_governancerole_text = zif_ppm_variation_wf_c=>c_governance_role_action-initiator.
      WHEN zif_ppm_variation_wf_c=>c_workflow_action-interested.
        lv_wf_action_text = zif_ppm_variation_wf_c=>c_workflow_action_text-interested.
          lv_governancerole_text = zif_ppm_variation_wf_c=>c_governance_role_action-interest_party.
      WHEN OTHERS.
    ENDCASE.

*    Get project name
    "PROJ
    SELECT SINGLE  Post1 as ProjectDescription
