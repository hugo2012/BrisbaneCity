* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Public Method ZCL_PPM_VARIATION_WF->GETACTIONPARTIES
* +-------------------------------------------------------------------------------------------------+
* | [--->] IV_PPM_ITEM                    TYPE        /RPM/TV_EXTID
* | [--->] IV_GOVERN_ROLE                 TYPE        ZDP_GOV_ROLE(optional)
* | [<---] ET_ACTOR_TAB                   TYPE        ZPPM_TT_SWHACTOR
* +--------------------------------------------------------------------------------------</SIGNATURE>
  METHOD getactionparties.
    DATA(lo_clssobj) = NEW zcl_ppm_variation_wf( ).
    CALL METHOD lo_clssobj->get_governance_role
      EXPORTING
        iv_ppm_item    = iv_ppm_item               " Business Object ID
        iv_govern_role = iv_govern_role               " Governance Role
      IMPORTING
        et_proj_roles  = DATA(lt_proj_role).                " Maintain Project Roles for Portfolio Item
    IF lt_proj_role IS NOT INITIAL.
      DATA(ls_proj_role) = VALUE #( lt_proj_role[ workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-interested ] OPTIONAL ).

      SELECT COUNT( * )
       FROM I_HCMObject
       INTO @DATA(lv_pos_match_count)
       WHERE HCMPlanVersion = @zif_ppm_variation_wf_c=>c_plan_version_active AND
             HCMObjectType = @zif_ppm_variation_wf_c=>c_type_position AND
             HCMObjectID = @ls_proj_role-position_id AND
             StartDate <= @sy-datum AND
             EndDate >= @sy-datum.
      IF lv_pos_match_count > 0.
        CALL METHOD lo_clssobj->get_holders
          EXPORTING
            iv_position_id  = ls_proj_role-position_id                " Org.Position ID
          IMPORTING
            et_holders      = DATA(lt_holders)                " Variation holder
          EXCEPTIONS
            no_holder_found = 1                " No holder found
            OTHERS          = 2.
        IF sy-subrc IS INITIAL.
          " Fill actor table with verified users
          LOOP AT lt_holders INTO DATA(ls_holder) WHERE userid IS NOT INITIAL.
            APPEND VALUE #( otype = 'US' objid = ls_holder-userid ) TO et_actor_tab.
          ENDLOOP.
        ENDIF.
      ELSE.
        "MESSAGE i010(zppm_var) WITH ls_proj_role-position_id  .
      ENDIF.
    ENDIF.
  ENDMETHOD.                                             "#EC CI_VALPAR


* <SIGNATURE>---------------------------------------------------------------------------------------+
