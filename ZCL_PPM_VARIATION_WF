*       WITH SY-MSGV1 SY-MSGV2 SY-MSGV3 SY-MSGV4.
    ENDIF.

*  ---Update decision for the current step(action step)------------------------------------
    IF iv_decision_wi_result = zif_ppm_variation_wf_c=>c_decision_outcome_id-approve.
      IF iv_workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-endorser.
        DATA(lv_status) = zif_ppm_variation_wf_c=>c_step_status-endorsed.
      ELSEIF iv_workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-approver_phase
        OR  iv_workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-approver_invest.
        lv_status = zif_ppm_variation_wf_c=>c_step_status-approved.
      ENDIF.
    ELSEIF iv_decision_wi_result = zif_ppm_variation_wf_c=>c_decision_outcome_id-requestinformation.
      IF iv_workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-endorser.
        lv_status = zif_ppm_variation_wf_c=>c_step_status-more_info_req.
      ELSEIF iv_workflow_action = zif_ppm_variation_wf_c=>c_workflow_action-approver_phase
