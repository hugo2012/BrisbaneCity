* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Public Method ZCL_PPM_VARIATION_WF->VALID_VARIAT_TYPE_TRIGGER_WF
* +-------------------------------------------------------------------------------------------------+
* | [--->] IV_VARIATION_TYPE              TYPE        QMART
* | [--->] IV_VAR_REASON                  TYPE        /NOVECO/VAR_REASON
* | [<---] R_VARIATWFTYPE                 TYPE        ZDE_APPRV_PATH
* | [<---] R_RESULT                       TYPE        BOOLE_D
* +--------------------------------------------------------------------------------------</SIGNATURE>
  METHOD valid_variat_type_trigger_wf.

    SELECT  SINGLE VariationType, VarReason, WfTrigger, VariatWfType
      INTO @DATA(ls_variat_conf)
      FROM zi_ppm_variat_conf
      WHERE VariationType = @iv_variation_type
      AND varreason = @iv_var_reason
      AND  WfTrigger = @abap_true.
    IF sy-subrc IS INITIAL.
      r_result = abap_true.
      r_variatwftype = ls_variat_conf-variatwftype.
    ELSE.
      r_result = abap_false.
    ENDIF.
  ENDMETHOD.
